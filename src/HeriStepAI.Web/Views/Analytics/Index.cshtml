@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Analytics";
    var allPOIs       = ViewBag.AllPOIs      as Dictionary<string, int>    ?? new Dictionary<string, int>();
    var poiNames      = ViewBag.POINames     as Dictionary<string, string> ?? new Dictionary<string, string>();
    var geoByPoi      = ViewBag.GeofenceByPOI as Dictionary<string, int>  ?? new Dictionary<string, int>();
    var manualByPoi   = ViewBag.ManualByPOI  as Dictionary<string, int>   ?? new Dictionary<string, int>();
    var totalGeofence = (int)(ViewBag.TotalGeofence ?? 0);
    var totalManual   = (int)(ViewBag.TotalManual   ?? 0);
    var totalVisits   = (int)(ViewBag.TotalVisits   ?? 0);
    var totalPOIs     = (int)(ViewBag.TotalPOIs     ?? 0);
    var poisWithVisits = allPOIs.Where(x => x.Value > 0).OrderByDescending(x => x.Value).ToList();
    var poisNoVisits   = allPOIs.Where(x => x.Value == 0).ToList();
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Analytics</h1>
        <p class="page-subtitle-text">Thống kê chi tiết lượt ghé thăm tất cả địa điểm</p>
    </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="stat-card green">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                <span class="stat-badge">Tổng</span>
            </div>
            <div class="stat-number">@totalVisits</div>
            <div class="stat-label">Tổng lượt ghé thăm</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card blue">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-broadcast"></i></div>
                <span class="stat-badge">Tự động</span>
            </div>
            <div class="stat-number">@totalGeofence</div>
            <div class="stat-label">Geofence</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card amber">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-hand-index-thumb"></i></div>
                <span class="stat-badge">Thủ công</span>
            </div>
            <div class="stat-number">@totalManual</div>
            <div class="stat-label">Manual</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card red">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-shop"></i></div>
                <span class="stat-badge">POI</span>
            </div>
            <div class="stat-number">@totalPOIs</div>
            <div class="stat-label">@poisWithVisits.Count có lượt ghé</div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <span><i class="bi bi-pie-chart me-2" style="color:var(--amber);"></i>Phân loại lượt ghé</span>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                @if (totalVisits > 0)
                {
                    <canvas id="visitTypeChart" style="max-height:240px;"></canvas>
                }
                else
                {
                    <div class="text-center py-4">
                        <div style="width:48px;height:48px;border-radius:50%;background:var(--dark4);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                            <i class="bi bi-pie-chart" style="color:var(--cream-muted);font-size:1.25rem;"></i>
                        </div>
                        <p style="color:var(--cream-muted);font-size:0.82rem;margin:0;">Chưa có dữ liệu</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <span><i class="bi bi-bar-chart-steps me-2" style="color:var(--amber);"></i>Chi tiết theo địa điểm</span>
            </div>
            <div class="card-body">
                @if (poisWithVisits.Any())
                {
                    <canvas id="stackedChart" style="max-height:280px;"></canvas>
                }
                else
                {
                    <div class="text-center py-5">
                        <div style="width:48px;height:48px;border-radius:50%;background:var(--dark4);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                            <i class="bi bi-bar-chart" style="color:var(--cream-muted);font-size:1.25rem;"></i>
                        </div>
                        <p style="color:var(--cream-muted);font-size:0.82rem;margin:0;">Chưa có dữ liệu truy cập</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Stats Table -->
<div class="table-card">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--border);">
        <span style="font-size:0.92rem;font-weight:600;color:var(--cream);display:flex;align-items:center;gap:8px;">
            <i class="bi bi-table" style="color:var(--amber);"></i>Thống kê tất cả địa điểm
        </span>
        <div style="display:flex;gap:8px;">
            <span style="background:var(--green-dim);color:var(--green);font-size:0.7rem;font-weight:600;padding:3px 10px;border-radius:99px;">@poisWithVisits.Count có lượt</span>
            <span style="background:var(--cream-dim);color:var(--cream-muted);font-size:0.7rem;font-weight:600;padding:3px 10px;border-radius:99px;">@poisNoVisits.Count chưa có</span>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th style="width:50px;padding-left:24px;">#</th>
                    <th>Địa điểm</th>
                    <th class="text-center" style="width:90px;">Tổng</th>
                    <th class="text-center" style="width:110px;">Geofence</th>
                    <th class="text-center" style="width:100px;">Manual</th>
                    <th class="text-center" style="width:200px;">Tỷ lệ</th>
                </tr>
            </thead>
            <tbody>
                @{ var rank = 1; }
                @foreach (var kvp in poisWithVisits)
                {
                    var name   = poiNames.ContainsKey(kvp.Key) ? poiNames[kvp.Key] : $"POI {kvp.Key}";
                    var geo    = geoByPoi.ContainsKey(kvp.Key)    ? geoByPoi[kvp.Key]    : 0;
                    var manual = manualByPoi.ContainsKey(kvp.Key) ? manualByPoi[kvp.Key] : 0;
                    var total  = kvp.Value;
                    var geoPct = total > 0 ? (geo * 100.0 / total) : 0;
                    var manPct = total > 0 ? (manual * 100.0 / total) : 0;
                    <tr>
                        <td style="padding-left:24px;">
                            @if (rank == 1)      { <span style="font-size:1.1rem;">🥇</span> }
                            else if (rank == 2)  { <span style="font-size:1.1rem;">🥈</span> }
                            else if (rank == 3)  { <span style="font-size:1.1rem;">🥉</span> }
                            else                 { <span style="color:var(--cream-muted);font-size:0.875rem;">@rank</span> }
                        </td>
                        <td style="font-weight:600;color:var(--cream);">@name</td>
                        <td class="text-center" style="font-weight:700;color:var(--cream);">@total</td>
                        <td class="text-center">
                            <span style="background:var(--green-dim);color:var(--green);border-radius:99px;padding:3px 10px;font-size:0.7rem;font-weight:600;">
                                <i class="bi bi-broadcast"></i> @geo
                            </span>
                        </td>
                        <td class="text-center">
                            <span style="background:var(--amber-dim);color:var(--amber);border-radius:99px;padding:3px 10px;font-size:0.7rem;font-weight:600;">
                                <i class="bi bi-hand-index-thumb"></i> @manual
                            </span>
                        </td>
                        <td>
                            <div style="height:6px;border-radius:99px;overflow:hidden;background:var(--dark4);display:flex;">
                                <div style="width:@geoPct.ToString("F0")%;background:var(--green);transition:width 0.3s;"></div>
                                <div style="width:@manPct.ToString("F0")%;background:var(--amber);transition:width 0.3s;"></div>
                            </div>
                        </td>
                    </tr>
                    rank++;
                }
                @foreach (var kvp in poisNoVisits)
                {
                    var name = poiNames.ContainsKey(kvp.Key) ? poiNames[kvp.Key] : $"POI {kvp.Key}";
                    <tr style="opacity:0.45;">
                        <td style="padding-left:24px;color:var(--cream-muted);font-size:0.875rem;">@rank</td>
                        <td style="color:var(--cream-muted);">@name</td>
                        <td class="text-center" style="color:var(--cream-muted);font-weight:600;">0</td>
                        <td class="text-center"><span style="color:var(--cream-muted);font-size:0.8rem;">—</span></td>
                        <td class="text-center"><span style="color:var(--cream-muted);font-size:0.8rem;">—</span></td>
                        <td><div style="height:6px;border-radius:99px;background:var(--dark4);"></div></td>
                    </tr>
                    rank++;
                }
            </tbody>
        </table>
    </div>
    <div style="padding:12px 24px;border-top:1px solid var(--border);display:flex;gap:16px;font-size:0.75rem;color:var(--cream-muted);">
        <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:var(--green);margin-right:4px;"></span>Geofence (Tự động)</span>
        <span><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:var(--amber);margin-right:4px;"></span>Manual (Thủ công)</span>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script>
        @if (totalVisits > 0)
        {
            <text>
            new Chart(document.getElementById('visitTypeChart').getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: ['Geofence', 'Manual'],
                    datasets: [{
                        data: [@totalGeofence, @totalManual],
                        backgroundColor: ['#10b981', '#4f46e5'],
                        borderWidth: 0,
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true, cutout: '68%',
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 16, font: { size: 12 }, color: '#64748b' } }
                    }
                }
            });
            </text>
        }

        @if (poisWithVisits.Any())
        {
            <text>
            const poiNamesMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(poiNames));
            const allData     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allPOIs));
            const geoData     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(geoByPoi));
            const manualData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(manualByPoi));

            const poiIds = Object.keys(allData).filter(id => allData[id] > 0).sort((a,b) => allData[b]-allData[a]);
            const labels = poiIds.map(id => {
                const n = poiNamesMap[id] || `POI ${id}`;
                return n.length > 18 ? n.substring(0,16)+'…' : n;
            });

            new Chart(document.getElementById('stackedChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels,
                    datasets: [
                        { label: 'Geofence', data: poiIds.map(id => geoData[id] || 0), backgroundColor: '#10b981', borderRadius: { topLeft:0,topRight:0,bottomLeft:4,bottomRight:4 }, borderSkipped:false },
                        { label: 'Manual',   data: poiIds.map(id => manualData[id] || 0), backgroundColor: '#4f46e5', borderRadius: { topLeft:4,topRight:4,bottomLeft:0,bottomRight:0 }, borderSkipped:false }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position:'bottom', labels:{ usePointStyle:true, padding:20, font:{size:12}, color:'#64748b' } } },
                    scales: {
                        x: { stacked:true, grid:{display:false}, ticks:{ maxRotation:35, color:'#64748b', font:{size:11} }, border:{ color:'#e2e8f0' } },
                        y: { stacked:true, beginAtZero:true, ticks:{ precision:0, color:'#64748b', font:{size:11} }, grid:{ color:'rgba(0,0,0,0.05)' }, border:{ color:'transparent' } }
                    }
                }
            });
            </text>
        }
    </script>
}
