@model List<HeriStepAI.Web.Models.DeviceRow>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Người dùng thiết bị";
    var summary     = ViewBag.Summary as HeriStepAI.Web.Models.DeviceSummary;
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages  = ViewBag.TotalPages  ?? 1;
    var tourists    = ViewBag.Tourists as List<HeriStepAI.Web.Models.TouristRow> ?? new();
    int strongCount = tourists.Count(t => t.DeviceProfile == "Strong");
    int weakCount   = tourists.Count(t => t.DeviceProfile == "Weak");
    int unknownCount = tourists.Count(t => t.DeviceProfile == null);
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Người dùng thiết bị</h1>
        <p class="page-subtitle-text">Người dùng app được nhận diện ẩn danh theo Device ID — mỗi thiết bị là một người dùng.</p>
    </div>
    <a href="@Url.Action("Dashboard", "Home")" class="btn btn-outline-light btn-sm">← Dashboard</a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (summary != null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-2">
            <div class="stat-card" style="border-color:#22c55e;background:linear-gradient(135deg,rgba(34,197,94,0.15),rgba(34,197,94,0.05));">
                <div class="stat-top">
                    <div class="stat-icon" style="color:#22c55e;"><i class="bi bi-circle-fill"></i></div>
                    <span class="stat-badge" style="background:rgba(34,197,94,0.2);color:#22c55e;">Live</span>
                </div>
                <div class="stat-number" id="online-now-count" style="color:#22c55e;">—</div>
                <div class="stat-label">Đang dùng app</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card blue">
                <div class="stat-top">
                    <div class="stat-icon"><i class="bi bi-phone-fill"></i></div>
                    <span class="stat-badge">Tổng</span>
                </div>
                <div class="stat-number">@summary.TotalDevices</div>
                <div class="stat-label">Thiết bị đã dùng app</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card green">
                <div class="stat-top">
                    <div class="stat-icon"><i class="bi bi-calendar-day"></i></div>
                    <span class="stat-badge">Hôm nay</span>
                </div>
                <div class="stat-number">@summary.ActiveToday</div>
                <div class="stat-label">Hoạt động hôm nay</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card amber">
                <div class="stat-top">
                    <div class="stat-icon"><i class="bi bi-calendar-week"></i></div>
                    <span class="stat-badge">7 ngày</span>
                </div>
                <div class="stat-number">@summary.ActiveThisWeek</div>
                <div class="stat-label">Hoạt động 7 ngày qua</div>
            </div>
        </div>
        <div class="col-6 col-md-2">
            <div class="stat-card red">
                <div class="stat-top">
                    <div class="stat-icon"><i class="bi bi-calendar-month"></i></div>
                    <span class="stat-badge">30 ngày</span>
                </div>
                <div class="stat-number">@summary.ActiveThisMonth</div>
                <div class="stat-label">Hoạt động 30 ngày qua</div>
            </div>
        </div>
    </div>
}

@section Scripts {
<script>
    async function fetchOnlineNow() {
        try {
            const res = await fetch('/Devices/OnlineNow');
            if (res.ok) {
                const data = await res.json();
                document.getElementById('online-now-count').textContent = data.onlineNow ?? 0;
            }
        } catch { }
    }

    fetchOnlineNow();
    setInterval(fetchOnlineNow, 3000);
</script>
}

<div class="table-card">
    <div class="table-responsive">
        <table class="table" style="table-layout:fixed;width:100%;">
            <colgroup>
                <col style="width:4%;">
                <col style="width:26%;">
                <col style="width:16%;">
                <col style="width:10%;">
                <col style="width:10%;">
                <col style="width:17%;">
                <col style="width:17%;">
            </colgroup>
            <thead>
                <tr>
                    <th style="padding-left:20px;">#</th>
                    <th>Device ID</th>
                    <th style="text-align:center;">Thiết bị</th>
                    <th style="text-align:center;">Lượt thăm</th>
                    <th style="text-align:center;">POI đã ghé</th>
                    <th>Lần đầu</th>
                    <th>Lần cuối</th>
                </tr>
            </thead>
            <tbody>
                @{
                    int startIndex = (currentPage - 1) * 50;
                }
                @foreach (var (row, i) in Model.Select((r, idx) => (r, idx)))
                {
                    var daysSince = (DateTime.UtcNow - row.LastSeen).TotalDays;
                    var isActive  = daysSince <= 7;
                    <tr>
                        <td style="padding-left:20px;color:var(--cream-muted);font-size:0.78rem;">
                            @(startIndex + i + 1)
                        </td>
                        <td>
                            <a href="@Url.Action("Detail", "Devices", new { id = row.DeviceId })" style="text-decoration:none;">
                                <code style="font-size:0.72rem;background:var(--dark4);padding:3px 8px;border-radius:5px;color:var(--amber);display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@row.DeviceId">
                                    @row.DeviceId
                                </code>
                            </a>
                        </td>
                        <td style="text-align:center;">
                            @if (row.DeviceProfile == "Strong")
                            {
                                <span style="background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#4ade80;padding:2px 8px;border-radius:10px;font-size:0.7rem;white-space:nowrap;" title="@row.DeviceCores core · ~@row.DeviceRamMb MB">
                                    <i class="bi bi-cpu-fill"></i> Mạnh
                                </span>
                            }
                            else if (row.DeviceProfile == "Weak")
                            {
                                <span style="background:rgba(234,179,8,0.12);border:1px solid rgba(234,179,8,0.3);color:#facc15;padding:2px 8px;border-radius:10px;font-size:0.7rem;white-space:nowrap;" title="@row.DeviceCores core · ~@row.DeviceRamMb MB">
                                    <i class="bi bi-wifi"></i> Yếu
                                </span>
                            }
                            else
                            {
                                <span style="color:var(--cream-muted);font-size:0.72rem;">—</span>
                            }
                        </td>
                        <td style="text-align:center;">
                            <span style="font-weight:600;color:var(--cream);">@row.VisitCount</span>
                        </td>
                        <td style="text-align:center;">
                            <span class="badge-soft-info">@row.UniquePOIs POI</span>
                        </td>
                        <td style="font-size:0.78rem;color:var(--cream-muted);white-space:nowrap;">
                            @row.FirstSeen.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td style="white-space:nowrap;">
                            <div style="font-size:0.78rem;color:var(--cream);">
                                @row.LastSeen.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </div>
                            @if (isActive)
                            {
                                <span class="badge-soft-success" style="font-size:0.65rem;margin-top:2px;">
                                    <i class="bi bi-circle-fill" style="font-size:0.45rem;vertical-align:middle;"></i> Active
                                </span>
                            }
                            else
                            {
                                <span style="font-size:0.68rem;color:var(--cream-muted);margin-top:2px;display:inline-block;">
                                    @((int)daysSince) ngày trước
                                </span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-5" style="color:var(--cream-muted);">
                            <i class="bi bi-phone" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.4;"></i>
                            Chưa có thiết bị nào ghé thăm POI.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <div style="padding:16px 20px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px;">
            <span style="font-size:0.78rem;color:var(--cream-muted);">
                Trang @currentPage / @totalPages
            </span>
            <div class="d-flex gap-2">
                @if (currentPage > 1)
                {
                    <a href="@Url.Action("Index", new { page = currentPage - 1 })" class="btn btn-ghost btn-sm">← Trước</a>
                }
                @if (currentPage < totalPages)
                {
                    <a href="@Url.Action("Index", new { page = currentPage + 1 })" class="btn btn-ghost btn-sm">Tiếp →</a>
                }
            </div>
        </div>
    }
</div>

<!-- TOURIST ACCOUNTS + DEVICE PROFILE -->
<div style="margin-top:32px;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px;">
        <div>
            <h2 style="font-family:'Playfair Display',serif;font-size:1.3rem;color:var(--cream);margin:0;">Tài khoản Du khách</h2>
            <p style="font-size:0.78rem;color:var(--cream-muted);margin:4px 0 0;">Năng lực thiết bị được gửi tự động sau khi đăng nhập app.</p>
        </div>
        <div style="display:flex;gap:10px;">
            <span style="background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#4ade80;padding:5px 12px;border-radius:20px;font-size:0.78rem;">
                <i class="bi bi-cpu-fill"></i> Mạnh: @strongCount
            </span>
            <span style="background:rgba(234,179,8,0.15);border:1px solid rgba(234,179,8,0.3);color:#facc15;padding:5px 12px;border-radius:20px;font-size:0.78rem;">
                <i class="bi bi-wifi"></i> Yếu: @weakCount
            </span>
            @if (unknownCount > 0)
            {
                <span style="background:rgba(148,163,184,0.1);border:1px solid rgba(148,163,184,0.2);color:var(--cream-muted);padding:5px 12px;border-radius:20px;font-size:0.78rem;">
                    Chưa rõ: @unknownCount
                </span>
            }
        </div>
    </div>

    <div class="table-card">
        <div class="table-responsive">
            <table class="table" style="table-layout:fixed;width:100%;">
                <colgroup>
                    <col style="width:4%;">
                    <col style="width:20%;">
                    <col style="width:22%;">
                    <col style="width:14%;">
                    <col style="width:18%;">
                    <col style="width:22%;">
                </colgroup>
                <thead>
                    <tr>
                        <th style="padding-left:20px;">#</th>
                        <th>Tên / Email</th>
                        <th style="text-align:center;">Thiết bị</th>
                        <th style="text-align:center;">CPU / RAM</th>
                        <th>Cập nhật lúc</th>
                        <th>Ngày đăng ký</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (t, i) in tourists.Select((r, idx) => (r, idx)))
                    {
                        var isStrong  = t.DeviceProfile == "Strong";
                        var isWeak    = t.DeviceProfile == "Weak";
                        var hasProfile = t.DeviceProfile != null;
                        <tr>
                            <td style="padding-left:20px;color:var(--cream-muted);font-size:0.78rem;">@(i + 1)</td>
                            <td>
                                <div style="font-size:0.85rem;color:var(--cream);font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@t.FullName">
                                    @(t.FullName ?? t.Username)
                                </div>
                                <div style="font-size:0.72rem;color:var(--cream-muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@t.Email">
                                    @t.Email
                                </div>
                            </td>
                            <td style="text-align:center;">
                                @if (isStrong)
                                {
                                    <span style="background:rgba(34,197,94,0.15);border:1px solid rgba(34,197,94,0.3);color:#4ade80;padding:3px 10px;border-radius:12px;font-size:0.75rem;white-space:nowrap;">
                                        <i class="bi bi-cpu-fill"></i> Mạnh · Offline
                                    </span>
                                }
                                else if (isWeak)
                                {
                                    <span style="background:rgba(234,179,8,0.12);border:1px solid rgba(234,179,8,0.3);color:#facc15;padding:3px 10px;border-radius:12px;font-size:0.75rem;white-space:nowrap;">
                                        <i class="bi bi-wifi"></i> Yếu · Online only
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--cream-muted);font-size:0.75rem;">—</span>
                                }
                            </td>
                            <td style="text-align:center;font-size:0.78rem;color:var(--cream-muted);">
                                @if (hasProfile)
                                {
                                    <span>@t.DeviceCores core</span><br>
                                    <span>~@t.DeviceRamMb MB</span>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </td>
                            <td style="font-size:0.75rem;color:var(--cream-muted);white-space:nowrap;">
                                @(t.DeviceProfileAt.HasValue
                                    ? t.DeviceProfileAt.Value.ToLocalTime().ToString("dd/MM HH:mm")
                                    : "Chưa cập nhật")
                            </td>
                            <td style="font-size:0.75rem;color:var(--cream-muted);white-space:nowrap;">
                                @t.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")
                                @if (!t.IsActive)
                                {
                                    <span style="color:#f87171;font-size:0.68rem;display:block;">Bị khóa</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!tourists.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5" style="color:var(--cream-muted);">
                                <i class="bi bi-people" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.4;"></i>
                                Chưa có tài khoản du khách nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
