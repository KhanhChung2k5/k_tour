@model HeriStepAI.API.Models.POI
@{
    ViewData["Title"] = "Chỉnh sửa cửa hàng";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="mb-0"><i class="bi bi-pencil"></i> Chỉnh sửa cửa hàng</h2>
                    <p class="text-muted">Cập nhật thông tin cửa hàng của bạn</p>
                </div>
                <a href="@Url.Action("Dashboard")" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
            </div>

            <!-- Edit Form -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <!-- Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Tên cửa hàng <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control form-control-lg" required />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Mô tả về cửa hàng, món ăn đặc trưng..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <!-- Address -->
                        <div class="mb-3">
                            <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                            <input asp-for="Address" class="form-control"
                                   placeholder="Số nhà, đường, quận, thành phố" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <!-- Image URL -->
                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-bold">Link ảnh</label>
                            <input asp-for="ImageUrl" class="form-control"
                                   placeholder="https://example.com/image.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <div class="mt-2">
                                    <img src="@Model.ImageUrl" alt="Preview"
                                         class="img-thumbnail" style="max-height: 200px;" />
                                </div>
                            }
                        </div>

                        <!-- Food Type -->
                        <div class="mb-3">
                            <label asp-for="FoodType" class="form-label fw-bold">Loại món ăn</label>
                            <select asp-for="FoodType" class="form-select">
                                <option value="0">Khác</option>
                                <option value="1">Hải sản</option>
                                <option value="2">Món chay</option>
                                <option value="3">Đặc sản Việt Nam</option>
                                <option value="4">Ẩm thực đường phố</option>
                                <option value="5">Đồ nướng (BBQ)</option>
                                <option value="6">Bún, Phở, Mì</option>
                            </select>
                        </div>

                        <!-- Price Range -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="PriceMin" class="form-label fw-bold">Giá từ (VNĐ)</label>
                                <input asp-for="PriceMin" type="number" class="form-control"
                                       placeholder="20,000" min="0" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PriceMax" class="form-label fw-bold">Giá đến (VNĐ)</label>
                                <input asp-for="PriceMax" type="number" class="form-control"
                                       placeholder="100,000" min="0" />
                            </div>
                        </div>

                        <!-- Estimated Minutes -->
                        <div class="mb-4">
                            <label asp-for="EstimatedMinutes" class="form-label fw-bold">Thời gian tham quan (phút)</label>
                            <input asp-for="EstimatedMinutes" type="number" class="form-control"
                                   placeholder="30" min="5" max="300" />
                            <small class="text-muted">Thời gian dự kiến khách sẽ ở lại cửa hàng</small>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Dashboard")" class="btn btn-lg btn-outline-secondary">
                                <i class="bi bi-x"></i> Hủy
                            </a>
                            <button type="submit" class="btn btn-lg btn-primary">
                                <i class="bi bi-check-lg"></i> Lưu thay đổi
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success mt-3" role="alert">
                    <i class="bi bi-check-circle"></i> @TempData["Success"]
                </div>
            }

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
