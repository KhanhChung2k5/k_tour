@model HeriStepAI.Web.Models.ShopOwnerPOICreateViewModel
@{
    Layout = "_ShopOwnerLayout";
    ViewData["Title"] = "Thêm địa điểm";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Thêm địa điểm</li>
    </ol>
</nav>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-4" role="alert">@TempData["Error"]</div>
}

<form method="post" asp-controller="ShopOwner" asp-action="Create" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-geo-alt-fill me-2" style="color:var(--accent);"></i>Thông tin cơ bản
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Tên POI <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Quán Bún Bò Huế Đông Ba" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="3" required placeholder="Mô tả ngắn gọn về địa điểm..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input asp-for="Address" class="form-control" placeholder="Số nhà, đường, phường, quận..." />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                            <input asp-for="Latitude" type="number" step="any" class="form-control" required placeholder="16.0544" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                            <input asp-for="Longitude" type="number" step="any" class="form-control" required placeholder="108.2022" />
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Bán kính geofence (m)</label>
                        <input asp-for="Radius" type="number" class="form-control" />
                        <div class="small mt-1" style="color:var(--text-muted);">Bán kính kích hoạt thuyết minh tự động</div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <i class="bi bi-translate me-2" style="color:var(--blue);"></i>Nội dung thuyết minh
                </div>
                <div class="card-body">
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item"><button type="button" class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-vi">🇻🇳 Việt</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-en">🇬🇧 EN</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-ko">🇰🇷 KO</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-zh">🇨🇳 ZH</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-ja">🇯🇵 JA</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-th">🇹🇭 TH</button></li>
                        <li class="nav-item"><button type="button" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-fr">🇫🇷 FR</button></li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tab-vi">
                            <textarea asp-for="TextContent_vi" class="form-control" rows="5" placeholder="Nội dung thuyết minh tiếng Việt..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-en">
                            <textarea asp-for="TextContent_en" class="form-control" rows="5" placeholder="English narration..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-ko">
                            <textarea asp-for="TextContent_ko" class="form-control" rows="5" placeholder="한국어..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-zh">
                            <textarea asp-for="TextContent_zh" class="form-control" rows="5" placeholder="中文..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-ja">
                            <textarea asp-for="TextContent_ja" class="form-control" rows="5" placeholder="日本語..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-th">
                            <textarea asp-for="TextContent_th" class="form-control" rows="5" placeholder="ไทย..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-fr">
                            <textarea asp-for="TextContent_fr" class="form-control" rows="5" placeholder="Français..."></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-tag-fill me-2" style="color:var(--accent);"></i>Phân loại &amp; cài đặt
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Loại POI <span class="text-danger">*</span></label>
                        <select asp-for="Category" class="form-select" id="categorySelect" required>
                            <option value="0">Tất cả</option>
                            <option value="1">Tham quan</option>
                            <option value="2" selected>Ẩm thực</option>
                            <option value="3">Nghỉ dưỡng</option>
                            <option value="4">Mua sắm</option>
                            <option value="5">Giải trí</option>
                            <option value="6">Di tích lịch sử</option>
                            <option value="7">Thiên nhiên</option>
                        </select>
                    </div>
                    <div class="mb-3" id="foodTypeDiv">
                        <label class="form-label">Loại món ăn</label>
                        <select asp-for="FoodType" class="form-select">
                            <option value="0">Khác</option>
                            <option value="1">Hải sản</option>
                            <option value="2">Món chay</option>
                            <option value="3">Đặc sản</option>
                            <option value="4">Đường phố</option>
                            <option value="5">Nướng</option>
                            <option value="6">Bún/Phở/Mì</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-3" id="priceDiv">
                        <div class="col-6">
                            <label class="form-label">Giá min (VND)</label>
                            <input asp-for="PriceMin" type="number" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Giá max (VND)</label>
                            <input asp-for="PriceMax" type="number" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thời gian tham quan (phút)</label>
                        <input asp-for="EstimatedMinutes" type="number" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ưu tiên</label>
                        <select asp-for="Priority" class="form-select">
                            <option value="1" selected>Thấp</option>
                            <option value="2">Trung bình</option>
                            <option value="3">Cao</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Link Google Maps</label>
                        <input asp-for="MapLink" type="url" class="form-control" placeholder="https://maps.google.com/..." />
                    </div>
                    <div class="d-flex align-items-center gap-2 p-3 rounded" style="background:var(--input-bg);border:1px solid var(--border);">
                        <input asp-for="IsActive" class="form-check-input m-0" type="checkbox" style="width:18px;height:18px;" />
                        <label class="form-label m-0" style="cursor:pointer;color:var(--text-muted);">
                            <i class="bi bi-check-circle-fill me-1" style="color:var(--green);"></i>Kích hoạt ngay
                        </label>
                    </div>
                </div>
            </div>

            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-image me-2" style="color:var(--blue);"></i>Hình ảnh
                </div>
                <div class="card-body">
                    <div id="imagePreview" class="mb-3" style="display:none;">
                        <img id="previewImg" src="" alt="Preview" style="width:100%;height:180px;object-fit:cover;border-radius:8px;border:1px solid var(--border);" />
                    </div>
                    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('imageFileInput').click()">
                        <i class="bi bi-cloud-upload" style="font-size:1.5rem;color:var(--text-muted);margin-bottom:8px;"></i>
                        <div style="font-size:0.813rem;color:var(--text-muted);font-weight:500;">Nhấn để chọn ảnh</div>
                        <div style="font-size:0.75rem;color:var(--text-muted);opacity:0.6;">JPG, PNG, WebP · Tối đa 5MB</div>
                    </div>
                    <input type="file" name="ImageFile" id="imageFileInput" accept="image/*" style="display:none;" />
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn-save">
                    <i class="bi bi-plus-circle me-2"></i>Lưu địa điểm
                </button>
                <a asp-action="Dashboard" class="btn-back">Quay lại Dashboard</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('categorySelect').addEventListener('change', function () {
            const isFood = this.value == '2';
            document.getElementById('foodTypeDiv').style.display = isFood ? 'block' : 'none';
            document.getElementById('priceDiv').style.display = isFood ? 'flex' : 'none';
        });
        document.getElementById('categorySelect').dispatchEvent(new Event('change'));

        document.getElementById('imageFileInput').addEventListener('change', function () {
            const file = this.files[0];
            if (!file || !file.type.startsWith('image/')) return;
            if (file.size > 5 * 1024 * 1024) { alert('File quá lớn! Tối đa 5MB.'); this.value = ''; return; }
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('previewImg').src = e.target.result;
                document.getElementById('imagePreview').style.display = 'block';
                document.getElementById('uploadZone').style.display = 'none';
            };
            reader.readAsDataURL(file);
        });
    </script>
}
