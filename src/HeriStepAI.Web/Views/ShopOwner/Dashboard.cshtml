@model List<HeriStepAI.Web.ViewModels.ShopOwnerPOIViewModel>
@{
    ViewData["Title"] = "Dashboard - Chủ cửa hàng";
    var totalPOIs   = (int)(ViewBag.TotalPOIs   ?? 0);
    var totalVisits = (int)(ViewBag.TotalVisits  ?? 0);
    var activePOIs  = (int)(ViewBag.ActivePOIs   ?? 0);
    var userInitial = User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "U";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HeriStepAI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --amber: #E8A14B;
            --amber-light: #F2C47E;
            --amber-dim: rgba(232,161,75,0.13);
            --dark: #0D0B08;
            --dark2: #131008;
            --dark3: #1C1710;
            --dark4: #231C10;
            --topbar: #0F0C07;
            --cream: #F5ECD7;
            --cream-muted: #9A8A70;
            --cream-dim: rgba(245,236,215,0.05);
            --green: #2ECC94;
            --green-dim: rgba(46,204,148,0.1);
            --red: #E05252;
            --blue: #5B9CF0;
            --blue-dim: rgba(91,156,240,0.1);
            --border: rgba(232,161,75,0.1);
            --border-soft: rgba(232,161,75,0.18);
        }
        *, *::before, *::after { box-sizing: border-box; }
        * { font-family: 'Be Vietnam Pro', sans-serif; }
        body { background: var(--dark2); color: var(--cream); margin: 0; min-height: 100vh; }

        /* Topbar */
        .so-navbar {
            background: var(--topbar);
            border-bottom: 1px solid var(--border);
            height: 64px;
            display: flex; align-items: center;
            padding: 0 32px;
            position: sticky; top: 0; z-index: 100;
            justify-content: space-between;
        }
        .so-navbar::after {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--amber), transparent);
            opacity: 0.2;
            pointer-events: none;
        }
        .so-brand { display: flex; align-items: center; gap: 12px; text-decoration: none; }
        .so-brand-icon {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--amber), #B8721A);
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            color: var(--dark); font-size: 1rem;
            box-shadow: 0 3px 10px rgba(232,161,75,0.3);
        }
        .so-brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.2rem; font-weight: 700;
            color: var(--cream); letter-spacing: -0.01em;
        }
        .so-brand-name span { color: var(--amber); }
        .so-right { display: flex; align-items: center; gap: 16px; }
        .so-user {
            display: flex; align-items: center; gap: 10px;
            padding: 6px 14px; border-radius: 8px;
            border: 1px solid var(--border); background: var(--cream-dim);
        }
        .so-user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: linear-gradient(135deg, var(--amber), #B8721A);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.72rem; font-weight: 700; color: var(--dark);
        }
        .so-user-name { font-size: 0.82rem; color: var(--cream-muted); }
        .btn-logout {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 8px 16px; border-radius: 8px;
            border: 1px solid var(--border-soft); background: transparent;
            color: var(--cream-muted);
            font-size: 0.8rem; cursor: pointer; transition: all .2s;
        }
        .btn-logout:hover { border-color: rgba(224,82,82,0.4); color: var(--red); }

        /* Content */
        .so-content { max-width: 1300px; margin: 0 auto; padding: 32px; }

        /* Page header */
        .page-title {
            font-family: 'Playfair Display', serif;
            font-size: 1.75rem; font-weight: 700;
            color: var(--cream); line-height: 1.2; margin: 0 0 6px;
        }
        .page-subtitle { font-size: 0.82rem; color: var(--cream-muted); font-weight: 300; margin: 0; }

        /* Stat cards */
        .stat-card {
            border-radius: 14px; padding: 26px;
            position: relative; overflow: hidden;
            transition: transform 0.2s;
        }
        .stat-card:hover { transform: translateY(-2px); }
        .stat-card.amber { background: linear-gradient(135deg, #2A1E08 0%, #1C1710 100%); border: 1px solid rgba(232,161,75,0.25); }
        .stat-card.green { background: linear-gradient(135deg, #0A1E14 0%, #0D1710 100%); border: 1px solid rgba(46,204,148,0.2); }
        .stat-card.blue  { background: linear-gradient(135deg, #0A1422 0%, #0D1219 100%); border: 1px solid rgba(91,156,240,0.2); }
        .stat-card::before {
            content: ''; position: absolute;
            top: 0; left: 0; right: 0; height: 2px;
            border-radius: 14px 14px 0 0;
        }
        .stat-card.amber::before { background: linear-gradient(90deg, var(--amber), transparent); }
        .stat-card.green::before { background: linear-gradient(90deg, var(--green), transparent); }
        .stat-card.blue::before  { background: linear-gradient(90deg, var(--blue), transparent); }
        .stat-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
        .stat-icon { width: 38px; height: 38px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 1rem; }
        .stat-card.amber .stat-icon { background: rgba(232,161,75,0.15); color: var(--amber); }
        .stat-card.green .stat-icon { background: rgba(46,204,148,0.12); color: var(--green); }
        .stat-card.blue  .stat-icon { background: rgba(91,156,240,0.12); color: var(--blue); }
        .stat-badge {
            font-size: 0.68rem; font-weight: 600; padding: 3px 10px;
            border-radius: 99px; letter-spacing: 0.05em;
        }
        .stat-card.amber .stat-badge { background: rgba(232,161,75,0.12); color: var(--amber); }
        .stat-card.green .stat-badge { background: rgba(46,204,148,0.1); color: var(--green); }
        .stat-card.blue  .stat-badge { background: rgba(91,156,240,0.1); color: var(--blue); }
        .stat-value {
            font-family: 'Playfair Display', serif;
            font-size: 2.4rem; font-weight: 700; line-height: 1; margin-bottom: 6px;
        }
        .stat-card.amber .stat-value { color: var(--amber-light); }
        .stat-card.green .stat-value { color: var(--green); }
        .stat-card.blue  .stat-value { color: var(--blue); }
        .stat-label { font-size: 0.78rem; color: var(--cream-muted); font-weight: 400; }

        /* Section card */
        .section-card {
            background: var(--dark3);
            border: 1px solid var(--border);
            border-radius: 14px; overflow: hidden;
        }
        .section-header {
            padding: 18px 24px;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
        }
        .section-title {
            font-size: 0.9rem; font-weight: 600; color: var(--cream);
            display: flex; align-items: center; gap: 8px;
        }
        .count-badge {
            width: 26px; height: 26px; border-radius: 50%;
            background: var(--amber); color: var(--dark);
            font-size: 0.75rem; font-weight: 700;
            display: flex; align-items: center; justify-content: center;
        }

        /* Table — override Bootstrap 5.3 white-cell defaults */
        .table {
            margin: 0; width: 100%;
            --bs-table-bg: transparent;
            --bs-table-color: var(--cream);
            --bs-table-border-color: transparent;
            --bs-table-striped-bg: transparent;
            --bs-table-hover-bg: var(--cream-dim);
            --bs-table-accent-bg: transparent;
            color: var(--cream);
        }
        .table thead tr { border-bottom: 1px solid var(--border); }
        .table thead tr th {
            background: transparent !important;
            padding: 12px 20px;
            font-size: 0.68rem; letter-spacing: 0.12em;
            text-transform: uppercase; color: var(--cream-muted);
            font-weight: 600; white-space: nowrap;
            border-bottom: 1px solid var(--border) !important;
        }
        .table tbody tr { border-bottom: 1px solid rgba(232,161,75,0.05); transition: background .15s; }
        .table tbody tr:last-child { border-bottom: none; }
        .table tbody tr:hover { background: var(--cream-dim) !important; }
        .table tbody td {
            padding: 16px 20px; font-size: 0.84rem;
            color: var(--cream); vertical-align: middle;
            background-color: transparent !important;
            border-color: transparent !important;
        }

        /* Badges */
        .food-tag {
            display: inline-block; padding: 3px 10px;
            border-radius: 99px; font-size: 0.72rem; font-weight: 600;
            background: var(--amber-dim); color: var(--amber);
            border: 1px solid rgba(232,161,75,0.18);
        }
        .badge-soft-warning {
            background: rgba(232,161,75,0.1); color: var(--amber);
            border-radius: 6px; padding: 3px 8px; font-size: .75rem; font-weight: 500;
        }
        .badge-soft-info {
            background: var(--blue-dim); color: var(--blue);
            border-radius: 6px; padding: 3px 8px; font-size: .75rem; font-weight: 500;
        }
        .status-pill {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 4px 12px; border-radius: 99px;
            font-size: 0.75rem; font-weight: 600;
        }
        .status-pill.active   { background: var(--green-dim); color: var(--green); }
        .status-pill.inactive { background: rgba(245,236,215,0.06); color: var(--cream-muted); }
        .status-pill::before  { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }

        /* Action buttons */
        .act-btn {
            width: 32px; height: 32px; border-radius: 7px;
            border: 1px solid var(--border); background: transparent;
            cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
            font-size: 0.85rem; transition: all .15s; color: var(--cream-muted);
            text-decoration: none;
        }
        .act-btn:hover { border-color: var(--border-soft); color: var(--amber); background: var(--amber-dim); }
        .act-btn.stat:hover { color: var(--blue); background: var(--blue-dim); border-color: rgba(91,156,240,0.3); }

        /* Shop cell */
        .shop-thumb { width: 42px; height: 42px; border-radius: 10px; border: 1px solid var(--border); flex-shrink: 0; object-fit: cover; }
        .shop-avatar {
            width: 42px; height: 42px; border-radius: 10px;
            border: 1px solid var(--border); flex-shrink: 0;
            background: var(--amber-dim); color: var(--amber);
            font-weight: 700; font-size: 1rem;
            display: flex; align-items: center; justify-content: center;
        }

        /* Empty state */
        .empty-icon {
            width: 56px; height: 56px; border-radius: 50%;
            background: var(--amber-dim);
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 14px; font-size: 1.5rem; color: var(--amber);
        }
    </style>
</head>
<body>
    <!-- Topbar -->
    <nav class="so-navbar">
        <a href="@Url.Action("Dashboard")" class="so-brand">
            <div class="so-brand-icon"><i class="bi bi-geo-alt-fill"></i></div>
            <span class="so-brand-name">Heri<span>Step</span>AI</span>
        </a>
        <div class="so-right">
            <div class="so-user d-none d-md-flex">
                <div class="so-user-avatar">@userInitial</div>
                <span class="so-user-name">@User.Identity?.Name</span>
            </div>
            <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                <button type="submit" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i>Đăng xuất
                </button>
            </form>
        </div>
    </nav>

    <div class="so-content">
        <!-- Header -->
        <div style="margin-bottom:28px;">
            <h1 class="page-title">Dashboard</h1>
            <p class="page-subtitle">Quản lý cửa hàng và theo dõi lượt ghé thăm</p>
        </div>

        <!-- Stat Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card amber">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-shop"></i></div>
                        <span class="stat-badge">Cửa hàng</span>
                    </div>
                    <div class="stat-value">@totalPOIs</div>
                    <div class="stat-label">Tổng cửa hàng</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card green">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                        <span class="stat-badge">Lượt ghé</span>
                    </div>
                    <div class="stat-value">@totalVisits</div>
                    <div class="stat-label">Tổng lượt ghé thăm</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card blue">
                    <div class="stat-top">
                        <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
                        <span class="stat-badge">Đang mở</span>
                    </div>
                    <div class="stat-value">@activePOIs</div>
                    <div class="stat-label">Đang hoạt động</div>
                </div>
            </div>
        </div>

        <!-- POI Table -->
        <div class="section-card">
            <div class="section-header">
                <span class="section-title">
                    <i class="bi bi-list-ul" style="color:var(--amber);"></i>
                    Danh sách cửa hàng
                </span>
                <div class="count-badge">@totalPOIs</div>
            </div>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th style="padding-left:24px;min-width:280px;">Cửa hàng</th>
                                <th class="text-center" style="width:110px;">Loại món</th>
                                <th class="text-center" style="width:140px;">Giá (đ)</th>
                                <th class="text-center" style="width:80px;">Lượt ghé</th>
                                <th class="text-center" style="width:80px;">Unique</th>
                                <th class="text-center" style="width:110px;">Nội dung</th>
                                <th class="text-center" style="width:100px;">Trạng thái</th>
                                <th class="text-end" style="width:100px;padding-right:24px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td style="padding-left:24px;">
                                        <div class="d-flex align-items-center gap-3">
                                            @if (!string.IsNullOrEmpty(item.POI.ImageUrl))
                                            {
                                                <img src="@item.POI.ImageUrl" alt="" class="shop-thumb" />
                                            }
                                            else
                                            {
                                                <div class="shop-avatar">@item.POI.Name.Substring(0,1).ToUpper()</div>
                                            }
                                            <div style="min-width:0;">
                                                <div style="font-weight:600;color:var(--cream);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;">@item.POI.Name</div>
                                                <div style="font-size:.72rem;color:var(--cream-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:200px;margin-top:3px;display:flex;align-items:center;gap:4px;">
                                                    <i class="bi bi-geo-alt"></i>@(item.POI.Address ?? "Chưa có địa chỉ")
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var foodName = item.POI.FoodType switch { 1=>"Hải sản",2=>"Chay",3=>"Đặc sản",4=>"Đường phố",5=>"Nướng",6=>"Bún/Phở",_=>"Khác" };
                                        }
                                        <span class="food-tag">@foodName</span>
                                    </td>
                                    <td class="text-center" style="font-size:.813rem;">
                                        @if (item.POI.PriceMin > 0 || item.POI.PriceMax > 0)
                                        {
                                            <span style="font-weight:500;color:var(--amber);">@item.POI.PriceMin.ToString("N0")–@item.POI.PriceMax.ToString("N0")</span>
                                        }
                                        else { <span style="color:var(--cream-muted);">—</span> }
                                    </td>
                                    <td class="text-center"><span style="font-weight:700;color:var(--green);">@item.TotalVisits</span></td>
                                    <td class="text-center"><span style="font-weight:700;color:var(--blue);">@item.UniqueVisitors</span></td>
                                    <td class="text-center">
                                        @{
                                            var cc = item.POI.Contents?.Count ?? 0;
                                        }
                                        @if (cc > 0)
                                        {
                                            <span class="badge-soft-info"><i class="bi bi-translate"></i> @cc</span>
                                        }
                                        else
                                        {
                                            <span class="badge-soft-warning"><i class="bi bi-exclamation-circle"></i> Chưa có</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (item.POI.IsActive)
                                        {
                                            <span class="status-pill active">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="status-pill inactive">Tạm dừng</span>
                                        }
                                    </td>
                                    <td class="text-end" style="padding-right:24px;">
                                        <div class="d-inline-flex gap-1">
                                            <a href="@Url.Action("Edit", new { id = item.POI.Id })" class="act-btn" title="Chỉnh sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="@Url.Action("Statistics", new { id = item.POI.Id })" class="act-btn stat" title="Thống kê">
                                                <i class="bi bi-bar-chart"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="empty-icon"><i class="bi bi-shop"></i></div>
                    <p style="font-weight:600;margin-bottom:4px;color:var(--cream);">Bạn chưa có cửa hàng nào</p>
                    <p style="font-size:.813rem;color:var(--cream-muted);margin:0;">Vui lòng liên hệ Admin để được thêm cửa hàng.</p>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
