@model List<HeriStepAI.Web.ViewModels.ShopOwnerPOIViewModel>
@{
    ViewData["Title"] = "Dashboard Chủ Cửa Hàng";
    var totalPOIs = (int)(ViewBag.TotalPOIs ?? 0);
    var totalVisits = (int)(ViewBag.TotalVisits ?? 0);
    var activePOIs = (int)(ViewBag.ActivePOIs ?? 0);
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        --success-gradient: linear-gradient(135deg, #11998e, #38ef7d);
        --danger-gradient: linear-gradient(135deg, #f093fb, #f5576c);
    }
    body { background-color: #f0f2f5; }
    .nav-owner { background: var(--primary-gradient); }
    .stat-card { transition: transform 0.2s, box-shadow 0.2s; border-radius: 16px; }
    .stat-card:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important; }
    .poi-row { transition: all 0.2s; }
    .poi-row:hover { background-color: #f8f9ff; }
    .avatar-lg { width: 64px; height: 64px; object-fit: cover; border-radius: 12px; }
    .badge-food { font-size: 0.7rem; padding: 4px 8px; border-radius: 6px; }
    .stat-icon { width: 52px; height: 52px; border-radius: 14px; display: flex; align-items: center; justify-content: center; }
    .table > :not(caption) > * > * { vertical-align: middle; }
    .content-count { font-size: 0.7rem; padding: 2px 7px; border-radius: 10px; }
</style>

<!-- Navbar -->
<nav class="navbar nav-owner shadow-sm px-0">
    <div class="container-fluid px-4">
        <span class="navbar-brand text-white fw-bold mb-0">
            <i class="bi bi-shop-window me-1"></i> HeriStepAI
        </span>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white-50 small d-none d-md-inline">
                <i class="bi bi-person-circle"></i> @User.Identity?.Name
            </span>
            <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                <button type="submit" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </button>
            </form>
        </div>
    </div>
</nav>

<div class="container-fluid px-4 py-4" style="max-width: 1400px;">

    <!-- Header -->
    <div class="mb-4">
        <h4 class="fw-bold mb-1"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h4>
        <p class="text-muted mb-0">Quản lý cửa hàng và theo dõi lượt ghé thăm</p>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3 p-3">
                    <div class="stat-icon text-white" style="background: var(--primary-gradient);">
                        <i class="bi bi-shop fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small mb-1">Tổng cửa hàng</div>
                        <div class="fs-3 fw-bold lh-1">@totalPOIs</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3 p-3">
                    <div class="stat-icon text-white" style="background: var(--success-gradient);">
                        <i class="bi bi-people fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small mb-1">Tổng lượt ghé thăm</div>
                        <div class="fs-3 fw-bold lh-1">@totalVisits</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3 p-3">
                    <div class="stat-icon text-white" style="background: var(--danger-gradient);">
                        <i class="bi bi-check-circle fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small mb-1">Đang hoạt động</div>
                        <div class="fs-3 fw-bold lh-1">@activePOIs</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- POI List Table -->
    <div class="card border-0 shadow-sm" style="border-radius: 16px; overflow: hidden;">
        <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center border-bottom">
            <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-1"></i> Danh sách cửa hàng</h6>
            <span class="badge bg-primary rounded-pill">@totalPOIs</span>
        </div>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4" style="min-width: 300px;">Cửa hàng</th>
                            <th class="text-center" style="width: 100px;">Loại món</th>
                            <th class="text-center" style="width: 130px;">Giá</th>
                            <th class="text-center" style="width: 80px;">Lượt ghé</th>
                            <th class="text-center" style="width: 80px;">Unique</th>
                            <th class="text-center" style="width: 100px;">Nội dung</th>
                            <th class="text-center" style="width: 100px;">Trạng thái</th>
                            <th class="text-end pe-4" style="width: 180px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="poi-row">
                                <!-- Shop Info -->
                                <td class="ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        @if (!string.IsNullOrEmpty(item.POI.ImageUrl))
                                        {
                                            <img src="@item.POI.ImageUrl" alt="" class="avatar-lg shadow-sm flex-shrink-0" />
                                        }
                                        else
                                        {
                                            <div class="avatar-lg bg-light d-flex align-items-center justify-content-center shadow-sm flex-shrink-0">
                                                <i class="bi bi-image text-muted"></i>
                                            </div>
                                        }
                                        <div class="min-w-0">
                                            <div class="fw-semibold text-truncate" style="max-width: 220px;">@item.POI.Name</div>
                                            <small class="text-muted text-truncate d-block" style="max-width: 220px;">
                                                <i class="bi bi-geo-alt"></i> @(item.POI.Address ?? "Chưa có địa chỉ")
                                            </small>
                                        </div>
                                    </div>
                                </td>

                                <!-- Food Type -->
                                <td class="text-center">
                                    @{
                                        var foodName = item.POI.FoodType switch { 1 => "Hải sản", 2 => "Món chay", 3 => "Đặc sản", 4 => "Đường phố", 5 => "Nướng", 6 => "Bún/Phở", _ => "Khác" };
                                        var foodColor = item.POI.FoodType switch { 1 => "primary", 2 => "success", 3 => "warning", 4 => "danger", 5 => "info", 6 => "secondary", _ => "dark" };
                                    }
                                    <span class="badge bg-@(foodColor)-subtle text-@foodColor badge-food">@foodName</span>
                                </td>

                                <!-- Price -->
                                <td class="text-center">
                                    @if (item.POI.PriceMin > 0 || item.POI.PriceMax > 0)
                                    {
                                        <small class="fw-medium">@item.POI.PriceMin.ToString("N0") - @item.POI.PriceMax.ToString("N0")đ</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">--</small>
                                    }
                                </td>

                                <!-- Visits -->
                                <td class="text-center">
                                    <span class="fw-bold text-primary">@item.TotalVisits</span>
                                </td>

                                <!-- Unique -->
                                <td class="text-center">
                                    <span class="fw-bold text-success">@item.UniqueVisitors</span>
                                </td>

                                <!-- Contents count -->
                                <td class="text-center">
                                    @{
                                        var contentCount = item.POI.Contents?.Count ?? 0;
                                    }
                                    @if (contentCount > 0)
                                    {
                                        <span class="badge bg-info-subtle text-info content-count">
                                            <i class="bi bi-translate"></i> @contentCount ngôn ngữ
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning-subtle text-warning content-count">
                                            <i class="bi bi-exclamation-circle"></i> Chưa có
                                        </span>
                                    }
                                </td>

                                <!-- Status -->
                                <td class="text-center">
                                    @if (item.POI.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success" style="font-size: 0.7rem;">
                                            <i class="bi bi-circle-fill" style="font-size: 0.4rem;"></i> Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary" style="font-size: 0.7rem;">
                                            <i class="bi bi-circle-fill" style="font-size: 0.4rem;"></i> Tạm dừng
                                        </span>
                                    }
                                </td>

                                <!-- Actions -->
                                <td class="text-end pe-4">
                                    <div class="btn-group btn-group-sm">
                                        <a href="@Url.Action("Edit", new { id = item.POI.Id })" class="btn btn-outline-primary" title="Chỉnh sửa">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a href="@Url.Action("Statistics", new { id = item.POI.Id })" class="btn btn-outline-info" title="Thống kê">
                                            <i class="bi bi-bar-chart"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-shop fs-1 text-muted"></i>
                <p class="text-muted mt-3 mb-1">Bạn chưa có cửa hàng nào.</p>
                <small class="text-muted">Vui lòng liên hệ Admin để được thêm cửa hàng.</small>
            </div>
        }
    </div>
</div>
