@model List<HeriStepAI.API.Models.VisitLog>
@{
    ViewData["Title"] = "Thống kê ghé thăm";
    var poi = ViewBag.POI as HeriStepAI.API.Models.POI;
    var from = ViewBag.From as DateTime?;
    var to = ViewBag.To as DateTime?;
    var totalVisits = ViewBag.TotalVisits ?? 0;
    var dailyStats = ViewBag.DailyStats as List<dynamic>;
}

<style>
    body { background-color: #f0f2f5; }
    .nav-owner { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
    .card { border-radius: 16px !important; }
    .stat-card { transition: transform 0.2s; }
    .stat-card:hover { transform: translateY(-3px); }
    .stat-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
</style>

<!-- Navbar -->
<nav class="navbar nav-owner shadow-sm">
    <div class="container-fluid px-4">
        <a href="@Url.Action("Dashboard")" class="navbar-brand text-white fw-bold text-decoration-none">
            <i class="bi bi-shop-window me-1"></i> HeriStepAI
        </a>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white-50 small d-none d-md-inline">
                <i class="bi bi-person-circle"></i> @User.Identity?.Name
            </span>
            <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                <button type="submit" class="btn btn-outline-light btn-sm">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </button>
            </form>
        </div>
    </div>
</nav>

<div class="container-fluid px-4 py-4" style="max-width: 1200px;">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="@Url.Action("Dashboard")" class="text-decoration-none"><i class="bi bi-house"></i> Dashboard</a></li>
            <li class="breadcrumb-item active">Thống kê: @poi.Name</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-0"><i class="bi bi-bar-chart-line me-2"></i>Thống kê ghé thăm</h4>
            <small class="text-muted">@poi.Name &middot; @poi.Address</small>
        </div>
        <a href="@Url.Action("Edit", new { id = poi.Id })" class="btn btn-outline-primary btn-sm" style="border-radius: 8px;">
            <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
        </a>
    </div>

    <!-- Date Filter -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold mb-1">Từ ngày</label>
                    <input type="date" name="from" class="form-control form-control-sm"
                           value="@from?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold mb-1">Đến ngày</label>
                    <input type="date" name="to" class="form-control form-control-sm"
                           value="@to?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary btn-sm w-100" style="border-radius: 8px;">
                        <i class="bi bi-funnel me-1"></i> Lọc dữ liệu
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Statistics Summary -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3 p-3">
                    <div class="stat-icon text-white" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                        <i class="bi bi-people fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Tổng lượt ghé</div>
                        <div class="fs-3 fw-bold text-primary lh-1">@totalVisits</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3 p-3">
                    <div class="stat-icon text-white" style="background: linear-gradient(135deg, #11998e, #38ef7d);">
                        <i class="bi bi-geo-alt fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Geofence (tự động)</div>
                        <div class="fs-3 fw-bold text-success lh-1">@Model.Count(v => v.VisitType == HeriStepAI.API.Models.VisitType.Geofence)</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm stat-card h-100">
                <div class="card-body d-flex align-items-center gap-3 p-3">
                    <div class="stat-icon text-white" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                        <i class="bi bi-hand-index fs-5"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Manual (thủ công)</div>
                        <div class="fs-3 fw-bold text-info lh-1">@Model.Count(v => v.VisitType == HeriStepAI.API.Models.VisitType.MapClick)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Daily Chart -->
    @if (dailyStats != null && dailyStats.Any())
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3 border-bottom">
                <h6 class="mb-0 fw-bold"><i class="bi bi-graph-up me-1"></i> Biểu đồ theo ngày</h6>
            </div>
            <div class="card-body">
                <canvas id="dailyChart" style="height: 300px;"></canvas>
            </div>
        </div>
    }

    <!-- Visit Logs Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold"><i class="bi bi-table me-1"></i> Chi tiết lượt ghé thăm</h6>
            <span class="badge bg-primary rounded-pill">@Model.Count lượt</span>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Thời gian</th>
                                <th class="text-center">Loại</th>
                                <th class="text-center">Tọa độ</th>
                                <th class="text-center">Khoảng cách</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var visit in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <small class="fw-medium">@visit.VisitTime.ToString("dd/MM/yyyy")</small>
                                        <small class="text-muted ms-1">@visit.VisitTime.ToString("HH:mm:ss")</small>
                                    </td>
                                    <td class="text-center">
                                        @if (visit.VisitType == HeriStepAI.API.Models.VisitType.Geofence)
                                        {
                                            <span class="badge bg-success-subtle text-success" style="font-size: 0.7rem;">
                                                <i class="bi bi-geo-alt"></i> Geofence
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info-subtle text-info" style="font-size: 0.7rem;">
                                                <i class="bi bi-hand-index"></i> Manual
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <small class="font-monospace text-muted">
                                            @(visit.Latitude?.ToString("F6") ?? "N/A"), @(visit.Longitude?.ToString("F6") ?? "N/A")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var distance = visit.Latitude.HasValue && visit.Longitude.HasValue
                                                ? CalculateDistance(poi.Latitude, poi.Longitude, visit.Latitude.Value, visit.Longitude.Value)
                                                : 0;
                                        }
                                        <small class="fw-medium">@distance.ToString("F0")m</small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox fs-1 text-muted"></i>
                    <p class="text-muted mt-3 mb-0">Chưa có lượt ghé thăm nào trong khoảng thời gian này</p>
                </div>
            }
        </div>
    </div>
</div>

@functions {
    double CalculateDistance(double lat1, double lon1, double lat2, double lon2)
    {
        const double R = 6371000;
        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLon = (lon2 - lon1) * Math.PI / 180;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180) *
                Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return R * c;
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @if (dailyStats != null && dailyStats.Any())
    {
        <script>
            const ctx = document.getElementById('dailyChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyStats.Select(x => ((DateTime)x.Date).ToString("dd/MM")))),
                    datasets: [
                        {
                            label: 'Tổng lượt ghé',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyStats.Select(x => x.TotalVisits))),
                            borderColor: '#667eea',
                            backgroundColor: 'rgba(102, 126, 234, 0.1)',
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            pointRadius: 4,
                            pointBackgroundColor: '#667eea'
                        },
                        {
                            label: 'Geofence',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyStats.Select(x => x.GeofenceVisits))),
                            borderColor: '#11998e',
                            backgroundColor: 'rgba(17, 153, 142, 0.1)',
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            pointRadius: 4,
                            pointBackgroundColor: '#11998e'
                        },
                        {
                            label: 'Manual',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyStats.Select(x => x.ManualVisits))),
                            borderColor: '#0dcaf0',
                            backgroundColor: 'rgba(13, 202, 240, 0.1)',
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            pointRadius: 4,
                            pointBackgroundColor: '#0dcaf0'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                    },
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: '#f0f0f0' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        </script>
    }
}
