@model List<HeriStepAI.API.Models.VisitLog>
@{
    ViewData["Title"] = "Thống kê ghé thăm";
    Layout = null;
    var poi = ViewBag.POI as HeriStepAI.API.Models.POI;
    var from = ViewBag.From as DateTime?;
    var to = ViewBag.To as DateTime?;
    var totalVisits = (int)(ViewBag.TotalVisits ?? 0);
    var dailyStats = ViewBag.DailyStats as List<dynamic>;
    var geofenceCount = Model.Count(v => v.VisitType == HeriStepAI.API.Models.VisitType.Geofence);
    var manualCount   = Model.Count(v => v.VisitType == HeriStepAI.API.Models.VisitType.MapClick);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HeriStepAI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
        body { background: linear-gradient(135deg,#eef2ff 0%,#faf9ff 45%,#ecfdf5 100%); background-attachment: fixed; margin: 0; color: #1e293b; }

        /* Navbar */
        .so-navbar {
            background: linear-gradient(135deg,#1e1b4b 0%,#312e81 60%,#4c1d95 100%);
            border-bottom: none;
            height: 60px;
            display: flex; align-items: center;
            padding: 0 24px;
            position: sticky; top: 0; z-index: 100;
            justify-content: space-between;
            box-shadow: 0 2px 16px rgba(79,70,229,0.25);
        }
        .so-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .so-brand-icon { width: 32px; height: 32px; border-radius: 8px; background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 0.938rem; }
        .so-brand-name { font-size: 1rem; font-weight: 700; color: #fff; }
        .so-right { display: flex; align-items: center; gap: 12px; }
        .so-user { font-size: 0.813rem; color: rgba(255,255,255,0.7); display: flex; align-items: center; gap: 6px; }
        .btn-logout { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.85); font-size: 0.813rem; font-weight: 500; cursor: pointer; transition: all .15s; }
        .btn-logout:hover { background: rgba(239,68,68,0.2); border-color: rgba(239,68,68,0.5); color: #fca5a5; }

        /* Content */
        .so-content { max-width: 1300px; margin: 0 auto; padding: 24px; }

        /* Breadcrumb */
        .breadcrumb { font-size: 0.813rem; background: none; padding: 0; margin: 0; }
        .breadcrumb-item a { color: #64748b; text-decoration: none; }
        .breadcrumb-item a:hover { color: #4f46e5; }
        .breadcrumb-item.active { color: #1e293b; font-weight: 500; }
        .breadcrumb-item + .breadcrumb-item::before { color: #cbd5e1; }

        /* Stat cards */
        .stat-card { border: none; border-radius: 14px; padding: 22px; display: flex; flex-direction: column; gap: 12px; transition: box-shadow .2s, transform .2s; color: #fff; position: relative; overflow: hidden; }
        .stat-card::before { content: ''; position: absolute; top: -40px; right: -40px; width: 120px; height: 120px; border-radius: 50%; background: rgba(255,255,255,0.08); }
        .stat-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.18); transform: translateY(-3px); }
        .stat-card .stat-number { color: #fff; }
        .stat-card .stat-label  { color: rgba(255,255,255,0.75); }
        .stat-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }

        /* Cards */
        .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
        .card-header { background: #fff; border-bottom: 1px solid #e2e8f0; padding: 14px 20px; font-size: 0.875rem; font-weight: 600; color: #1e293b; display: flex; align-items: center; gap: 8px; }
        .card-body { padding: 20px; }

        /* Filter form */
        .filter-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 16px 20px; }
        .form-label { font-size: 0.75rem; font-weight: 600; color: #64748b; margin-bottom: 4px; }
        .form-control, .form-select {
            border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.875rem; color: #1e293b;
            padding: 8px 12px; transition: border-color .15s, box-shadow .15s;
        }
        .form-control:focus, .form-select:focus { border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,.08); outline: none; }
        .btn-filter { display: inline-flex; align-items: center; gap: 6px; padding: 8px 18px; border-radius: 8px; background: #4f46e5; color: #fff; border: none; font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: background .15s; }
        .btn-filter:hover { background: #4338ca; }

        /* Table */
        .table-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
        .table { margin: 0; }
        .table thead tr th { background: #f8fafc; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: .05em; color: #64748b; border-bottom: 1px solid #e2e8f0; padding: 12px 16px; white-space: nowrap; }
        .table tbody tr { transition: background .1s; }
        .table tbody tr:hover { background: #f8fafc; }
        .table tbody td { padding: 12px 16px; vertical-align: middle; border-color: #f1f5f9; font-size: 0.875rem; }

        /* Badges */
        .badge-geo    { background: #f0fdf4; color: #166534; border-radius: 6px; padding: 3px 8px; font-size: .75rem; font-weight: 500; }
        .badge-manual { background: #eff6ff; color: #1e40af; border-radius: 6px; padding: 3px 8px; font-size: .75rem; font-weight: 500; }

        /* Edit button */
        .btn-edit { display: inline-flex; align-items: center; gap: 6px; padding: 7px 14px; border-radius: 8px; border: 1px solid #e2e8f0; background: #fff; color: #475569; font-size: 0.813rem; font-weight: 500; text-decoration: none; transition: all .15s; }
        .btn-edit:hover { background: #eef2ff; border-color: #c7d2fe; color: #4f46e5; }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="so-navbar">
        <a href="@Url.Action("Dashboard")" class="so-brand">
            <div class="so-brand-icon"><i class="bi bi-geo-alt-fill"></i></div>
            <span class="so-brand-name">HeriStepAI</span>
        </a>
        <div class="so-right">
            <span class="so-user d-none d-md-flex">
                <i class="bi bi-person-circle"></i> @User.Identity?.Name
            </span>
            <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                <button type="submit" class="btn-logout">
                    <i class="bi bi-box-arrow-right"></i>Đăng xuất
                </button>
            </form>
        </div>
    </nav>

    <div class="so-content">
        <!-- Breadcrumb + Header -->
        <div style="margin-bottom: 20px;">
            <nav aria-label="breadcrumb" style="margin-bottom: 12px;">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Dashboard")"><i class="bi bi-house"></i> Dashboard</a></li>
                    <li class="breadcrumb-item active">Thống kê: @poi?.Name</li>
                </ol>
            </nav>
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 style="font-size: 1.375rem; font-weight: 700; margin: 0 0 2px; letter-spacing: -.02em;">Thống kê ghé thăm</h1>
                    <p style="font-size: 0.813rem; color: #64748b; margin: 0;">
                        <i class="bi bi-geo-alt me-1"></i>@poi?.Name
                        @if (!string.IsNullOrEmpty(poi?.Address))
                        {
                            <span class="mx-1" style="color: #cbd5e1;">·</span>
                            @poi.Address
                        }
                    </p>
                </div>
                <a href="@Url.Action("Edit", new { id = poi?.Id })" class="btn-edit">
                    <i class="bi bi-pencil"></i>Chỉnh sửa
                </a>
            </div>
        </div>

        <!-- Date Filter -->
        <div class="filter-card mb-4">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Từ ngày</label>
                    <input type="date" name="from" class="form-control"
                           value="@from?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Đến ngày</label>
                    <input type="date" name="to" class="form-control"
                           value="@to?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn-filter w-100" style="height: 38px;">
                        <i class="bi bi-funnel"></i>Lọc dữ liệu
                    </button>
                </div>
            </form>
        </div>

        <!-- Stat Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card" style="background:linear-gradient(135deg,#4f46e5 0%,#7c3aed 100%);">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-people-fill"></i></div>
                        <span style="background:rgba(255,255,255,0.18);color:#fff;font-size:.688rem;font-weight:600;padding:4px 10px;border-radius:20px;">Tổng</span>
                    </div>
                    <div style="position:relative;z-index:1;">
                        <div class="stat-number">@totalVisits</div>
                        <div class="stat-label">Tổng lượt ghé thăm</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card" style="background:linear-gradient(135deg,#059669 0%,#0ea5e9 100%);">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-broadcast"></i></div>
                        <span style="background:rgba(255,255,255,0.18);color:#fff;font-size:.688rem;font-weight:600;padding:4px 10px;border-radius:20px;">Tự động</span>
                    </div>
                    <div style="position:relative;z-index:1;">
                        <div class="stat-number">@geofenceCount</div>
                        <div class="stat-label">Geofence (tự động)</div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card" style="background:linear-gradient(135deg,#0284c7 0%,#6366f1 100%);">
                    <div class="d-flex align-items-center justify-content-between">
                        <div class="stat-icon" style="background:rgba(255,255,255,0.18);color:#fff;"><i class="bi bi-hand-index-thumb"></i></div>
                        <span style="background:rgba(255,255,255,0.18);color:#fff;font-size:.688rem;font-weight:600;padding:4px 10px;border-radius:20px;">Thủ công</span>
                    </div>
                    <div style="position:relative;z-index:1;">
                        <div class="stat-number">@manualCount</div>
                        <div class="stat-label">Manual (thủ công)</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Daily Chart -->
        @if (dailyStats != null && dailyStats.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-graph-up" style="color: #4f46e5;"></i>Biểu đồ theo ngày
                </div>
                <div class="card-body">
                    <canvas id="dailyChart" style="height: 280px;"></canvas>
                </div>
            </div>
        }

        <!-- Visit Logs Table -->
        <div class="table-card">
            <div class="d-flex align-items-center justify-content-between" style="padding: 16px 20px; border-bottom: 1px solid #e2e8f0;">
                <span style="font-size: .938rem; font-weight: 600; color: #1e293b;">
                    <i class="bi bi-table me-2" style="color: #4f46e5;"></i>Chi tiết lượt ghé thăm
                </span>
                <span style="background: #4f46e5; color: #fff; font-size: .75rem; font-weight: 600; padding: 4px 12px; border-radius: 20px;">@Model.Count lượt</span>
            </div>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th style="padding-left: 20px;">Thời gian</th>
                                <th class="text-center" style="width: 120px;">Loại</th>
                                <th class="text-center">Tọa độ</th>
                                <th class="text-center" style="width: 120px;">Khoảng cách</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var visit in Model)
                            {
                                <tr>
                                    <td style="padding-left: 20px;">
                                        <span style="font-weight: 500;">@visit.VisitTime.ToString("dd/MM/yyyy")</span>
                                        <span style="color: #94a3b8; font-size: .8rem; margin-left: 6px;">@visit.VisitTime.ToString("HH:mm:ss")</span>
                                    </td>
                                    <td class="text-center">
                                        @if (visit.VisitType == HeriStepAI.API.Models.VisitType.Geofence)
                                        {
                                            <span class="badge-geo"><i class="bi bi-broadcast me-1"></i>Geofence</span>
                                        }
                                        else
                                        {
                                            <span class="badge-manual"><i class="bi bi-hand-index-thumb me-1"></i>Manual</span>
                                        }
                                    </td>
                                    <td class="text-center" style="font-family: monospace; font-size: .8rem; color: #64748b;">
                                        @(visit.Latitude?.ToString("F6") ?? "N/A"), @(visit.Longitude?.ToString("F6") ?? "N/A")
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var distance = visit.Latitude.HasValue && visit.Longitude.HasValue && poi != null
                                                ? CalculateDistance(poi.Latitude, poi.Longitude, visit.Latitude.Value, visit.Longitude.Value)
                                                : 0;
                                        }
                                        <span style="font-weight: 600; color: #1e293b;">@distance.ToString("F0")m</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div style="width: 56px; height: 56px; border-radius: 50%; background: #eef2ff; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px;">
                        <i class="bi bi-inbox" style="font-size: 1.5rem; color: #4f46e5;"></i>
                    </div>
                    <p style="font-weight: 600; margin-bottom: 4px;">Chưa có lượt ghé thăm</p>
                    <p style="font-size: .813rem; color: #94a3b8; margin: 0;">Không có dữ liệu trong khoảng thời gian này.</p>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @if (dailyStats != null && dailyStats.Any())
    {
        <script>
            new Chart(document.getElementById('dailyChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyStats.Select(x => ((DateTime)x.Date).ToString("dd/MM")))),
                    datasets: [
                        {
                            label: 'Tổng lượt ghé',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyStats.Select(x => x.TotalVisits))),
                            borderColor: '#4f46e5',
                            backgroundColor: 'rgba(79,70,229,0.08)',
                            borderWidth: 2, tension: 0.4, fill: true,
                            pointRadius: 4, pointBackgroundColor: '#4f46e5'
                        },
                        {
                            label: 'Geofence',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyStats.Select(x => x.GeofenceVisits))),
                            borderColor: '#10b981',
                            backgroundColor: 'rgba(16,185,129,0.08)',
                            borderWidth: 2, tension: 0.4, fill: true,
                            pointRadius: 4, pointBackgroundColor: '#10b981'
                        },
                        {
                            label: 'Manual',
                            data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(dailyStats.Select(x => x.ManualVisits))),
                            borderColor: '#3b82f6',
                            backgroundColor: 'rgba(59,130,246,0.08)',
                            borderWidth: 2, tension: 0.4, fill: true,
                            pointRadius: 4, pointBackgroundColor: '#3b82f6'
                        }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { size: 12 }, color: '#64748b' } } },
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0, color: '#94a3b8', font: { size: 11 } }, grid: { color: '#f1f5f9' } },
                        x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 11 } } }
                    }
                }
            });
        </script>
    }
</body>
</html>

@functions {
    double CalculateDistance(double lat1, double lon1, double lat2, double lon2)
    {
        const double R = 6371000;
        var dLat = (lat2 - lat1) * Math.PI / 180;
        var dLon = (lon2 - lon1) * Math.PI / 180;
        var a = Math.Sin(dLat / 2) * Math.Sin(dLat / 2) +
                Math.Cos(lat1 * Math.PI / 180) * Math.Cos(lat2 * Math.PI / 180) *
                Math.Sin(dLon / 2) * Math.Sin(dLon / 2);
        var c = 2 * Math.Atan2(Math.Sqrt(a), Math.Sqrt(1 - a));
        return R * c;
    }
}
