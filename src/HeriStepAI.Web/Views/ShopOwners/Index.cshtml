@model List<HeriStepAI.Web.Models.ShopOwnerRow>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý chủ quán";
    var filter = ViewBag.FilterStatus as string ?? "";
    int total    = ViewBag.Total    ?? 0;
    int pending  = ViewBag.Pending  ?? 0;
    int approved = ViewBag.Approved ?? 0;
    int rejected = ViewBag.Rejected ?? 0;
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Quản lý chủ quán</h1>
        <p class="page-subtitle-text">Xem tất cả ShopOwner — duyệt, từ chối, kích hoạt hoặc vô hiệu hóa tài khoản.</p>
    </div>
    <a href="@Url.Action("Dashboard", "Home")" class="btn btn-outline-light btn-sm">← Dashboard</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <span>@TempData["Success"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@TempData["Error"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card blue">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                <span class="stat-badge">Tổng</span>
            </div>
            <div class="stat-number">@total</div>
            <div class="stat-label">Chủ quán</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card amber">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
                <span class="stat-badge">Chờ</span>
            </div>
            <div class="stat-number">@pending</div>
            <div class="stat-label">Chờ duyệt</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card green">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-person-check-fill"></i></div>
                <span class="stat-badge">Duyệt</span>
            </div>
            <div class="stat-number">@approved</div>
            <div class="stat-label">Đã duyệt</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card red">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-person-x-fill"></i></div>
                <span class="stat-badge">Từ chối</span>
            </div>
            <div class="stat-number">@rejected</div>
            <div class="stat-label">Từ chối</div>
        </div>
    </div>
</div>

<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <span style="font-size:0.8rem;color:var(--cream-muted);">Lọc:</span>
    <a href="@Url.Action("Index")" class="btn btn-sm @(filter == "" ? "btn-primary" : "btn-ghost")">Tất cả</a>
    <a href="@Url.Action("Index", new { status = "Pending" })" class="btn btn-sm @(filter == "Pending" ? "btn-warning" : "btn-ghost")">⏳ Chờ duyệt</a>
    <a href="@Url.Action("Index", new { status = "Approved" })" class="btn btn-sm @(filter == "Approved" ? "btn-success" : "btn-ghost")">✓ Đã duyệt</a>
    <a href="@Url.Action("Index", new { status = "Rejected" })" class="btn btn-sm @(filter == "Rejected" ? "btn-danger" : "btn-ghost")">✕ Từ chối</a>
</div>

<div class="table-card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th style="padding-left:20px;width:60px;">ID</th>
                        <th>Tên đăng nhập</th>
                        <th>Email</th>
                        <th>Họ tên</th>
                        <th>Điện thoại</th>
                        <th>Trạng thái</th>
                        <th>Tài khoản</th>
                        <th>Đăng ký lúc</th>
                        <th style="padding-right:20px;text-align:right;white-space:nowrap;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model)
                    {
                        <tr>
                            <td style="padding-left:20px;">
                                <code style="font-size:0.78rem;color:var(--cream-muted);">#@row.Id</code>
                            </td>
                            <td>
                                <div style="font-weight:600;">@row.Username</div>
                            </td>
                            <td style="color:var(--cream-muted);font-size:0.85rem;">@row.Email</td>
                            <td>@(row.FullName ?? "—")</td>
                            <td style="color:var(--cream-muted);font-size:0.85rem;">@(row.Phone ?? "—")</td>
                            <td>
                                @if (row.ApprovalStatus == "Approved")
                                {
                                    <span class="badge-soft-success">Đã duyệt</span>
                                }
                                else if (row.ApprovalStatus == "Pending")
                                {
                                    <span class="badge-soft-warning">Chờ duyệt</span>
                                }
                                else if (row.ApprovalStatus == "Rejected")
                                {
                                    <span class="badge-soft-danger">Từ chối</span>
                                }
                                else
                                {
                                    <span class="badge-soft-secondary">@row.ApprovalStatus</span>
                                }
                            </td>
                            <td>
                                @if (row.IsActive)
                                {
                                    <span class="badge-soft-success"><i class="bi bi-circle-fill" style="font-size:0.5rem;vertical-align:middle;"></i> Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge-soft-secondary"><i class="bi bi-circle" style="font-size:0.5rem;vertical-align:middle;"></i> Vô hiệu</span>
                                }
                            </td>
                            <td style="font-size:0.8rem;color:var(--cream-muted);white-space:nowrap;">
                                @row.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            </td>
                            <td style="padding-right:20px;text-align:right;">
                                <div class="d-flex gap-1 justify-content-end flex-wrap">
                                    @if (row.ApprovalStatus == "Pending")
                                    {
                                        <form asp-action="Approve" asp-route-returnStatus="@filter" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@row.Id" />
                                            <button type="submit" class="btn btn-sm btn-success" title="Duyệt">
                                                <i class="bi bi-check-lg"></i> Duyệt
                                            </button>
                                        </form>
                                        <form asp-action="Reject" asp-route-returnStatus="@filter" method="post" class="d-inline"
                                              onsubmit="return confirm('Từ chối đăng ký @Html.Raw((row.FullName ?? row.Username).Replace("'", "\\'"))?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@row.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Từ chối">
                                                <i class="bi bi-x-lg"></i> Từ chối
                                            </button>
                                        </form>
                                    }
                                    else if (row.ApprovalStatus == "Rejected")
                                    {
                                        <form asp-action="Approve" asp-route-returnStatus="@filter" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@row.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Duyệt lại">
                                                <i class="bi bi-arrow-counterclockwise"></i> Duyệt lại
                                            </button>
                                        </form>
                                    }
                                    @if (row.ApprovalStatus == "Approved")
                                    {
                                        <form asp-action="ToggleActive" asp-route-returnStatus="@filter" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@row.Id" />
                                            @if (row.IsActive)
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-secondary" title="Vô hiệu hóa"
                                                        onclick="return confirm('Vô hiệu hóa tài khoản @Html.Raw((row.FullName ?? row.Username).Replace("'", "\\'"))?')">
                                                    <i class="bi bi-pause-circle"></i> Vô hiệu
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="btn btn-sm btn-outline-success" title="Kích hoạt lại">
                                                    <i class="bi bi-play-circle"></i> Kích hoạt
                                                </button>
                                            }
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-people" style="font-size:2.5rem;color:var(--cream-muted);opacity:0.5;"></i>
            <p class="mt-3 mb-0" style="color:var(--cream-muted);font-size:0.9rem;">
                @(filter == "" ? "Chưa có chủ quán nào." : "Không có chủ quán nào với trạng thái \"" + filter + "\".")
            </p>
        </div>
    }
</div>
