@model CreatePOIWithOwnerViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm POI mới";
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Thêm POI &amp; Tài khoản chủ quán</h1>
        <p class="page-subtitle-text">Tạo địa điểm mới và tài khoản quản lý cho chủ quán</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-ghost btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@TempData["Error"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="post" asp-action="Create" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-7">
            <!-- Basic Info -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-geo-alt-fill me-2" style="color:var(--amber);"></i>Thông tin cơ bản
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Tên POI <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: Quán Bún Bò Huế Đông Ba" required />
                        <span asp-validation-for="Name" class="text-danger" style="font-size:0.75rem;"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả <span class="text-danger">*</span></label>
                        <textarea asp-for="Description" class="form-control" rows="3" required placeholder="Mô tả ngắn gọn về địa điểm..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input asp-for="Address" class="form-control" placeholder="Số nhà, đường, phường, quận..." />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                            <input asp-for="Latitude" type="number" step="any" class="form-control" required placeholder="16.0544" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                            <input asp-for="Longitude" type="number" step="any" class="form-control" required placeholder="108.2022" />
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Bán kính geofence (m)</label>
                        <input asp-for="Radius" type="number" class="form-control" value="50" />
                        <div style="font-size:0.75rem;color:var(--cream-muted);margin-top:4px;">Bán kính kích hoạt thuyết minh tự động</div>
                    </div>
                </div>
            </div>

            <!-- Owner Account -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-person-badge me-2" style="color:var(--green);"></i>Tài khoản chủ quán
                </div>
                <div class="card-body">
                    <div class="alert alert-info mb-4" style="display:flex;align-items:flex-start;gap:10px;">
                        <i class="bi bi-info-circle-fill flex-shrink-0" style="color:var(--blue);margin-top:1px;"></i>
                        <span>Tài khoản sẽ được tạo với quyền <strong>ShopOwner</strong> để quản lý POI này.</span>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Tên đầy đủ</label>
                            <input asp-for="OwnerFullName" class="form-control" placeholder="Nguyễn Văn A" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số điện thoại</label>
                            <input asp-for="OwnerPhone" class="form-control" placeholder="0912345678" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tên đăng nhập <span class="text-danger">*</span></label>
                        <input asp-for="OwnerUsername" class="form-control" required placeholder="owner_username" />
                        <div style="font-size:0.75rem;color:var(--cream-muted);margin-top:4px;">Từ 3–50 ký tự, không có khoảng cách</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input asp-for="OwnerEmail" type="email" class="form-control" required placeholder="owner@example.com" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Mật khẩu <span class="text-danger">*</span></label>
                        <input asp-for="OwnerPassword" type="password" class="form-control" required placeholder="Tối thiểu 6 ký tự" />
                    </div>
                </div>
            </div>

            <!-- Narration Content -->
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-translate me-2" style="color:var(--blue);"></i>Nội dung thuyết minh
                </div>
                <div class="card-body">
                    <ul class="nav nav-tabs-pill mb-3" role="tablist">
                        <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-vi">🇻🇳 Việt</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-en">🇬🇧 EN</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-ko">🇰🇷 KO</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-zh">🇨🇳 ZH</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-ja">🇯🇵 JA</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-th">🇹🇭 TH</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-fr">🇫🇷 FR</a></li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tab-vi">
                            <textarea asp-for="TextContent_vi" class="form-control" rows="5" placeholder="Nội dung thuyết minh tiếng Việt..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-en">
                            <textarea asp-for="TextContent_en" class="form-control" rows="5" placeholder="English narration content..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-ko">
                            <textarea asp-for="TextContent_ko" class="form-control" rows="5" placeholder="한국어 나레이션 내용..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-zh">
                            <textarea asp-for="TextContent_zh" class="form-control" rows="5" placeholder="中文解说内容..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-ja">
                            <textarea asp-for="TextContent_ja" class="form-control" rows="5" placeholder="日本語ナレーション内容..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-th">
                            <textarea asp-for="TextContent_th" class="form-control" rows="5" placeholder="เนื้อหาบรรยายภาษาไทย..."></textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-fr">
                            <textarea asp-for="TextContent_fr" class="form-control" rows="5" placeholder="Contenu de narration en français..."></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-5">
            <!-- Category & Settings -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-tag-fill me-2" style="color:var(--amber);"></i>Phân loại &amp; Cài đặt
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Loại POI <span class="text-danger">*</span></label>
                        <select asp-for="Category" class="form-select" id="categorySelect" required>
                            <option value="0">Tất cả</option>
                            <option value="1">Tham quan</option>
                            <option value="2" selected>Ẩm thực</option>
                            <option value="3">Nghỉ dưỡng</option>
                            <option value="4">Mua sắm</option>
                            <option value="5">Giải trí</option>
                            <option value="6">Di tích lịch sử</option>
                            <option value="7">Thiên nhiên</option>
                        </select>
                    </div>
                    <div class="mb-3" id="foodTypeDiv">
                        <label class="form-label">Loại món ăn</label>
                        <select asp-for="FoodType" class="form-select">
                            <option value="0">Khác</option>
                            <option value="1">Hải sản</option>
                            <option value="2">Món chay</option>
                            <option value="3">Đặc sản</option>
                            <option value="4">Đường phố</option>
                            <option value="5">Nướng</option>
                            <option value="6">Bún/Phở/Mì</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-3" id="priceDiv">
                        <div class="col-6">
                            <label class="form-label">Giá min (VND)</label>
                            <input asp-for="PriceMin" type="number" class="form-control" value="0" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Giá max (VND)</label>
                            <input asp-for="PriceMax" type="number" class="form-control" value="0" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thời gian tham quan (phút)</label>
                        <input asp-for="EstimatedMinutes" type="number" class="form-control" value="30" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ưu tiên</label>
                        <select asp-for="Priority" class="form-select">
                            <option value="1" selected>Thấp</option>
                            <option value="2">Trung bình</option>
                            <option value="3">Cao</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Link Google Maps</label>
                        <input asp-for="MapLink" type="url" class="form-control" placeholder="https://maps.google.com/..." />
                    </div>
                    <div class="d-flex align-items-center gap-2 p-3" style="background:var(--dark4);border-radius:8px;border:1px solid var(--border);">
                        <input asp-for="IsActive" class="form-check-input m-0" type="checkbox" value="true" checked style="width:18px;height:18px;" />
                        <label class="form-label m-0" style="cursor:pointer;">
                            <i class="bi bi-check-circle-fill me-1" style="color:var(--green);"></i>Kích hoạt ngay
                        </label>
                    </div>
                </div>
            </div>

            <!-- Image Upload -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-image me-2" style="color:var(--blue);"></i>Hình ảnh
                </div>
                <div class="card-body">
                    <div id="imagePreview" class="mb-3" style="display:none;">
                        <img id="previewImg" src="" alt="Preview"
                             style="width:100%;height:180px;object-fit:cover;border-radius:8px;border:1px solid var(--border);" />
                    </div>
                    <div class="upload-zone" id="uploadZone" onclick="document.getElementById('imageFileInput').click()">
                        <i class="bi bi-cloud-upload" style="font-size:1.5rem;color:var(--cream-muted);margin-bottom:8px;"></i>
                        <div style="font-size:0.813rem;color:var(--cream-muted);font-weight:500;">Nhấn để chọn ảnh</div>
                        <div style="font-size:0.75rem;color:var(--cream-muted);opacity:0.6;">JPG, PNG, WebP · Tối đa 5MB</div>
                    </div>
                    <input type="file" name="ImageFile" id="imageFileInput" accept="image/*" style="display:none;" />
                </div>
            </div>

            <!-- Submit -->
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary" style="padding:11px;">
                    <i class="bi bi-plus-circle me-2"></i>Tạo POI &amp; Tài khoản
                </button>
                <a href="@Url.Action("Index")" class="btn btn-ghost btn-sm text-center" style="padding:9px;">
                    Hủy bỏ
                </a>
            </div>
        </div>
    </div>
</form>

@section Styles {
    <style>
        .upload-zone {
            border: 2px dashed var(--border);
            border-radius: 10px;
            padding: 24px;
            text-align: center;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            transition: border-color 0.15s, background 0.15s;
        }
        .upload-zone:hover { border-color: var(--amber); background: rgba(79,70,229,0.04); }
        textarea.form-control { resize: vertical; min-height: 110px; }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('categorySelect').addEventListener('change', function () {
            const isFood = this.value == '2';
            document.getElementById('foodTypeDiv').style.display = isFood ? 'block' : 'none';
            document.getElementById('priceDiv').style.display = isFood ? 'flex' : 'none';
        });
        document.getElementById('categorySelect').dispatchEvent(new Event('change'));

        document.getElementById('imageFileInput').addEventListener('change', function () {
            const file = this.files[0];
            if (!file || !file.type.startsWith('image/')) return;
            if (file.size > 5 * 1024 * 1024) { alert('File quá lớn! Tối đa 5MB.'); this.value = ''; return; }
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('previewImg').src = e.target.result;
                document.getElementById('imagePreview').style.display = 'block';
                document.getElementById('uploadZone').style.display = 'none';
            };
            reader.readAsDataURL(file);
        });

        document.querySelector('input[name="OwnerEmail"]').addEventListener('blur', function () {
            const username = document.querySelector('input[name="OwnerUsername"]');
            if (!username.value && this.value) {
                username.value = this.value.split('@@')[0].toLowerCase().replace(/[^a-z0-9_]/g, '');
            }
        });
    </script>
}
