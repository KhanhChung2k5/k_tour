@model POIViewModel
@{
    ViewData["Title"] = "Thêm POI mới";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1"><i class="bi bi-plus-circle"></i> Thêm POI mới</span>
            <a href="@Url.Action("Index")" class="btn btn-outline-light">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="card shadow">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0"><i class="bi bi-shop"></i> Tạo Cửa hàng / Địa điểm mới</h4>
                    </div>
                    <div class="card-body">
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show">
                                <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        }

                        <form method="post" asp-action="Create" enctype="multipart/form-data">
                            @Html.AntiForgeryToken()

                            <div class="row">
                                <!-- Basic Information -->
                                <div class="col-md-6">
                                    <h5 class="text-primary mb-3"><i class="bi bi-info-circle"></i> Thông tin cơ bản</h5>

                                    <div class="mb-3">
                                        <label class="form-label">Tên POI <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" name="Name" required />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Mô tả <span class="text-danger">*</span></label>
                                        <textarea class="form-control" name="Description" rows="3" required></textarea>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Địa chỉ</label>
                                        <input type="text" class="form-control" name="Address" />
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Vĩ độ (Latitude) <span class="text-danger">*</span></label>
                                            <input type="number" step="any" class="form-control" name="Latitude" required />
                                            <small class="text-muted">VD: 16.0544</small>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Kinh độ (Longitude) <span class="text-danger">*</span></label>
                                            <input type="number" step="any" class="form-control" name="Longitude" required />
                                            <small class="text-muted">VD: 108.2022</small>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Bán kính geofence (m)</label>
                                        <input type="number" class="form-control" name="Radius" value="50" />
                                        <small class="text-muted">Bán kính để kích hoạt thông báo (mặc định: 50m)</small>
                                    </div>
                                </div>

                                <!-- Category & Details -->
                                <div class="col-md-6">
                                    <h5 class="text-primary mb-3"><i class="bi bi-tag"></i> Phân loại & Chi tiết</h5>

                                    <div class="mb-3">
                                        <label class="form-label">Loại POI <span class="text-danger">*</span></label>
                                        <select class="form-select" name="Category" id="categorySelect" required>
                                            <option value="0">Tất cả</option>
                                            <option value="1">Tham quan</option>
                                            <option value="2" selected>Ẩm thực</option>
                                            <option value="3">Nghỉ dưỡng</option>
                                            <option value="4">Mua sắm</option>
                                            <option value="5">Giải trí</option>
                                            <option value="6">Di tích lịch sử</option>
                                            <option value="7">Thiên nhiên</option>
                                        </select>
                                    </div>

                                    <div class="mb-3" id="foodTypeDiv">
                                        <label class="form-label">Loại món ăn</label>
                                        <select class="form-select" name="FoodType">
                                            <option value="0">Khác</option>
                                            <option value="1">Hải sản</option>
                                            <option value="2">Món chay</option>
                                            <option value="3">Đặc sản</option>
                                            <option value="4">Đường phố</option>
                                            <option value="5">Nướng</option>
                                            <option value="6">Bún/Phở/Mì</option>
                                        </select>
                                    </div>

                                    <div class="row" id="priceDiv">
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Giá tối thiểu (VND)</label>
                                            <input type="number" class="form-control" name="PriceMin" value="0" />
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="form-label">Giá tối đa (VND)</label>
                                            <input type="number" class="form-control" name="PriceMax" value="0" />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Thời gian tham quan (phút)</label>
                                        <input type="number" class="form-control" name="EstimatedMinutes" value="30" />
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Ưu tiên</label>
                                        <select class="form-select" name="Priority">
                                            <option value="1" selected>Thấp</option>
                                            <option value="2">Trung bình</option>
                                            <option value="3">Cao</option>
                                        </select>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label"><i class="bi bi-image"></i> Hình ảnh</label>
                                        <input type="file" class="form-control" name="ImageFile" id="imageFileInput" accept="image/*" />
                                        <small class="text-muted">Chọn ảnh từ thiết bị (.jpg, .png, .webp). Tối đa 5MB.</small>
                                        <div id="imagePreview" class="mt-2" style="display: none;">
                                            <img id="previewImg" src="" alt="Preview" class="img-thumbnail" style="max-width: 200px; max-height: 200px;" />
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">Link Google Maps</label>
                                        <input type="url" class="form-control" name="MapLink" />
                                    </div>

                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" checked />
                                        <label class="form-check-label">
                                            <i class="bi bi-check-circle text-success"></i> Kích hoạt ngay
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4" />

                            <!-- POI Content (Multilingual) -->
                            <h5 class="text-primary mb-3"><i class="bi bi-translate"></i> Nội dung thuyết minh</h5>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">
                                            <img src="https://flagcdn.com/w20/vn.png" alt="VI" /> Nội dung tiếng Việt
                                        </label>
                                        <textarea class="form-control" name="TextContent_vi" rows="6" placeholder="Nhập nội dung thuyết minh bằng tiếng Việt..."></textarea>
                                        <small class="text-muted">Nội dung sẽ được phát khi du khách đến địa điểm</small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <label class="form-label">
                                            <img src="https://flagcdn.com/w20/us.png" alt="EN" /> English Content
                                        </label>
                                        <textarea class="form-control" name="TextContent_en" rows="6" placeholder="Enter narration content in English..."></textarea>
                                        <small class="text-muted">Content will be played when tourists arrive</small>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4" />

                            <div class="d-flex justify-content-between">
                                <a href="@Url.Action("Index")" class="btn btn-secondary">
                                    <i class="bi bi-x-circle"></i> Hủy
                                </a>
                                <button type="submit" class="btn btn-success btn-lg">
                                    <i class="bi bi-save"></i> Tạo POI
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Show/hide food type and price fields based on category
        document.getElementById('categorySelect').addEventListener('change', function() {
            const foodTypeDiv = document.getElementById('foodTypeDiv');
            const priceDiv = document.getElementById('priceDiv');

            if (this.value == '2') { // Food category
                foodTypeDiv.style.display = 'block';
                priceDiv.style.display = 'flex';
            } else {
                foodTypeDiv.style.display = 'none';
                priceDiv.style.display = 'none';
            }
        });

        // Trigger on page load
        document.getElementById('categorySelect').dispatchEvent(new Event('change'));

        // Image file preview
        const imageFileInput = document.getElementById('imageFileInput');
        const imagePreview = document.getElementById('imagePreview');
        const previewImg = document.getElementById('previewImg');

        imageFileInput.addEventListener('change', function() {
            const file = this.files[0];
            if (file && file.type.startsWith('image/')) {
                if (file.size > 5 * 1024 * 1024) {
                    alert('File quá lớn! Vui lòng chọn file nhỏ hơn 5MB.');
                    this.value = '';
                    imagePreview.style.display = 'none';
                    return;
                }
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    imagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);
            } else {
                imagePreview.style.display = 'none';
            }
        });
    </script>
</body>
</html>
