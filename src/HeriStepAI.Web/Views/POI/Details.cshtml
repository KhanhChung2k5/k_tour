@model POIViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết POI";
}

<div class="page-header">
    <div>
        <button class="back-link" onclick="history.back()">← Quay lại danh sách</button>
        <h1 class="page-title-text" style="margin-top:8px;">@Model.Name</h1>
        <p class="page-subtitle-text">Chi tiết địa điểm #@Model.Id</p>
    </div>
    <div style="display:flex;gap:10px;align-items:center;">
        <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary btn-sm">
            <i class="bi bi-pencil"></i>Chỉnh sửa
        </a>
        <a href="@Url.Action("Index")" class="btn btn-ghost btn-sm">
            <i class="bi bi-arrow-left"></i>Quay lại
        </a>
    </div>
</div>

<div class="row g-4">
    <!-- Main Info -->
    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header">
                <span><i class="bi bi-shop me-2" style="color:var(--amber);"></i>Thông tin chính</span>
                @if (Model.IsActive)
                {
                    <span class="status-dot active">Hoạt động</span>
                }
                else
                {
                    <span class="status-dot inactive">Tạm dừng</span>
                }
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <div class="mb-4">
                        <img src="@Model.ImageUrl" alt="@Model.Name"
                             style="width:100%;height:220px;object-fit:cover;border-radius:10px;border:1px solid var(--border);" />
                    </div>
                }

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="info-field">
                            <div class="info-label">Tên địa điểm</div>
                            <div class="info-value">@Model.Name</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-field">
                            <div class="info-label">Địa chỉ</div>
                            <div class="info-value">
                                <i class="bi bi-geo-alt" style="color:var(--red);"></i>
                                @(Model.Address ?? "Chưa có")
                            </div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="info-field">
                            <div class="info-label">Mô tả</div>
                            <div class="info-value" style="font-weight:300;line-height:1.7;color:var(--cream-muted);">@(Model.Description ?? "Chưa có mô tả")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-field">
                            <div class="info-label">Tọa độ</div>
                            <div class="info-value d-flex flex-column gap-1">
                                <code style="font-size:0.75rem;background:var(--dark4);color:var(--blue);padding:3px 8px;border-radius:5px;">Lat: @Model.Latitude.ToString("F6")</code>
                                <code style="font-size:0.75rem;background:var(--dark4);color:var(--blue);padding:3px 8px;border-radius:5px;">Lng: @Model.Longitude.ToString("F6")</code>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-field">
                            <div class="info-label">Loại</div>
                            <div class="info-value d-flex flex-wrap gap-1">
                                <span class="badge-soft-primary">@Model.CategoryName</span>
                                @if (Model.Category == 2)
                                {
                                    <span class="badge-soft-warning">@Model.FoodTypeName</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-field">
                            <div class="info-label">Đánh giá</div>
                            <div class="info-value">
                                @if (Model.Rating.HasValue)
                                {
                                    <span><i class="bi bi-star-fill" style="color:var(--amber);"></i> @Model.Rating.Value.ToString("F1") <span style="color:var(--cream-muted);font-size:0.75rem;">(@Model.ReviewCount đánh giá)</span></span>
                                }
                                else
                                {
                                    <span style="color:var(--cream-muted);">Chưa có đánh giá</span>
                                }
                            </div>
                        </div>
                    </div>
                    @if (Model.Category == 2 && (Model.PriceMin > 0 || Model.PriceMax > 0))
                    {
                        <div class="col-md-4">
                            <div class="info-field">
                                <div class="info-label">Giá</div>
                                <div class="info-value" style="color:var(--amber);font-weight:600;">
                                    @Model.PriceMin.ToString("N0")–@Model.PriceMax.ToString("N0") VND
                                </div>
                            </div>
                        </div>
                    }
                    <div class="col-md-4">
                        <div class="info-field">
                            <div class="info-label">Thời gian tham quan</div>
                            <div class="info-value"><i class="bi bi-clock me-1"></i>@Model.EstimatedMinutes phút</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-field">
                            <div class="info-label">Ưu tiên</div>
                            <div class="info-value">
                                @switch (Model.Priority)
                                {
                                    case 1: <span class="badge-soft-secondary">Thấp</span> break;
                                    case 2: <span class="badge-soft-info">Trung bình</span> break;
                                    case 3: <span class="badge-soft-danger">Cao</span> break;
                                    default: <span class="badge-soft-secondary">@Model.Priority</span> break;
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.MapLink))
                {
                    <div class="mt-3 pt-3" style="border-top:1px solid var(--border);">
                        <a href="@Model.MapLink" target="_blank"
                           style="display:inline-flex;align-items:center;gap:8px;padding:10px 18px;background:var(--dark4);border:1px solid var(--border);border-radius:9px;color:var(--cream-muted);font-size:0.82rem;text-decoration:none;transition:all 0.2s;"
                           onmouseover="this.style.borderColor='var(--border-hover)';this.style.color='var(--amber)';"
                           onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--cream-muted)';">
                            🗺 Xem trên Google Maps
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Narration Content -->
        @if (Model.Contents != null && Model.Contents.Any())
        {
            <div class="card">
                <div class="card-header">
                    <span><i class="bi bi-translate me-2" style="color:var(--blue);"></i>Nội dung thuyết minh</span>
                </div>
                <div class="card-body">
                    @{
                        var languages = new[] { "vi", "en", "ko", "zh", "ja", "th", "fr" };
                        var langLabels = new Dictionary<string, string> {
                            {"vi","🇻🇳 Việt"}, {"en","🇬🇧 EN"}, {"ko","🇰🇷 KO"},
                            {"zh","🇨🇳 ZH"}, {"ja","🇯🇵 JA"}, {"th","🇹🇭 TH"}, {"fr","🇫🇷 FR"}
                        };
                        var firstLang = Model.Contents.Select(c => c.Language).FirstOrDefault(l => languages.Contains(l)) ?? "vi";
                    }
                    <ul class="nav nav-tabs-pill mb-3" role="tablist">
                        @foreach (var lang in languages)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(lang == firstLang ? "active" : "")"
                                   data-bs-toggle="tab" href="#dtab-@lang">@langLabels[lang]</a>
                            </li>
                        }
                    </ul>
                    <div class="tab-content">
                        @foreach (var lang in languages)
                        {
                            var content = Model.Contents.FirstOrDefault(c => c.Language == lang);
                            <div class="tab-pane fade @(lang == firstLang ? "show active" : "")" id="dtab-@lang">
                                @if (content != null)
                                {
                                    <div style="background:var(--dark4);border:1px solid var(--border);border-radius:10px;padding:16px;font-size:0.88rem;color:var(--cream);line-height:1.7;font-weight:300;min-height:80px;white-space:pre-wrap;">@content.TextContent</div>
                                    @if (!string.IsNullOrEmpty(content.AudioUrl))
                                    {
                                        <audio controls src="@content.AudioUrl" style="width:100%;border-radius:8px;margin-top:12px;"></audio>
                                    }
                                }
                                else
                                {
                                    <p style="color:var(--cream-muted);font-style:italic;font-size:0.875rem;">Chưa có nội dung cho ngôn ngữ này.</p>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Side Panel -->
    <div class="col-lg-4">
        <!-- Technical Info -->
        <div class="card mb-4">
            <div class="card-header">
                <span><i class="bi bi-gear me-2" style="color:var(--cream-muted);"></i>Thông tin kỹ thuật</span>
            </div>
            <div class="card-body" style="padding:0 20px !important;">
                <div class="detail-row"><span class="detail-label">Bán kính Geofence</span><span class="detail-val">@Model.Radius m</span></div>
                <div class="detail-row"><span class="detail-label">Owner ID</span><span class="detail-val">@(Model.OwnerId?.ToString() ?? "—")</span></div>
                <div class="detail-row"><span class="detail-label">Tour ID</span><span class="detail-val" style="color:var(--cream-muted);">@(Model.TourId?.ToString() ?? "—")</span></div>
                <div class="detail-row"><span class="detail-label">Ngày tạo</span><span class="detail-val">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
                <div class="detail-row" style="border-bottom:none;"><span class="detail-label">Cập nhật cuối</span><span class="detail-val">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span></div>
            </div>
        </div>

        <!-- Actions -->
        <div class="card">
            <div class="card-header">
                <span><i class="bi bi-lightning-charge me-2" style="color:var(--amber);"></i>Thao tác</span>
            </div>
            <div class="card-body d-grid gap-2">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-primary" style="justify-content:center;">
                    <i class="bi bi-pencil"></i>Chỉnh sửa
                </a>
                <form method="post" action="@Url.Action("ToggleActive", new { id = Model.Id })">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn w-100" style="justify-content:center;display:flex;align-items:center;gap:8px;background:@(Model.IsActive ? "rgba(232,161,75,0.12)" : "rgba(46,204,148,0.12)");color:@(Model.IsActive ? "var(--amber)" : "var(--green)");border:1px solid @(Model.IsActive ? "rgba(232,161,75,0.3)" : "rgba(46,204,148,0.3)");">
                        <i class="bi bi-toggle-@(Model.IsActive ? "off" : "on")"></i>
                        @(Model.IsActive ? "Tạm dừng" : "Kích hoạt")
                    </button>
                </form>
                <button type="button" class="btn" data-bs-toggle="modal" data-bs-target="#deleteModal"
                        style="justify-content:center;display:flex;align-items:center;gap:8px;background:var(--red-dim);color:var(--red);border:1px solid rgba(224,82,82,0.3);">
                    <i class="bi bi-trash"></i>Xóa POI
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body p-4 text-center">
                <div style="width:48px;height:48px;border-radius:12px;background:var(--red-dim);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                    <i class="bi bi-trash" style="color:var(--red);font-size:1.25rem;"></i>
                </div>
                <h6 style="font-weight:700;margin-bottom:6px;color:var(--cream);">Xóa POI?</h6>
                <p style="font-size:0.82rem;color:var(--cream-muted);margin-bottom:20px;">
                    Xóa <strong style="color:var(--cream);">@Model.Name</strong>? Hành động không thể hoàn tác.
                </p>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-sm flex-fill btn-ghost" data-bs-dismiss="modal">Hủy</button>
                    <form method="post" action="@Url.Action("Delete", new { id = Model.Id })" class="flex-fill">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm w-100"
                                style="background:var(--red);color:#fff;border:none;">Xóa vĩnh viễn</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .back-link {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 0.8rem; color: var(--cream-muted);
            cursor: pointer; transition: color 0.2s;
            border: none; background: none;
            font-family: 'Be Vietnam Pro', sans-serif; padding: 0;
        }
        .back-link:hover { color: var(--amber); }

        .info-field { display: flex; flex-direction: column; gap: 4px; }
        .info-label  { font-size: 0.68rem; font-weight: 600; color: var(--cream-muted); text-transform: uppercase; letter-spacing: 0.12em; }
        .info-value  { font-size: 0.9rem; color: var(--cream); font-weight: 400; }

        .status-dot {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 0.78rem; font-weight: 500;
            padding: 4px 10px; border-radius: 99px;
        }
        .status-dot::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
        .status-dot.active   { background: var(--green-dim); color: var(--green); }
        .status-dot.inactive { background: var(--cream-dim); color: var(--cream-muted); }

        .detail-row {
            padding: 14px 0;
            border-bottom: 1px solid var(--border);
            display: flex; align-items: flex-start;
            justify-content: space-between; gap: 12px;
        }
        .detail-label { font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--cream-muted); font-weight: 600; flex-shrink: 0; }
        .detail-val   { font-size: 0.84rem; color: var(--cream); font-weight: 500; text-align: right; }
    </style>
}
