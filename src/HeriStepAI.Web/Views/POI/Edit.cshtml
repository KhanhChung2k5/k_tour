@model POIViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh sửa POI";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="page-title"><i class="bi bi-pencil-square me-2"></i>Chỉnh sửa: @Model.Name</h4>
        <p class="page-subtitle">Cập nhật thông tin địa điểm</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm" style="border-radius:8px;">
        <i class="bi bi-arrow-left me-1"></i> Quay lại
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" style="border-radius:10px;">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="post" asp-action="Edit" asp-route-id="@Model.Id" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />
    <input type="hidden" name="CreatedAt" value="@Model.CreatedAt" />
    <input type="hidden" name="OwnerId" value="@Model.OwnerId" />

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-7">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-bottom">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-info-circle me-1"></i> Thông tin cơ bản</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Tên POI <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="Name" value="@Model.Name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Mô tả <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="Description" rows="3" required>@Model.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Địa chỉ</label>
                        <input type="text" class="form-control" name="Address" value="@Model.Address" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small">Vĩ độ <span class="text-danger">*</span></label>
                            <input type="number" step="any" class="form-control" name="Latitude" value="@Model.Latitude" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold small">Kinh độ <span class="text-danger">*</span></label>
                            <input type="number" step="any" class="form-control" name="Longitude" value="@Model.Longitude" required />
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label fw-semibold small">Bán kính geofence (m)</label>
                        <input type="number" class="form-control" name="Radius" value="@Model.Radius" />
                    </div>
                </div>
            </div>

            <!-- Content -->
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3 border-bottom">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-translate me-1"></i> Nội dung thuyết minh</h6>
                </div>
                <div class="card-body p-4">
                    <ul class="nav nav-tabs" id="langTabs" role="tablist">
                        <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-vi">🇻🇳 Tiếng Việt</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-en">🇬🇧 English</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-ko">🇰🇷 한국어</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-zh">🇨🇳 中文</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-ja">🇯🇵 日本語</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-th">🇹🇭 ภาษาไทย</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-fr">🇫🇷 Français</a></li>
                    </ul>
                    <div class="tab-content pt-3">
                        <div class="tab-pane fade show active" id="tab-vi">
                            <textarea class="form-control" name="TextContent_vi" rows="5" placeholder="Nội dung thuyết minh tiếng Việt...">@Model.TextContent_vi</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-en">
                            <textarea class="form-control" name="TextContent_en" rows="5" placeholder="English narration content...">@Model.TextContent_en</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-ko">
                            <textarea class="form-control" name="TextContent_ko" rows="5" placeholder="한국어 나레이션 내용...">@Model.TextContent_ko</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-zh">
                            <textarea class="form-control" name="TextContent_zh" rows="5" placeholder="中文解说内容...">@Model.TextContent_zh</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-ja">
                            <textarea class="form-control" name="TextContent_ja" rows="5" placeholder="日本語ナレーション内容...">@Model.TextContent_ja</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-th">
                            <textarea class="form-control" name="TextContent_th" rows="5" placeholder="เนื้อหาบรรยายภาษาไทย...">@Model.TextContent_th</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-fr">
                            <textarea class="form-control" name="TextContent_fr" rows="5" placeholder="Contenu de narration en français...">@Model.TextContent_fr</textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-5">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-bottom">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-tag me-1"></i> Phân loại</h6>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Loại POI <span class="text-danger">*</span></label>
                        <select class="form-select" name="Category" id="categorySelect" required>
                            <option value="0">Tất cả</option>
                            <option value="1">Tham quan</option>
                            <option value="2">Ẩm thực</option>
                            <option value="3">Nghỉ dưỡng</option>
                            <option value="4">Mua sắm</option>
                            <option value="5">Giải trí</option>
                            <option value="6">Di tích lịch sử</option>
                            <option value="7">Thiên nhiên</option>
                        </select>
                    </div>
                    <div class="mb-3" id="foodTypeDiv">
                        <label class="form-label fw-semibold small">Loại món ăn</label>
                        <select class="form-select" name="FoodType" id="foodTypeSelect">
                            <option value="0">Khác</option>
                            <option value="1">Hải sản</option>
                            <option value="2">Món chay</option>
                            <option value="3">Đặc sản</option>
                            <option value="4">Đường phố</option>
                            <option value="5">Nướng</option>
                            <option value="6">Bún/Phở/Mì</option>
                        </select>
                    </div>
                    <div class="row" id="priceDiv">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold small">Giá min (VND)</label>
                            <input type="number" class="form-control" name="PriceMin" value="@Model.PriceMin" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold small">Giá max (VND)</label>
                            <input type="number" class="form-control" name="PriceMax" value="@Model.PriceMax" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Thời gian tham quan (phút)</label>
                        <input type="number" class="form-control" name="EstimatedMinutes" value="@Model.EstimatedMinutes" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Ưu tiên</label>
                        <select class="form-select" name="Priority" id="prioritySelect">
                            <option value="1">Thấp</option>
                            <option value="2">Trung bình</option>
                            <option value="3">Cao</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Link Google Maps</label>
                        <input type="url" class="form-control" name="MapLink" value="@Model.MapLink" />
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="IsActive" value="true" id="isActiveCheck" />
                        <label class="form-check-label small">
                            <i class="bi bi-check-circle text-success"></i> Kích hoạt
                        </label>
                    </div>
                </div>
            </div>

            <!-- Image -->
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-white py-3 border-bottom">
                    <h6 class="mb-0 fw-bold"><i class="bi bi-image me-1"></i> Hình ảnh</h6>
                </div>
                <div class="card-body p-4">
                    <input type="file" class="form-control" name="ImageFile" id="imageFileInput" accept="image/*" />
                    <input type="hidden" name="ImageUrl" value="@Model.ImageUrl" />
                    <small class="text-muted">Chọn ảnh mới để thay thế. Để trống nếu giữ ảnh cũ.</small>
                    <div id="imagePreview" class="mt-3 text-center" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")">
                        <img id="previewImg" src="@Model.ImageUrl" alt="Preview" class="img-thumbnail" style="max-width:100%;max-height:200px;border-radius:10px;" />
                    </div>
                </div>
            </div>

            <!-- Metadata -->
            <div class="card shadow-sm mb-4">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between small text-muted">
                        <span><i class="bi bi-calendar-plus me-1"></i> Tạo: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        <span><i class="bi bi-calendar-check me-1"></i> Cập nhật: @Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div>
            </div>

            <!-- Submit -->
            <div class="d-grid">
                <button type="submit" class="btn btn-primary" style="border-radius:10px;padding:10px;">
                    <i class="bi bi-save me-1"></i> Cập nhật
                </button>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Set initial values from model
        document.getElementById('categorySelect').value = '@Model.Category';
        document.getElementById('foodTypeSelect').value = '@Model.FoodType';
        document.getElementById('prioritySelect').value = '@Model.Priority';
        document.getElementById('isActiveCheck').checked = @(Model.IsActive ? "true" : "false");

        document.getElementById('categorySelect').addEventListener('change', function () {
            document.getElementById('foodTypeDiv').style.display = this.value == '2' ? 'block' : 'none';
            document.getElementById('priceDiv').style.display = this.value == '2' ? 'flex' : 'none';
        });
        document.getElementById('categorySelect').dispatchEvent(new Event('change'));

        document.getElementById('imageFileInput').addEventListener('change', function () {
            const file = this.files[0];
            if (file && file.type.startsWith('image/')) {
                if (file.size > 5 * 1024 * 1024) { alert('File quá lớn! Tối đa 5MB.'); this.value = ''; return; }
                const reader = new FileReader();
                reader.onload = e => { document.getElementById('previewImg').src = e.target.result; document.getElementById('imagePreview').style.display = 'block'; };
                reader.readAsDataURL(file);
            }
        });
    </script>
}
