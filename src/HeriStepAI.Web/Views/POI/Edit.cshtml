@model POIViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh sửa POI";
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Chỉnh sửa: @Model.Name</h1>
        <p class="page-subtitle-text">Cập nhật thông tin địa điểm</p>
    </div>
    <a href="@Url.Action("Index")" class="btn btn-sm" style="background:#f1f5f9;color:#475569;border:none;">
        <i class="bi bi-arrow-left me-1"></i>Quay lại
    </a>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@TempData["Error"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<form method="post" asp-action="Edit" asp-route-id="@Model.Id" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id" />
    <input type="hidden" name="CreatedAt" value="@Model.CreatedAt" />
    <input type="hidden" name="OwnerId" value="@Model.OwnerId" />

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-7">
            <!-- Basic Info -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-geo-alt-fill me-2" style="color:#4f46e5;"></i>Thông tin cơ bản
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Tên POI <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="Name" value="@Model.Name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Mô tả <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="Description" rows="3" required>@Model.Description</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" class="form-control" name="Address" value="@Model.Address" />
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Vĩ độ <span class="text-danger">*</span></label>
                            <input type="number" step="any" class="form-control" name="Latitude" value="@Model.Latitude" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kinh độ <span class="text-danger">*</span></label>
                            <input type="number" step="any" class="form-control" name="Longitude" value="@Model.Longitude" required />
                        </div>
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Bán kính geofence (m)</label>
                        <input type="number" class="form-control" name="Radius" value="@Model.Radius" />
                    </div>
                </div>
            </div>

            <!-- Narration Content -->
            <div class="card">
                <div class="card-header">
                    <i class="bi bi-translate me-2" style="color:#8b5cf6;"></i>Nội dung thuyết minh
                </div>
                <div class="card-body">
                    <ul class="nav nav-tabs-pill mb-3" role="tablist">
                        <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-vi">🇻🇳 Việt</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-en">🇬🇧 EN</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-ko">🇰🇷 KO</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-zh">🇨🇳 ZH</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-ja">🇯🇵 JA</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-th">🇹🇭 TH</a></li>
                        <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-fr">🇫🇷 FR</a></li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="tab-vi">
                            <textarea class="form-control" name="TextContent_vi" rows="5" placeholder="Nội dung tiếng Việt...">@Model.TextContent_vi</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-en">
                            <textarea class="form-control" name="TextContent_en" rows="5" placeholder="English content...">@Model.TextContent_en</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-ko">
                            <textarea class="form-control" name="TextContent_ko" rows="5" placeholder="한국어 내용...">@Model.TextContent_ko</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-zh">
                            <textarea class="form-control" name="TextContent_zh" rows="5" placeholder="中文内容...">@Model.TextContent_zh</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-ja">
                            <textarea class="form-control" name="TextContent_ja" rows="5" placeholder="日本語内容...">@Model.TextContent_ja</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-th">
                            <textarea class="form-control" name="TextContent_th" rows="5" placeholder="เนื้อหาภาษาไทย...">@Model.TextContent_th</textarea>
                        </div>
                        <div class="tab-pane fade" id="tab-fr">
                            <textarea class="form-control" name="TextContent_fr" rows="5" placeholder="Contenu français...">@Model.TextContent_fr</textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-5">
            <!-- Category & Settings -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-tag-fill me-2" style="color:#f59e0b;"></i>Phân loại &amp; Cài đặt
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Loại POI <span class="text-danger">*</span></label>
                        <select class="form-select" name="Category" id="categorySelect" required>
                            <option value="0">Tất cả</option>
                            <option value="1">Tham quan</option>
                            <option value="2">Ẩm thực</option>
                            <option value="3">Nghỉ dưỡng</option>
                            <option value="4">Mua sắm</option>
                            <option value="5">Giải trí</option>
                            <option value="6">Di tích lịch sử</option>
                            <option value="7">Thiên nhiên</option>
                        </select>
                    </div>
                    <div class="mb-3" id="foodTypeDiv">
                        <label class="form-label">Loại món ăn</label>
                        <select class="form-select" name="FoodType" id="foodTypeSelect">
                            <option value="0">Khác</option>
                            <option value="1">Hải sản</option>
                            <option value="2">Món chay</option>
                            <option value="3">Đặc sản</option>
                            <option value="4">Đường phố</option>
                            <option value="5">Nướng</option>
                            <option value="6">Bún/Phở/Mì</option>
                        </select>
                    </div>
                    <div class="row g-2 mb-3" id="priceDiv">
                        <div class="col-6">
                            <label class="form-label">Giá min (VND)</label>
                            <input type="number" class="form-control" name="PriceMin" value="@Model.PriceMin" />
                        </div>
                        <div class="col-6">
                            <label class="form-label">Giá max (VND)</label>
                            <input type="number" class="form-control" name="PriceMax" value="@Model.PriceMax" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Thời gian tham quan (phút)</label>
                        <input type="number" class="form-control" name="EstimatedMinutes" value="@Model.EstimatedMinutes" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ưu tiên</label>
                        <select class="form-select" name="Priority" id="prioritySelect">
                            <option value="1">Thấp</option>
                            <option value="2">Trung bình</option>
                            <option value="3">Cao</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Link Google Maps</label>
                        <input type="url" class="form-control" name="MapLink" value="@Model.MapLink" />
                    </div>
                    <div class="d-flex align-items-center gap-2 p-3" style="background:#f8fafc;border-radius:8px;">
                        <input class="form-check-input m-0" type="checkbox" name="IsActive" value="true" id="isActiveCheck" style="width:18px;height:18px;" />
                        <label class="form-label m-0" for="isActiveCheck" style="cursor:pointer;">
                            <i class="bi bi-check-circle-fill me-1" style="color:#10b981;"></i>Kích hoạt
                        </label>
                    </div>
                </div>
            </div>

            <!-- Image -->
            <div class="card mb-4">
                <div class="card-header">
                    <i class="bi bi-image me-2" style="color:#3b82f6;"></i>Hình ảnh
                </div>
                <div class="card-body">
                    <div id="imagePreview" style="@(string.IsNullOrEmpty(Model.ImageUrl) ? "display:none;" : "")margin-bottom:12px;">
                        <img id="previewImg" src="@Model.ImageUrl" alt="Preview"
                             style="width:100%;height:180px;object-fit:cover;border-radius:8px;border:1px solid #e2e8f0;" />
                    </div>
                    <input type="file" class="form-control" name="ImageFile" id="imageFileInput" accept="image/*" />
                    <input type="hidden" name="ImageUrl" value="@Model.ImageUrl" />
                    <div style="font-size:0.75rem;color:#94a3b8;margin-top:6px;">Chọn ảnh mới để thay thế · Để trống nếu giữ ảnh cũ</div>
                </div>
            </div>

            <!-- Metadata -->
            <div class="card mb-4" style="background:#f8fafc !important;">
                <div class="card-body" style="padding:14px 16px !important;">
                    <div style="font-size:0.75rem;color:#94a3b8;display:flex;justify-content:space-between;flex-wrap:wrap;gap:6px;">
                        <span><i class="bi bi-calendar-plus me-1"></i>Tạo: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                        <span><i class="bi bi-calendar-check me-1"></i>Cập nhật: @Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div>
            </div>

            <!-- Submit -->
            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary" style="padding:11px;">
                    <i class="bi bi-check2 me-2"></i>Lưu thay đổi
                </button>
                <a href="@Url.Action("Details", new { id = Model.Id })" class="btn btn-sm text-center"
                   style="background:#f1f5f9;color:#475569;border:none;padding:9px;">
                    Hủy bỏ
                </a>
            </div>
        </div>
    </div>
</form>

@section Styles {
    <style>
        textarea.form-control { resize: vertical; min-height: 110px; }
    </style>
}

@section Scripts {
    <script>
        document.getElementById('categorySelect').value = '@Model.Category';
        document.getElementById('foodTypeSelect').value = '@Model.FoodType';
        document.getElementById('prioritySelect').value = '@Model.Priority';
        document.getElementById('isActiveCheck').checked = @(Model.IsActive ? "true" : "false");

        document.getElementById('categorySelect').addEventListener('change', function () {
            const isFood = this.value == '2';
            document.getElementById('foodTypeDiv').style.display = isFood ? 'block' : 'none';
            document.getElementById('priceDiv').style.display = isFood ? 'flex' : 'none';
        });
        document.getElementById('categorySelect').dispatchEvent(new Event('change'));

        document.getElementById('imageFileInput').addEventListener('change', function () {
            const file = this.files[0];
            if (!file || !file.type.startsWith('image/')) return;
            if (file.size > 5 * 1024 * 1024) { alert('File quá lớn! Tối đa 5MB.'); this.value = ''; return; }
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('previewImg').src = e.target.result;
                document.getElementById('imagePreview').style.display = 'block';
            };
            reader.readAsDataURL(file);
        });
    </script>
}
