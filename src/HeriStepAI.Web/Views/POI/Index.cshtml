@model List<POIViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý POI";
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Quản lý POI</h1>
        <p class="page-subtitle-text">Danh sách cửa hàng &amp; địa điểm du lịch</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <span>@TempData["Success"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@TempData["Error"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-card">
    <div style="display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--border);">
        <span style="font-size:0.92rem;font-weight:600;color:var(--cream);display:flex;align-items:center;gap:8px;">
            <i class="bi bi-list-ul" style="color:var(--amber);"></i>Danh sách POI
        </span>
        <div style="display:flex;align-items:center;gap:12px;">
            <span style="font-size:0.8rem;color:var(--cream-muted);">
                <span class="dot-active"></span> @Model.Count(p => p.IsActive) hoạt động
                &nbsp;·&nbsp;
                <span class="dot-inactive"></span> @Model.Count(p => !p.IsActive) tạm dừng
            </span>
            <span style="background:var(--amber-dim);color:var(--amber);font-size:0.7rem;font-weight:700;padding:3px 10px;border-radius:99px;">
                @Model.Count tổng
            </span>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th style="width:60px;padding-left:24px;">ID</th>
                        <th style="min-width:300px;">Địa điểm</th>
                        <th class="text-center" style="width:120px;">Loại</th>
                        <th class="text-center" style="width:120px;">Món ăn</th>
                        <th class="text-center" style="width:140px;">Giá (đ)</th>
                        <th class="text-center" style="width:110px;">Trạng thái</th>
                        <th class="text-end"    style="width:130px;padding-right:24px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var poi in Model)
                    {
                        <tr>
                            <td style="padding-left:24px;">
                                <code style="font-size:0.78rem;color:var(--cream-muted);background:var(--dark4);padding:2px 7px;border-radius:5px;">#@poi.Id</code>
                            </td>
                            <td>
                                <div style="display:flex;align-items:center;gap:12px;">
                                    @if (!string.IsNullOrEmpty(poi.ImageUrl))
                                    {
                                        <img src="@poi.ImageUrl" alt="@poi.Name"
                                             style="width:40px;height:40px;border-radius:8px;object-fit:cover;flex-shrink:0;border:1px solid var(--border);" />
                                    }
                                    else
                                    {
                                        <div class="poi-avatar">@poi.Name.Substring(0, 1).ToUpper()</div>
                                    }
                                    <div style="min-width:0;">
                                        <div style="font-weight:600;font-size:0.88rem;color:var(--cream);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:240px;">
                                            @poi.Name
                                        </div>
                                        <div style="font-size:0.74rem;color:var(--cream-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:240px;margin-top:2px;">
                                            <i class="bi bi-geo-alt"></i> @(poi.Address ?? "Chưa có địa chỉ")
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge-soft-primary">@poi.CategoryName</span>
                            </td>
                            <td class="text-center">
                                @if (poi.Category == 2 && !string.IsNullOrEmpty(poi.FoodTypeName))
                                {
                                    <span class="badge-soft-info">@poi.FoodTypeName</span>
                                }
                                else
                                {
                                    <span style="color:var(--cream-muted);font-size:0.8rem;">—</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (poi.PriceMin > 0 || poi.PriceMax > 0)
                                {
                                    <span style="font-size:0.82rem;font-weight:600;color:var(--amber);">
                                        @poi.PriceMin.ToString("N0")–@poi.PriceMax.ToString("N0")
                                    </span>
                                }
                                else
                                {
                                    <span style="color:var(--cream-muted);font-size:0.8rem;">—</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (poi.IsActive)
                                {
                                    <span class="status-dot active">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="status-dot inactive">Tạm dừng</span>
                                }
                            </td>
                            <td class="text-end" style="padding-right:24px;">
                                <div class="d-inline-flex gap-1">
                                    <a href="@Url.Action("Details", new { id = poi.Id })"
                                       class="action-btn" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = poi.Id })"
                                       class="action-btn edit" title="Sửa">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form method="post" action="@Url.Action("ToggleActive", new { id = poi.Id })" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="action-btn @(poi.IsActive ? "pause" : "play")"
                                                title="@(poi.IsActive ? "Tạm dừng" : "Kích hoạt")">
                                            <i class="bi bi-@(poi.IsActive ? "pause" : "play")-circle"></i>
                                        </button>
                                    </form>
                                    <button type="button" class="action-btn delete"
                                            data-bs-toggle="modal" data-bs-target="#del@(poi.Id)" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>

                                <!-- Delete Modal -->
                                <div class="modal fade" id="del@(poi.Id)" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered modal-sm">
                                        <div class="modal-content">
                                            <div class="modal-body p-4 text-center">
                                                <div style="width:48px;height:48px;border-radius:12px;background:var(--red-dim);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                                                    <i class="bi bi-trash" style="color:var(--red);font-size:1.25rem;"></i>
                                                </div>
                                                <h6 style="font-weight:700;margin-bottom:6px;color:var(--cream);">Xóa POI?</h6>
                                                <p style="font-size:0.82rem;color:var(--cream-muted);margin-bottom:20px;">
                                                    Xóa <strong style="color:var(--cream);">@poi.Name</strong>? Hành động này không thể hoàn tác.
                                                </p>
                                                <div class="d-flex gap-2">
                                                    <button type="button" class="btn btn-sm flex-fill btn-ghost" data-bs-dismiss="modal">Hủy</button>
                                                    <form method="post" action="@Url.Action("Delete", new { id = poi.Id })" class="flex-fill">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-sm w-100"
                                                                style="background:var(--red);color:#fff;border:none;">Xóa</button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div style="width:60px;height:60px;border-radius:50%;background:var(--amber-dim);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
                <i class="bi bi-shop" style="font-size:1.5rem;color:var(--amber);"></i>
            </div>
            <p style="font-weight:600;color:var(--cream);margin-bottom:4px;">Chưa có POI nào</p>
            <p style="font-size:0.82rem;color:var(--cream-muted);margin-bottom:0;">Chủ quán tự thêm địa điểm sau khi được duyệt và đăng nhập (không tạo từ Admin).</p>
        </div>
    }
</div>

@section Styles {
    <style>
        .poi-avatar {
            width: 40px; height: 40px;
            border-radius: 8px;
            background: var(--amber-dim);
            color: var(--amber);
            font-weight: 700;
            font-size: 1rem;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .dot-active   { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--green); vertical-align: middle; margin-right: 3px; }
        .dot-inactive { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--cream-muted); vertical-align: middle; margin-right: 3px; }

        .status-dot {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 0.78rem; font-weight: 500;
            padding: 4px 10px; border-radius: 99px;
        }
        .status-dot::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
        .status-dot.active   { background: var(--green-dim); color: var(--green); }
        .status-dot.inactive { background: var(--cream-dim); color: var(--cream-muted); }

        .action-btn {
            display: inline-flex; align-items: center; justify-content: center;
            width: 32px; height: 32px; border-radius: 7px;
            border: 1px solid var(--border);
            background: transparent;
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.15s;
            color: var(--cream-muted);
            text-decoration: none;
        }
        .action-btn:hover        { border-color: var(--border-hover); color: var(--amber); background: var(--amber-dim); }
        .action-btn.edit:hover   { border-color: rgba(91,138,240,0.4); color: var(--blue); background: var(--blue-dim); }
        .action-btn.pause:hover  { border-color: rgba(232,161,75,0.4); color: var(--amber); background: var(--amber-dim); }
        .action-btn.play:hover   { border-color: rgba(46,204,148,0.4); color: var(--green); background: var(--green-dim); }
        .action-btn.delete:hover { border-color: rgba(224,82,82,0.4);  color: var(--red);   background: var(--red-dim); }
    </style>
}
