@model List<POIViewModel>
@{
    ViewData["Title"] = "Quản lý Cửa hàng & Địa điểm";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .badge-category {
            font-size: 0.85em;
            padding: 0.35em 0.65em;
        }
        .price-range {
            color: #28a745;
            font-weight: 600;
        }
        .poi-image {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
        }
        .action-btns {
            white-space: nowrap;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1"><i class="bi bi-shop"></i> Quản lý POI</span>
            <div>
                <a href="@Url.Action("Dashboard", "Home")" class="btn btn-outline-light me-2">
                    <i class="bi bi-house"></i> Dashboard
                </a>
                <form method="post" action="@Url.Action("Logout", "Auth")" class="d-inline">
                    <button type="submit" class="btn btn-outline-light">
                        <i class="bi bi-box-arrow-right"></i> Đăng xuất
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-geo-alt-fill text-primary"></i> Danh sách Cửa hàng & Địa điểm</h2>
            <a href="@Url.Action("Create")" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Thêm POI mới
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card shadow">
            <div class="card-body">
                @if (Model.Count == 0)
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox" style="font-size: 4rem; color: #ccc;"></i>
                        <p class="text-muted mt-3">Chưa có POI nào. Hãy thêm POI mới!</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>ID</th>
                                    <th>Hình ảnh</th>
                                    <th>Tên</th>
                                    <th>Địa chỉ</th>
                                    <th>Loại</th>
                                    <th>Món ăn</th>
                                    <th>Giá</th>
                                    <th>Đánh giá</th>
                                    <th>Trạng thái</th>
                                    <th class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var poi in Model)
                                {
                                    <tr>
                                        <td><strong>#@poi.Id</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(poi.ImageUrl))
                                            {
                                                <img src="@poi.ImageUrl" alt="@poi.Name" class="poi-image" />
                                            }
                                            else
                                            {
                                                <div class="poi-image bg-secondary d-flex align-items-center justify-content-center">
                                                    <i class="bi bi-image text-white"></i>
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            <strong>@poi.Name</strong><br />
                                            <small class="text-muted">@(poi.Description != null && poi.Description.Length > 0 ? poi.Description.Substring(0, Math.Min(50, poi.Description.Length)) + (poi.Description.Length > 50 ? "..." : "") : "")</small>
                                        </td>
                                        <td>
                                            <i class="bi bi-geo-alt text-danger"></i>
                                            @(poi.Address ?? "N/A")<br />
                                            <small class="text-muted">
                                                Lat: @poi.Latitude.ToString("F5"), Lng: @poi.Longitude.ToString("F5")
                                            </small>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary badge-category">
                                                @poi.CategoryName
                                            </span>
                                        </td>
                                        <td>
                                            @if (poi.Category == 2) // Food category
                                            {
                                                <span class="badge bg-warning text-dark badge-category">
                                                    @poi.FoodTypeName
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (poi.PriceMin > 0 || poi.PriceMax > 0)
                                            {
                                                <span class="price-range">
                                                    @poi.PriceMin.ToString("N0") - @poi.PriceMax.ToString("N0") ₫
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (poi.Rating.HasValue)
                                            {
                                                <span>
                                                    <i class="bi bi-star-fill text-warning"></i>
                                                    @poi.Rating.Value.ToString("F1")
                                                    <small class="text-muted">(@poi.ReviewCount)</small>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Chưa có</span>
                                            }
                                        </td>
                                        <td>
                                            @if (poi.IsActive)
                                            {
                                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Hoạt động</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Vô hiệu</span>
                                            }
                                        </td>
                                        <td class="action-btns text-center">
                                            <a href="@Url.Action("Details", new { id = poi.Id })" class="btn btn-sm btn-info" title="Chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="@Url.Action("Edit", new { id = poi.Id })" class="btn btn-sm btn-warning" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form method="post" action="@Url.Action("ToggleActive", new { id = poi.Id })" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm @(poi.IsActive ? "btn-secondary" : "btn-success")" title="@(poi.IsActive ? "Vô hiệu hóa" : "Kích hoạt")">
                                                    <i class="bi bi-@(poi.IsActive ? "toggle-off" : "toggle-on")"></i>
                                                </button>
                                            </form>
                                            <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal@(poi.Id)" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>

                                            <!-- Delete Confirmation Modal -->
                                            <div class="modal fade" id="deleteModal@(poi.Id)" tabindex="-1">
                                                <div class="modal-dialog">
                                                    <div class="modal-content">
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Xác nhận xóa</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            Bạn có chắc chắn muốn xóa POI <strong>@poi.Name</strong>?
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                                                            <form method="post" action="@Url.Action("Delete", new { id = poi.Id })" class="d-inline">
                                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="btn btn-danger">Xóa</button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <p class="text-muted">
                            <i class="bi bi-info-circle"></i>
                            Tổng số: <strong>@Model.Count</strong> POI
                            | Hoạt động: <strong>@Model.Count(p => p.IsActive)</strong>
                            | Vô hiệu: <strong>@Model.Count(p => !p.IsActive)</strong>
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
