@model List<POIViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý POI";
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="page-title"><i class="bi bi-shop me-2"></i>Quản lý POI</h4>
        <p class="page-subtitle">Danh sách cửa hàng & địa điểm</p>
    </div>
    <a href="@Url.Action("Create")" class="btn btn-primary btn-sm" style="border-radius:8px;">
        <i class="bi bi-plus-circle me-1"></i> Thêm POI mới
    </a>
</div>

<!-- Alerts -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius:10px;">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius:10px;">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- POI Table -->
<div class="card shadow-sm" style="overflow:hidden;">
    <div class="card-header bg-white py-3 px-4 d-flex justify-content-between align-items-center border-bottom">
        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-1"></i> Danh sách</h6>
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted small">
                <i class="bi bi-check-circle text-success"></i> @Model.Count(p => p.IsActive) hoạt động
                &middot;
                <i class="bi bi-x-circle text-secondary"></i> @Model.Count(p => !p.IsActive) tạm dừng
            </span>
            <span class="badge bg-primary rounded-pill">@Model.Count</span>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4" style="width:50px;">ID</th>
                        <th style="min-width:280px;">Cửa hàng</th>
                        <th class="text-center" style="width:100px;">Loại</th>
                        <th class="text-center" style="width:100px;">Món ăn</th>
                        <th class="text-center" style="width:120px;">Giá</th>
                        <th class="text-center" style="width:80px;">Rating</th>
                        <th class="text-center" style="width:90px;">Trạng thái</th>
                        <th class="text-end pe-4" style="width:160px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var poi in Model)
                    {
                        <tr style="transition:background .2s;">
                            <td class="ps-4"><strong class="text-muted">#@poi.Id</strong></td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    @if (!string.IsNullOrEmpty(poi.ImageUrl))
                                    {
                                        <img src="@poi.ImageUrl" alt="" style="width:52px;height:52px;object-fit:cover;border-radius:10px;" class="shadow-sm flex-shrink-0" />
                                    }
                                    else
                                    {
                                        <div class="bg-light d-flex align-items-center justify-content-center shadow-sm flex-shrink-0"
                                             style="width:52px;height:52px;border-radius:10px;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                    <div class="min-w-0">
                                        <div class="fw-semibold text-truncate" style="max-width:200px;">@poi.Name</div>
                                        <small class="text-muted text-truncate d-block" style="max-width:200px;">
                                            <i class="bi bi-geo-alt"></i> @(poi.Address ?? "N/A")
                                        </small>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-primary-subtle text-primary" style="font-size:.72rem;border-radius:6px;">
                                    @poi.CategoryName
                                </span>
                            </td>
                            <td class="text-center">
                                @if (poi.Category == 2)
                                {
                                    <span class="badge bg-warning-subtle text-warning" style="font-size:.72rem;border-radius:6px;">
                                        @poi.FoodTypeName
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (poi.PriceMin > 0 || poi.PriceMax > 0)
                                {
                                    <small class="fw-medium text-success">@poi.PriceMin.ToString("N0")-@poi.PriceMax.ToString("N0")đ</small>
                                }
                                else
                                {
                                    <small class="text-muted">--</small>
                                }
                            </td>
                            <td class="text-center">
                                @if (poi.Rating.HasValue)
                                {
                                    <span><i class="bi bi-star-fill text-warning"></i> <small class="fw-medium">@poi.Rating.Value.ToString("F1")</small></span>
                                }
                                else
                                {
                                    <small class="text-muted">--</small>
                                }
                            </td>
                            <td class="text-center">
                                @if (poi.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success" style="font-size:.68rem;">
                                        <i class="bi bi-circle-fill" style="font-size:.35rem;"></i> Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary" style="font-size:.68rem;">
                                        <i class="bi bi-circle-fill" style="font-size:.35rem;"></i> Tạm dừng
                                    </span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm">
                                    <a href="@Url.Action("Details", new { id = poi.Id })" class="btn btn-outline-secondary" title="Chi tiết">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="@Url.Action("Edit", new { id = poi.Id })" class="btn btn-outline-primary" title="Sửa">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form method="post" action="@Url.Action("ToggleActive", new { id = poi.Id })" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-@(poi.IsActive ? "warning" : "success")" title="@(poi.IsActive ? "Tạm dừng" : "Kích hoạt")">
                                            <i class="bi bi-toggle-@(poi.IsActive ? "off" : "on")"></i>
                                        </button>
                                    </form>
                                    <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal@(poi.Id)" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>

                                <!-- Delete Modal -->
                                <div class="modal fade" id="deleteModal@(poi.Id)" tabindex="-1">
                                    <div class="modal-dialog">
                                        <div class="modal-content" style="border-radius:14px;">
                                            <div class="modal-header border-0 pb-0">
                                                <h6 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle text-danger me-1"></i> Xác nhận xóa</h6>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body">
                                                Bạn có chắc chắn muốn xóa <strong>@poi.Name</strong>?
                                                <br><small class="text-danger">Hành động này không thể hoàn tác!</small>
                                            </div>
                                            <div class="modal-footer border-0 pt-0">
                                                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal" style="border-radius:8px;">Hủy</button>
                                                <form method="post" action="@Url.Action("Delete", new { id = poi.Id })" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-danger btn-sm" style="border-radius:8px;">
                                                        <i class="bi bi-trash me-1"></i> Xóa
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-shop fs-1 text-muted"></i>
            <p class="text-muted mt-3 mb-1">Chưa có POI nào.</p>
            <a href="@Url.Action("Create")" class="btn btn-primary btn-sm mt-2" style="border-radius:8px;">
                <i class="bi bi-plus-circle me-1"></i> Thêm POI mới
            </a>
        </div>
    }
</div>
