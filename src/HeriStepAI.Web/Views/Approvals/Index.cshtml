@model List<HeriStepAI.Web.Models.PendingShopOwnerViewModel>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Duyệt chủ quán";
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Đăng ký chờ duyệt</h1>
        <p class="page-subtitle-text">Chủ quán đăng ký công khai — duyệt để họ có thể đăng nhập và thêm POI</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <span>@TempData["Success"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill"></i>
        <span>@TempData["Error"]</span>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-card">
    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th style="padding-left:24px;">ID</th>
                        <th>Tên đăng nhập</th>
                        <th>Email</th>
                        <th>Họ tên</th>
                        <th>Điện thoại</th>
                        <th>Đăng ký lúc</th>
                        <th class="text-end" style="padding-right:24px;width:200px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td style="padding-left:24px;"><code>#@u.Id</code></td>
                            <td>@u.Username</td>
                            <td>@u.Email</td>
                            <td>@(u.FullName ?? "—")</td>
                            <td>@(u.Phone ?? "—")</td>
                            <td>@u.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end" style="padding-right:24px;">
                                <form asp-action="Approve" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <button type="submit" class="btn btn-sm btn-success me-1"><i class="bi bi-check-lg"></i> Duyệt</button>
                                </form>
                                <form asp-action="Reject" method="post" class="d-inline" onsubmit="return confirm('Từ chối đăng ký này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i> Từ chối</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size:2rem;color:var(--cream-muted);"></i>
            <p class="mt-3 mb-0" style="color:var(--cream-muted);">Không có đăng ký nào đang chờ duyệt.</p>
        </div>
    }
</div>
