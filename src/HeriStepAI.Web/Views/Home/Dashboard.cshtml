@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
    var totalPOIs     = (int)(ViewBag.TotalPOIs ?? 0);
    var totalVisits   = (int)(ViewBag.TotalVisits ?? 0);
    var activePOIs    = (int)(ViewBag.ActivePOIs ?? 0);
    var geofenceVisits = (int)(ViewBag.GeofenceVisits ?? 0);
    var topPOIs  = ViewBag.TopPOIs  as Dictionary<string, int>    ?? new Dictionary<string, int>();
    var poiNames = ViewBag.POINames as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Dashboard</h1>
        <p class="page-subtitle-text">Tổng quan hệ thống HeriStepAI — @DateTime.Now.ToString("dd/MM/yyyy")</p>
    </div>
    <a href="@Url.Action("Create", "POI")" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg"></i>Thêm POI mới
    </a>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card amber">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-geo-alt-fill"></i></div>
                <span class="stat-badge">POI</span>
            </div>
            <div class="stat-number">@totalPOIs</div>
            <div class="stat-label">Tổng số địa điểm</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card green">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
                <span class="stat-badge">↑ +12%</span>
            </div>
            <div class="stat-number">@totalVisits</div>
            <div class="stat-label">Tổng lượt ghé thăm</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card blue">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-broadcast"></i></div>
                <span class="stat-badge">Geofence</span>
            </div>
            <div class="stat-number">@geofenceVisits</div>
            <div class="stat-label">Tự động nhận diện</div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card red">
            <div class="stat-top">
                <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
                <span class="stat-badge">Hoạt động</span>
            </div>
            <div class="stat-number">@activePOIs</div>
            <div class="stat-label">POI đang mở</div>
        </div>
    </div>
</div>

<!-- Quick Actions + Chart -->
<div class="row g-3">
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <span><i class="bi bi-lightning-charge-fill me-2" style="color:var(--amber);"></i>Truy cập nhanh</span>
            </div>
            <div class="card-body d-flex flex-column gap-2" style="padding:16px !important;">
                <a href="@Url.Action("Index", "POI")" class="quick-link">
                    <div class="quick-icon" style="background:var(--amber-dim);">
                        <i class="bi bi-shop" style="color:var(--amber);"></i>
                    </div>
                    <div>
                        <div class="quick-title">Quản lý POI</div>
                        <div class="quick-desc">Thêm, sửa, xoá địa điểm</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto" style="color:var(--cream-muted);font-size:0.8rem;"></i>
                </a>

                <a href="@Url.Action("Index", "Analytics")" class="quick-link">
                    <div class="quick-icon" style="background:var(--green-dim);">
                        <i class="bi bi-bar-chart-fill" style="color:var(--green);"></i>
                    </div>
                    <div>
                        <div class="quick-title">Analytics</div>
                        <div class="quick-desc">Thống kê &amp; phân tích</div>
                    </div>
                    <i class="bi bi-chevron-right ms-auto" style="color:var(--cream-muted);font-size:0.8rem;"></i>
                </a>

                <div class="quick-link" style="opacity:0.4;pointer-events:none;">
                    <div class="quick-icon" style="background:var(--cream-dim);">
                        <i class="bi bi-gear-fill" style="color:var(--cream-muted);"></i>
                    </div>
                    <div>
                        <div class="quick-title">Cài đặt</div>
                        <div class="quick-desc">Sắp ra mắt</div>
                    </div>
                    <span class="ms-auto" style="font-size:0.65rem;background:var(--cream-dim);color:var(--cream-muted);padding:2px 8px;border-radius:99px;font-weight:600;">Soon</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <span><i class="bi bi-bar-chart-line me-2" style="color:var(--amber);"></i>Top địa điểm được ghé thăm</span>
                @if (topPOIs.Any())
                {
                    <span style="font-size:0.75rem;color:var(--cream-muted);font-weight:400;">@topPOIs.Count địa điểm</span>
                }
            </div>
            <div class="card-body">
                @if (topPOIs.Any())
                {
                    <canvas id="topPOIsChart" style="max-height:280px;"></canvas>
                }
                else
                {
                    <div class="text-center py-5">
                        <div style="width:56px;height:56px;border-radius:50%;background:var(--dark4);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                            <i class="bi bi-bar-chart" style="font-size:1.5rem;color:var(--cream-muted);"></i>
                        </div>
                        <p style="color:var(--cream-muted);font-size:0.875rem;margin:0;">Chưa có dữ liệu lượt thăm</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .quick-link {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: 10px;
            text-decoration: none;
            color: var(--cream);
            border: 1px solid var(--border);
            background: var(--dark4);
            transition: all 0.2s;
            cursor: pointer;
        }
        .quick-link:hover {
            background: var(--cream-dim);
            border-color: var(--border-hover);
            color: var(--cream);
        }
        .quick-icon {
            width: 38px; height: 38px;
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }
        .quick-title { font-size: 0.88rem; font-weight: 600; color: var(--cream); }
        .quick-desc  { font-size: 0.75rem; color: var(--cream-muted); margin-top: 2px; }
    </style>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    @if (topPOIs.Any())
    {
        <script>
            const poiNamesMap = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(poiNames));
            const topData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(topPOIs));

            const labels = Object.keys(topData).map(id => {
                const name = poiNamesMap[id] || `POI ${id}`;
                return name.length > 20 ? name.substring(0, 20) + '…' : name;
            });
            const values = Object.values(topData);

            new Chart(document.getElementById('topPOIsChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels,
                    datasets: [{
                        label: 'Lượt thăm',
                        data: values,
                        backgroundColor: 'rgba(79,70,229,0.7)',
                        borderRadius: 4,
                        borderSkipped: false,
                        barThickness: 28
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { precision: 0, color: '#64748b', font: { size: 11 } },
                            grid: { color: 'rgba(0,0,0,0.05)' },
                            border: { color: 'transparent' }
                        },
                        x: {
                            grid: { display: false },
                            ticks: { color: '#64748b', font: { size: 11 }, maxRotation: 30 },
                            border: { color: '#e2e8f0' }
                        }
                    }
                }
            });
        </script>
    }
}
