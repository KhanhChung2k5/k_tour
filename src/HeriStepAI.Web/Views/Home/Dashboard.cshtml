<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - HeriStepAI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <nav class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">HeriStepAI Dashboard</span>
            <form method="post" action="@Url.Action("Logout", "Auth")" class="d-inline">
                <button type="submit" class="btn btn-outline-light">Đăng xuất</button>
            </form>
        </div>
    </nav>
    <div class="container mt-4">
        <h2><i class="bi bi-speedometer2"></i> Dashboard</h2>

        <!-- Quick Menu Cards -->
        <div class="row mt-4">
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-shop" style="font-size: 3rem; color: #0d6efd;"></i>
                        <h5 class="card-title mt-3">Quản lý POI</h5>
                        <p class="card-text text-muted">Thêm, sửa, xóa cửa hàng và địa điểm</p>
                        <a href="@Url.Action("Index", "POI")" class="btn btn-primary">
                            <i class="bi bi-arrow-right-circle"></i> Mở
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-bar-chart-fill" style="font-size: 3rem; color: #198754;"></i>
                        <h5 class="card-title mt-3">Analytics</h5>
                        <p class="card-text text-muted">Thống kê và phân tích dữ liệu</p>
                        <a href="@Url.Action("Index", "Analytics")" class="btn btn-success">
                            <i class="bi bi-arrow-right-circle"></i> Mở
                        </a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-gear-fill" style="font-size: 3rem; color: #6c757d;"></i>
                        <h5 class="card-title mt-3">Cài đặt</h5>
                        <p class="card-text text-muted">Cấu hình hệ thống</p>
                        <button class="btn btn-secondary" disabled>
                            <i class="bi bi-arrow-right-circle"></i> Mở
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <h3 class="mt-5"><i class="bi bi-graph-up"></i> Thống kê Truy cập</h3>
        <div class="row mt-3">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h5>Top Địa điểm được truy cập nhiều nhất</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="topPOIsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script>
        // Chart sẽ được cập nhật khi có dữ liệu từ API
        const ctx = document.getElementById('topPOIsChart').getContext('2d');
        const chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: [],
                datasets: [{
                    label: 'Số lượt truy cập',
                    data: [],
                    backgroundColor: 'rgba(102, 126, 234, 0.8)'
                }]
            },
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
</body>
</html>
