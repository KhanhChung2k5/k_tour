@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dashboard";
    var totalPOIs = (int)(ViewBag.TotalPOIs ?? 0);
    var totalVisits = (int)(ViewBag.TotalVisits ?? 0);
    var activePOIs = (int)(ViewBag.ActivePOIs ?? 0);
    var topPOIs = ViewBag.TopPOIs as Dictionary<string, int> ?? new Dictionary<string, int>();
    var poiNames = ViewBag.POINames as Dictionary<string, string> ?? new Dictionary<string, string>();
}

<!-- Page Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="page-title"><i class="bi bi-grid-1x2 me-2"></i>Dashboard</h4>
        <p class="page-subtitle">Tổng quan hệ thống HeriStepAI</p>
    </div>
    <div class="d-flex gap-2">
        <a href="@Url.Action("Create", "POI")" class="btn btn-primary btn-sm" style="border-radius:8px;">
            <i class="bi bi-plus-circle me-1"></i> Thêm POI
        </a>
        <a href="@Url.Action("Index", "Analytics")" class="btn btn-outline-primary btn-sm" style="border-radius:8px;">
            <i class="bi bi-bar-chart me-1"></i> Analytics
        </a>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon text-white" style="background:linear-gradient(135deg,#667eea,#764ba2);">
                    <i class="bi bi-shop"></i>
                </div>
                <div>
                    <div class="text-muted small">Tổng POI</div>
                    <div class="fs-3 fw-bold lh-1">@totalPOIs</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon text-white" style="background:linear-gradient(135deg,#11998e,#38ef7d);">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <div class="text-muted small">Tổng lượt ghé</div>
                    <div class="fs-3 fw-bold lh-1">@totalVisits</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="stat-icon text-white" style="background:linear-gradient(135deg,#f093fb,#f5576c);">
                    <i class="bi bi-check-circle"></i>
                </div>
                <div>
                    <div class="text-muted small">Đang hoạt động</div>
                    <div class="fs-3 fw-bold lh-1">@activePOIs</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <a href="@Url.Action("Index", "POI")" class="card shadow-sm h-100 text-decoration-none" style="transition:transform .2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='none'">
            <div class="card-body text-center p-4">
                <div class="mb-3">
                    <div class="stat-icon text-white mx-auto" style="background:linear-gradient(135deg,#667eea,#764ba2);width:56px;height:56px;border-radius:14px;">
                        <i class="bi bi-shop fs-4"></i>
                    </div>
                </div>
                <h6 class="fw-bold text-dark">Quản lý POI</h6>
                <small class="text-muted">Thêm, sửa, xóa địa điểm</small>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <a href="@Url.Action("Index", "Analytics")" class="card shadow-sm h-100 text-decoration-none" style="transition:transform .2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='none'">
            <div class="card-body text-center p-4">
                <div class="mb-3">
                    <div class="stat-icon text-white mx-auto" style="background:linear-gradient(135deg,#11998e,#38ef7d);width:56px;height:56px;border-radius:14px;">
                        <i class="bi bi-bar-chart-fill fs-4"></i>
                    </div>
                </div>
                <h6 class="fw-bold text-dark">Analytics</h6>
                <small class="text-muted">Thống kê & phân tích</small>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100" style="opacity:.6;">
            <div class="card-body text-center p-4">
                <div class="mb-3">
                    <div class="stat-icon text-white mx-auto" style="background:linear-gradient(135deg,#a8a8a8,#6c757d);width:56px;height:56px;border-radius:14px;">
                        <i class="bi bi-gear-fill fs-4"></i>
                    </div>
                </div>
                <h6 class="fw-bold text-dark">Cài đặt</h6>
                <small class="text-muted">Sắp ra mắt</small>
            </div>
        </div>
    </div>
</div>

<!-- Chart -->
@if (topPOIs.Any())
{
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="mb-0 fw-bold"><i class="bi bi-graph-up me-1"></i> Top địa điểm được truy cập nhiều nhất</h6>
        </div>
        <div class="card-body">
            <canvas id="topPOIsChart" style="height:320px;"></canvas>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <i class="bi bi-bar-chart fs-1 text-muted"></i>
            <p class="text-muted mt-3 mb-0">Chưa có dữ liệu truy cập</p>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @if (topPOIs.Any())
    {
        <script>
            const poiNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(poiNames));
            const topData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(topPOIs));

            const labels = Object.keys(topData).map(id => poiNames[id] || `POI ${id}`);
            const data = Object.values(topData);

            new Chart(document.getElementById('topPOIsChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Lượt ghé thăm',
                        data: data,
                        backgroundColor: data.map((_, i) => {
                            const colors = ['rgba(102,126,234,0.8)', 'rgba(17,153,142,0.8)', 'rgba(240,147,251,0.8)',
                                'rgba(245,87,108,0.8)', 'rgba(56,239,125,0.8)', 'rgba(118,75,162,0.8)',
                                'rgba(13,202,240,0.8)', 'rgba(255,193,7,0.8)', 'rgba(25,135,84,0.8)', 'rgba(108,117,125,0.8)'];
                            return colors[i % colors.length];
                        }),
                        borderRadius: 8,
                        borderSkipped: false,
                        barThickness: 36
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: '#f0f0f0' } },
                        x: { grid: { display: false }, ticks: { maxRotation: 45 } }
                    }
                }
            });
        </script>
    }
}
