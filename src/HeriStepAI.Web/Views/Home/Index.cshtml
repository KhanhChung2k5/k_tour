@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="refresh" content="0;url=/Auth/Login" />
    <title>HeriStepAI – Đang chuyển hướng</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Be+Vietnam+Pro:wght@400;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --amber: #E8A14B;
            --dark: #0A0906;
            --cream: #F8F3E8;
            --cream-muted: #A89B82;
        }
        body {
            min-height: 100vh;
            background: var(--dark);
            font-family: 'Be Vietnam Pro', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--cream);
        }
        .msg {
            text-align: center;
            font-size: 0.95rem;
            color: var(--cream-muted);
        }
        .msg a { color: var(--amber); text-decoration: none; }
        .msg a:hover { text-decoration: underline; }
    </style>
</head>
<body>
    <div class="msg">
        Đang chuyển tới trang đăng nhập…<br />
        <a href="/Auth/Login">Bấm vào đây nếu không tự chuyển.</a>
    </div>
    <script>window.location.replace("/Auth/Login");</script>
</body>
</html>
