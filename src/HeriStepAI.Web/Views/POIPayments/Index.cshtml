@model List<HeriStepAI.Web.Models.POIPaymentRow>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thanh toán kích hoạt POI";
    var summary = ViewBag.Summary as HeriStepAI.Web.Models.POIPaymentSummary;
    var filter = ViewBag.FilterStatus as string ?? "";
}

<div class="page-header">
    <div>
        <h1 class="page-title-text">Thanh toán kích hoạt POI</h1>
        <p class="page-subtitle-text">ShopOwner tạo POI → chuyển khoản → Admin đối soát → Xác nhận kích hoạt.</p>
    </div>
    <a href="@Url.Action("Dashboard", "Home")" class="btn btn-outline-light btn-sm">← Dashboard</a>
</div>

@if (summary != null)
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card amber">
                <div class="stat-label">Chờ đối soát</div>
                <div class="stat-number">@summary.Pending</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card green">
                <div class="stat-label">Đã xác nhận</div>
                <div class="stat-number">@summary.Verified</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card red">
                <div class="stat-label">Từ chối</div>
                <div class="stat-number">@summary.Rejected</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card blue">
                <div class="stat-label">Tổng doanh thu</div>
                <div class="stat-number" style="font-size:1rem;">@summary.TotalAmountVndVerified.ToString("N0")đ</div>
            </div>
        </div>
    </div>
}

<div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
    <span class="text-muted small">Lọc:</span>
    <a href="@Url.Action("Index", new { status = (string?)null })" class="btn btn-sm @(string.IsNullOrEmpty(filter) ? "btn-primary" : "btn-outline-secondary")">Tất cả</a>
    <a href="@Url.Action("Index", new { status = "Pending" })" class="btn btn-sm @(filter == "Pending" ? "btn-warning" : "btn-outline-secondary")">Chờ</a>
    <a href="@Url.Action("Index", new { status = "Verified" })" class="btn btn-sm @(filter == "Verified" ? "btn-success" : "btn-outline-secondary")">Đã duyệt</a>
    <a href="@Url.Action("Index", new { status = "Rejected" })" class="btn btn-sm @(filter == "Rejected" ? "btn-danger" : "btn-outline-secondary")">Từ chối</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="table-card">
    <div class="table-responsive">
        <table class="table" style="table-layout:fixed;width:100%;">
            <colgroup>
                <col style="width:18%;">
                <col style="width:14%;">
                <col style="width:9%;">
                <col style="width:12%;">
                <col style="width:17%;">
                <col style="width:11%;">
                <col style="width:11%;">
                <col style="width:8%;">
            </colgroup>
            <thead>
                <tr>
                    <th style="padding-left:20px;">POI</th>
                    <th>Chủ cửa hàng</th>
                    <th>Ưu tiên</th>
                    <th>Số tiền</th>
                    <th>Mã CK</th>
                    <th>Trạng thái</th>
                    <th>Báo lúc</th>
                    <th style="padding-right:20px;text-align:right;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model)
                {
                    <tr>
                        <td style="padding-left:20px;">
                            <div style="font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@row.POIName">@row.POIName</div>
                            <div style="font-size:0.72rem;color:var(--cream-muted);margin-top:2px;">ID: @row.POIId</div>
                        </td>
                        <td>
                            <div style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@row.OwnerName">@row.OwnerName</div>
                        </td>
                        <td>
                            @{
                                var badgeColor = row.Priority == 3 ? "var(--red)" : row.Priority == 2 ? "var(--amber)" : "var(--green)";
                            }
                            <span class="badge" style="background:@(badgeColor)22;color:@badgeColor;white-space:nowrap;">@row.PriorityLabel</span>
                        </td>
                        <td style="font-weight:600;color:var(--amber);white-space:nowrap;">
                            @row.AmountVnd.ToString("N0")đ
                        </td>
                        <td>
                            <code style="font-size:0.75rem;background:var(--dark4);padding:3px 7px;border-radius:5px;color:var(--amber);display:block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@row.TransferRef">@row.TransferRef</code>
                        </td>
                        <td>
                            @if (row.Status == "Verified")
                            {
                                <span class="badge-soft-success">Đã xác nhận</span>
                            }
                            else if (row.Status == "Rejected")
                            {
                                <span class="badge-soft-danger">Từ chối</span>
                            }
                            else
                            {
                                <span class="badge-soft-warning">Chờ đối soát</span>
                            }
                        </td>
                        <td style="font-size:0.78rem;color:var(--cream-muted);white-space:nowrap;">
                            @row.ReportedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                            @if (row.VerifiedAtUtc.HasValue)
                            {
                                <div style="margin-top:2px;font-size:0.7rem;opacity:0.7;">✓ @row.VerifiedAtUtc.Value.ToLocalTime().ToString("dd/MM HH:mm")</div>
                            }
                        </td>
                        <td style="padding-right:20px;text-align:right;vertical-align:middle;">
                            @if (row.Status == "Pending")
                            {
                                <div class="d-flex gap-1 justify-content-end flex-wrap">
                                    <form asp-action="Verify" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@row.Id" />
                                        <button type="submit" class="btn btn-success btn-sm"
                                                onclick="return confirm('Xác nhận đã nhận tiền và kích hoạt POI @Html.Raw(row.POIName.Replace("'","\\'")??"") ?')">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <form asp-action="Reject" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@row.Id" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('Từ chối thanh toán POI này?')">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                </div>
                            }
                            else
                            {
                                <span style="font-size:0.7rem;color:var(--cream-muted);">—</span>
                            }
                            @if (!string.IsNullOrEmpty(row.AdminNote))
                            {
                                <div style="font-size:0.7rem;color:var(--cream-muted);margin-top:4px;text-align:right;">@row.AdminNote</div>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5" style="color:var(--cream-muted);">
                            <i class="bi bi-inbox" style="font-size:2rem;display:block;margin-bottom:8px;opacity:0.4;"></i>
                            Chưa có bản ghi nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
