<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HeriStepAI Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
    :root {
        --sidebar-w:    260px;
        --topbar-h:     62px;
        --amber:        #E8A14B;
        --amber-light:  #F2C47E;
        --amber-dim:    rgba(232,161,75,0.15);
        --dark:         #0D0B08;
        --dark2:        #141108;
        --dark3:        #1E1810;
        --dark4:        #261F14;
        --sidebar-bg:   #110F0A;
        --cream:        #F5ECD7;
        --cream-muted:  #9E8E75;
        --cream-dim:    rgba(245,236,215,0.06);
        --green:        #2ECC94;
        --green-dim:    rgba(46,204,148,0.12);
        --red:          #E05252;
        --red-dim:      rgba(224,82,82,0.12);
        --blue:         #5B8AF0;
        --blue-dim:     rgba(91,138,240,0.12);
        --border:       rgba(232,161,75,0.12);
        --border-hover: rgba(232,161,75,0.3);
        --radius:       14px;
    }

    * { font-family: 'Be Vietnam Pro', sans-serif; box-sizing: border-box; }

    body {
        background: var(--dark2);
        margin: 0;
        color: var(--cream);
        overflow-x: hidden;
    }

    /* ===== SIDEBAR ===== */
    .admin-sidebar {
        position: fixed;
        top: 0; left: 0;
        width: var(--sidebar-w);
        height: 100vh;
        background: var(--sidebar-bg);
        border-right: 1px solid var(--border);
        z-index: 1050;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        transition: transform 0.25s ease;
    }

    .admin-sidebar::after {
        content: '';
        position: absolute;
        top: 0; right: -1px; bottom: 0;
        width: 1px;
        background: linear-gradient(to bottom, transparent, var(--amber), transparent);
        opacity: 0.2;
    }

    .sidebar-brand {
        height: var(--topbar-h);
        padding: 0 24px;
        display: flex;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
    }

    .brand-icon {
        width: 38px; height: 38px;
        border-radius: 10px;
        background: linear-gradient(135deg, var(--amber), #C07820);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(232,161,75,0.3);
    }

    .sidebar-brand h5 {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--cream);
        margin: 0;
        letter-spacing: -0.01em;
    }

    .sidebar-brand h5 span { color: var(--amber); }

    .sidebar-nav {
        flex: 1;
        padding: 8px 0;
        overflow-y: auto;
    }

    .nav-section-label {
        font-size: 0.65rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--cream-muted);
        padding: 20px 24px 8px;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 11px 20px;
        margin: 2px 12px;
        border-radius: 10px;
        color: var(--cream-muted);
        text-decoration: none;
        font-size: 0.88rem;
        font-weight: 400;
        transition: all 0.2s;
        position: relative;
    }

    .sidebar-item:hover {
        background: var(--cream-dim);
        color: var(--cream);
    }

    .sidebar-item.active {
        background: var(--amber-dim);
        color: var(--amber);
        font-weight: 600;
    }

    .sidebar-item.active::before {
        content: '';
        position: absolute;
        left: -12px; top: 50%;
        transform: translateY(-50%);
        width: 3px; height: 20px;
        background: var(--amber);
        border-radius: 0 3px 3px 0;
    }

    .sidebar-item i {
        font-size: 1rem;
        width: 20px;
        text-align: center;
        flex-shrink: 0;
    }

    .sidebar-item.disabled {
        opacity: 0.4;
        pointer-events: none;
    }

    .sidebar-footer {
        border-top: 1px solid var(--border);
        padding: 16px 12px;
        flex-shrink: 0;
    }

    .sidebar-user-card {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 10px;
        cursor: pointer;
        transition: background 0.2s;
    }

    .sidebar-user-card:hover { background: var(--cream-dim); }

    .user-avatar-sm {
        width: 34px; height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--amber), #C07820);
        display: flex; align-items: center; justify-content: center;
        color: var(--dark);
        font-size: 0.85rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .user-info-sm .u-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--cream);
        line-height: 1.3;
    }

    .user-info-sm .u-role {
        font-size: 0.72rem;
        color: var(--cream-muted);
        line-height: 1.3;
    }

    /* ===== MAIN AREA ===== */
    .admin-main {
        margin-left: var(--sidebar-w);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: var(--dark2);
        transition: margin-left 0.25s ease;
    }

    /* ===== TOPBAR ===== */
    .admin-topbar {
        height: var(--topbar-h);
        background: var(--dark2);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 36px;
        position: sticky;
        top: 0;
        z-index: 100;
        flex-shrink: 0;
    }

    .topbar-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .topbar-page-title {
        font-size: 0.82rem;
        font-weight: 400;
        color: var(--cream-muted);
    }

    .sidebar-toggle-btn {
        background: none;
        border: none;
        font-size: 1.25rem;
        color: var(--cream-muted);
        cursor: pointer;
        padding: 6px;
        border-radius: 8px;
        display: none;
        line-height: 1;
    }

    .sidebar-toggle-btn:hover { background: var(--cream-dim); color: var(--cream); }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .topbar-user-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .topbar-user-info .u-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--cream);
        line-height: 1.2;
    }

    .topbar-user-info .u-role {
        font-size: 0.72rem;
        color: var(--cream-muted);
        line-height: 1.2;
    }

    .btn-logout {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--cream-muted);
        font-family: 'Be Vietnam Pro', sans-serif;
        font-size: 0.8rem;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

    .btn-logout:hover {
        border-color: var(--border-hover);
        color: var(--amber);
    }

    /* ===== CONTENT ===== */
    .admin-content {
        flex: 1;
        padding: 36px;
    }

    /* ===== FOOTER ===== */
    .admin-footer {
        padding: 14px 36px;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.72rem;
        color: var(--cream-muted);
    }

    /* ===== CARDS ===== */
    .card {
        border-radius: var(--radius) !important;
        border: 1px solid var(--border) !important;
        background: var(--dark3) !important;
        box-shadow: none !important;
    }

    .card-header {
        background: transparent !important;
        border-bottom: 1px solid var(--border) !important;
        padding: 20px 24px !important;
        font-weight: 600;
        font-size: 0.92rem;
        color: var(--cream);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .card-body { padding: 20px 24px !important; }

    /* ===== STAT CARDS ===== */
    .stat-card {
        background: var(--dark3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 24px;
        position: relative;
        overflow: hidden;
        transition: border-color 0.2s, transform 0.2s;
        cursor: default;
    }

    .stat-card:hover {
        border-color: var(--border-hover);
        transform: translateY(-2px);
    }

    .stat-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        border-radius: var(--radius) var(--radius) 0 0;
    }

    .stat-card.amber::before { background: linear-gradient(90deg, var(--amber), transparent); }
    .stat-card.green::before  { background: linear-gradient(90deg, var(--green), transparent); }
    .stat-card.blue::before   { background: linear-gradient(90deg, var(--blue), transparent); }
    .stat-card.red::before    { background: linear-gradient(90deg, var(--red), transparent); }

    .stat-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .stat-icon {
        width: 40px; height: 40px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
    }

    .stat-card.amber .stat-icon { background: rgba(232,161,75,0.15); color: var(--amber); }
    .stat-card.green .stat-icon { background: rgba(46,204,148,0.12); color: var(--green); }
    .stat-card.blue  .stat-icon { background: rgba(91,138,240,0.12); color: var(--blue); }
    .stat-card.red   .stat-icon { background: rgba(224,82,82,0.12);  color: var(--red); }

    .stat-badge {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 99px;
    }

    .stat-card.amber .stat-badge { background: rgba(232,161,75,0.15); color: var(--amber); }
    .stat-card.green .stat-badge { background: rgba(46,204,148,0.12); color: var(--green); }
    .stat-card.blue  .stat-badge { background: rgba(91,138,240,0.12); color: var(--blue); }
    .stat-card.red   .stat-badge { background: rgba(224,82,82,0.12);  color: var(--red); }

    .stat-number, .stat-value {
        font-family: 'Playfair Display', serif;
        font-size: 2.4rem;
        font-weight: 700;
        color: var(--cream);
        line-height: 1;
        margin-bottom: 6px;
    }

    .stat-label {
        font-size: 0.78rem;
        color: var(--cream-muted);
        font-weight: 400;
    }

    /* ===== PAGE HEADER ===== */
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 32px;
        flex-wrap: wrap;
        gap: 12px;
    }

    .page-title-text {
        font-family: 'Playfair Display', serif;
        font-size: 1.9rem;
        font-weight: 700;
        color: var(--cream);
        margin: 0;
        line-height: 1.2;
    }

    .page-subtitle-text {
        font-size: 0.82rem;
        color: var(--cream-muted);
        margin: 4px 0 0;
        font-weight: 300;
    }

    /* ===== BUTTONS ===== */
    .btn {
        font-family: 'Be Vietnam Pro', sans-serif !important;
        font-weight: 600;
        border-radius: 10px;
        font-size: 0.86rem;
    }

    .btn-primary {
        display: inline-flex !important;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, var(--amber), #C07820) !important;
        border: none !important;
        color: var(--dark) !important;
        box-shadow: 0 4px 16px rgba(232,161,75,0.25) !important;
        transition: all 0.2s !important;
    }

    .btn-primary:hover {
        transform: translateY(-2px) !important;
        box-shadow: 0 8px 24px rgba(232,161,75,0.35) !important;
        filter: brightness(1.05);
        color: var(--dark) !important;
    }

    .btn-secondary-dark {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 11px 20px;
        background: transparent;
        border: 1px solid var(--border-hover);
        border-radius: 10px;
        color: var(--amber);
        font-size: 0.86rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

    .btn-secondary-dark:hover { background: var(--amber-dim); color: var(--amber); }

    .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        background: var(--dark4) !important;
        border: 1px solid var(--border) !important;
        color: var(--cream-muted) !important;
        border-radius: 10px;
        font-size: 0.86rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
    }

    .btn-ghost:hover {
        border-color: var(--border-hover) !important;
        color: var(--cream) !important;
    }

    .btn-outline-primary {
        color: var(--amber) !important;
        border: 1px solid var(--border-hover) !important;
        background: transparent !important;
    }

    .btn-outline-primary:hover {
        background: var(--amber-dim) !important;
        color: var(--amber) !important;
    }

    .btn-sm { padding: 8px 16px; font-size: 0.82rem; }

    /* ===== INPUTS ===== */
    .form-control, .form-select {
        border-radius: 10px;
        border: 1px solid var(--border);
        font-size: 0.88rem;
        color: var(--cream);
        background: var(--dark4);
        font-family: 'Be Vietnam Pro', sans-serif;
    }

    .form-control:focus, .form-select:focus {
        border-color: var(--amber);
        box-shadow: 0 0 0 3px rgba(232,161,75,0.1);
        background: var(--dark4);
        color: var(--cream);
    }

    .form-control::placeholder { color: rgba(158,142,117,0.5); }
    textarea.form-control { resize: vertical; line-height: 1.6; }

    .form-select option {
        background: var(--dark4);
        color: var(--cream);
    }

    .form-label {
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--cream-muted);
        margin-bottom: 8px;
    }

    .form-text {
        font-size: 0.75rem;
        color: var(--cream-muted);
    }

    /* ===== BADGES ===== */
    .badge { font-weight: 600; border-radius: 99px; padding: 3px 10px; font-size: 0.7rem; }

    .badge-soft-success  { background: rgba(46,204,148,0.12);  color: var(--green); border-radius: 99px; padding: 3px 10px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
    .badge-soft-danger   { background: rgba(224,82,82,0.12);   color: var(--red);   border-radius: 99px; padding: 3px 10px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
    .badge-soft-warning  { background: rgba(232,161,75,0.15);  color: var(--amber); border-radius: 99px; padding: 3px 10px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
    .badge-soft-info     { background: rgba(91,138,240,0.12);  color: var(--blue);  border-radius: 99px; padding: 3px 10px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
    .badge-soft-primary  { background: rgba(232,161,75,0.15);  color: var(--amber); border-radius: 99px; padding: 3px 10px; font-size: 0.7rem; font-weight: 600; display: inline-block; }
    .badge-soft-secondary{ background: var(--cream-dim); color: var(--cream-muted); border-radius: 99px; padding: 3px 10px; font-size: 0.7rem; font-weight: 600; display: inline-block; }

    /* ===== TABLES ===== */
    .table-card {
        background: var(--dark3);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
    }

    /* Override Bootstrap 5.3 table CSS vars so cells don't turn white */
    .table {
        margin: 0;
        --bs-table-bg: transparent;
        --bs-table-color: var(--cream);
        --bs-table-border-color: transparent;
        --bs-table-striped-bg: transparent;
        --bs-table-hover-bg: var(--cream-dim);
        --bs-table-accent-bg: transparent;
        color: var(--cream);
    }

    .table thead tr th {
        background: var(--dark3) !important;
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--cream-muted);
        border-bottom: 1px solid var(--border);
        padding: 14px 20px;
        white-space: nowrap;
    }

    .table tbody tr {
        border-bottom: 1px solid rgba(232,161,75,0.06);
        transition: background 0.15s;
        cursor: pointer;
        background: transparent;
    }

    .table tbody tr:last-child { border-bottom: none; }
    .table tbody tr:hover { background: var(--cream-dim) !important; }

    .table tbody td {
        padding: 16px 20px;
        vertical-align: middle;
        border-color: transparent !important;
        font-size: 0.84rem;
        color: var(--cream);
        background-color: transparent !important;
    }

    /* ===== ALERTS ===== */
    .alert {
        border-radius: 10px;
        border: 1px solid;
        font-size: 0.85rem;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .alert-success { background: rgba(46,204,148,0.08) !important; color: var(--green) !important; border-color: rgba(46,204,148,0.2) !important; }
    .alert-danger  { background: rgba(224,82,82,0.08) !important;  color: var(--red) !important;   border-color: rgba(224,82,82,0.2) !important; }
    .alert-warning { background: rgba(232,161,75,0.08) !important; color: var(--amber) !important; border-color: rgba(232,161,75,0.2) !important; }
    .alert-info    { background: rgba(91,138,240,0.08) !important; color: var(--blue) !important;  border-color: rgba(91,138,240,0.2) !important; }
    .btn-close { filter: invert(1) opacity(0.5); }

    /* ===== TABS ===== */
    .nav-tabs-pill {
        display: flex;
        gap: 4px;
        flex-wrap: wrap;
        margin-bottom: 16px;
        border: none;
    }

    .nav-tabs-pill .nav-link {
        padding: 6px 14px;
        border-radius: 7px;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--cream-muted);
        font-size: 0.78rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
        font-family: 'Be Vietnam Pro', sans-serif;
    }

    .nav-tabs-pill .nav-link.active {
        background: var(--amber-dim);
        border-color: var(--border-hover);
        color: var(--amber);
        font-weight: 600;
    }

    .nav-tabs-pill .nav-link:hover:not(.active) {
        border-color: var(--border-hover);
        color: var(--cream);
        background: none;
    }

    .tab-content { color: var(--cream); }
    .tab-content audio { border-radius: 8px; background: var(--dark4); }

    /* ===== MODAL ===== */
    .modal-content {
        background: var(--dark3) !important;
        border: 1px solid var(--border) !important;
        border-radius: var(--radius) !important;
        color: var(--cream) !important;
    }

    .modal-backdrop { background: rgba(0,0,0,0.7); }

    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(232,161,75,0.2); border-radius: 99px; }
    ::-webkit-scrollbar-thumb:hover { background: rgba(232,161,75,0.4); }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 992px) {
        .admin-sidebar {
            transform: translateX(-100%);
        }
        .admin-sidebar.show {
            transform: translateX(0);
            box-shadow: 4px 0 24px rgba(0,0,0,0.5);
        }
        .admin-main { margin-left: 0; }
        .sidebar-toggle-btn { display: block; }
        .admin-content { padding: 20px; }
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            z-index: 1040;
        }
        .sidebar-overlay.show { display: block; }
    }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Mobile overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- Sidebar -->
    <aside class="admin-sidebar" id="adminSidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">🎙</div>
            <h5>Heri<span>Step</span>AI</h5>
        </div>

        <nav class="sidebar-nav">
            @{
                var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                var act  = ViewContext.RouteData.Values["action"]?.ToString();
            }

            <div class="nav-section-label">Menu</div>

            <a href="@Url.Action("Dashboard", "Home")"
               class="sidebar-item @(ctrl == "Home" && act == "Dashboard" ? "active" : "")">
                <i class="bi bi-squares-fill"></i>
                <span>Dashboard</span>
            </a>

            <a href="@Url.Action("Index", "POI")"
               class="sidebar-item @(ctrl == "POI" ? "active" : "")">
                <i class="bi bi-shop"></i>
                <span>Quản lý POI</span>
            </a>

            <a href="@Url.Action("Index", "Analytics")"
               class="sidebar-item @(ctrl == "Analytics" ? "active" : "")">
                <i class="bi bi-bar-chart-line"></i>
                <span>Analytics</span>
            </a>

            <div class="nav-section-label">Hệ thống</div>

            <span class="sidebar-item disabled">
                <i class="bi bi-gear"></i>
                <span>Cài đặt</span>
                <span style="margin-left:auto;font-size:0.65rem;color:var(--cream-muted);background:var(--cream-dim);padding:2px 7px;border-radius:99px;">Soon</span>
            </span>

            <span class="sidebar-item disabled">
                <i class="bi bi-people"></i>
                <span>Người dùng</span>
                <span style="margin-left:auto;font-size:0.65rem;color:var(--cream-muted);background:var(--cream-dim);padding:2px 7px;border-radius:99px;">Soon</span>
            </span>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user-card">
                <div class="user-avatar-sm">A</div>
                <div class="user-info-sm">
                    <div class="u-name">@(User.Identity?.Name ?? "Admin")</div>
                    <div class="u-role">Administrator</div>
                </div>
                <span style="margin-left:auto;color:var(--cream-muted);font-size:0.75rem;">→</span>
            </div>
        </div>
    </aside>

    <!-- Main area -->
    <div class="admin-main">
        <header class="admin-topbar">
            <div class="topbar-left">
                <button class="sidebar-toggle-btn" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
                <span class="topbar-page-title">@ViewData["Title"]</span>
            </div>

            <div class="topbar-right">
                <div class="topbar-user-info d-none d-md-flex">
                    <div class="user-avatar-sm" style="width:30px;height:30px;font-size:0.75rem;">A</div>
                    <div>
                        <div class="u-name">@(User.Identity?.Name ?? "Admin")</div>
                        <div class="u-role">Administrator</div>
                    </div>
                </div>
                <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                    <button type="submit" class="btn-logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span class="d-none d-sm-inline">Đăng xuất</span>
                    </button>
                </form>
            </div>
        </header>

        <main class="admin-content">
            @RenderBody()
        </main>

        <footer class="admin-footer">
            <span>&copy; 2026 HeriStepAI &mdash; Hệ thống Thuyết minh Du lịch Tự động</span>
            <span>v1.0.0</span>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('adminSidebar').classList.toggle('show');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }
        document.querySelectorAll('.sidebar-item').forEach(el => {
            el.addEventListener('click', () => {
                if (window.innerWidth <= 992) toggleSidebar();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
