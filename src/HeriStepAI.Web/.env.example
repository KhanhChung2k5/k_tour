# HeriStepAI Web Environment Variables

# ===== DATABASE =====
# Local PostgreSQL (Development)
SUPABASE_CONNECTION_STRING=Host=localhost;Port=5432;Database=heristepai_db;Username=postgres;Password=admin123;SSL Mode=Prefer

# Neon.tech (Shared Staging - FREE)
# SUPABASE_CONNECTION_STRING=Host=ep-xxx.region.aws.neon.tech;Port=5432;Database=heristepai;Username=neondb_owner;Password=xxx;SSL Mode=Require

# ===== JWT =====
JWT_SECRET_KEY=YourSuperSecretKeyForJWTTokenGeneration12345
JWT_ISSUER=HeriStepAI
JWT_AUDIENCE=HeriStepAIUsers

# ===== API URL =====
# Local Development
API_BASE_URL=http://localhost:5000/api/

# Production (Render)
# API_BASE_URL=https://heristep-1.onrender.com/api/

# ===== SUPABASE STORAGE (OPTIONAL - for image upload) =====
# If not configured, image upload will be disabled
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_BUCKET=c-media
