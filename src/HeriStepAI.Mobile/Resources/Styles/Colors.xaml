<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brown/Cream editorial palette — matches HeriStepAI UI Kit -->
    <Color x:Key="Primary">#2C2416</Color>
    <Color x:Key="PrimaryDark">#1A1410</Color>
    <Color x:Key="PrimaryLight">#6B5A3E</Color>

    <Color x:Key="Secondary">#2C7A3F</Color>
    <Color x:Key="SecondaryDark">#1E5C2E</Color>
    <Color x:Key="SecondaryLight">#4DA162</Color>

    <Color x:Key="Accent">#C4A24A</Color>
    <Color x:Key="AccentLight">#D4B86A</Color>
    <Color x:Key="CreamDark">#C4B99A</Color>
    <Color x:Key="CreamMid">#D4C9B0</Color>

    <Color x:Key="PageBackground">#F5F0E8</Color>
    <Color x:Key="CardBackground">#FAFAF8</Color>
    <Color x:Key="SurfaceColor">#FAFAF8</Color>
    <Color x:Key="WarmCream">#F0ECE4</Color>
    <Color x:Key="WarmBorder">#E2DDD5</Color>

    <Color x:Key="TextPrimary">#1A1712</Color>
    <Color x:Key="TextSecondary">#5A4E38</Color>
    <Color x:Key="TextMuted">#7A7268</Color>
    <Color x:Key="TextFaint">#A8A09A</Color>
    <Color x:Key="TextLight">#FFFFFF</Color>

    <Color x:Key="Success">#2C7A3F</Color>
    <Color x:Key="Warning">#C4A24A</Color>
    <Color x:Key="Error">#B94040</Color>
    <Color x:Key="Info">#3A6EA8</Color>

    <Color x:Key="StarColor">#C4A24A</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>
    <Color x:Key="Transparent">Transparent</Color>

    <Color x:Key="Gray50">#FAFAF8</Color>
    <Color x:Key="Gray100">#F5F0E8</Color>
    <Color x:Key="Gray200">#E2DDD5</Color>
    <Color x:Key="Gray300">#D4C9B0</Color>
    <Color x:Key="Gray400">#C4B99A</Color>
    <Color x:Key="Gray500">#A8A09A</Color>
    <Color x:Key="Gray600">#7A7268</Color>
    <Color x:Key="Gray700">#5A4E38</Color>
    <Color x:Key="Gray800">#6B5A3E</Color>
    <Color x:Key="Gray900">#2C2416</Color>

    <!-- Legacy aliases kept for compatibility -->
    <Color x:Key="GradientStart">#2C2416</Color>
    <Color x:Key="GradientEnd">#1A1410</Color>
    <Color x:Key="CardGradientStart">#FAFAF8</Color>
    <Color x:Key="CardGradientEnd">#F0ECE4</Color>

    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1410" Offset="0.0" />
        <GradientStop Color="#2C2416" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1410" Offset="0.0" />
        <GradientStop Color="#2C2416" Offset="0.65" />
        <GradientStop Color="#3A3020" Offset="1.0" />
    </LinearGradientBrush>

    <!-- Overlay for photo headers -->
    <LinearGradientBrush x:Key="ImageOverlayGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#33000000" Offset="0.0" />
        <GradientStop Color="#DD1A1712" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FAFAF8" Offset="0.0" />
        <GradientStop Color="#F0ECE4" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GoldGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#C4A24A" Offset="0.0" />
        <GradientStop Color="#A8882E" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>
