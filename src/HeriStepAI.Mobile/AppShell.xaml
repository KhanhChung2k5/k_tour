<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HeriStepAI.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:HeriStepAI.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="{StaticResource White}"
    Shell.TabBarTitleColor="{StaticResource Primary}"
    Shell.TabBarUnselectedColor="{StaticResource Gray500}">

    <TabBar>
        <ShellContent x:Name="MainTab" Title="Trang chủ" Icon="home" Route="MainPage" />
        <ShellContent x:Name="MapTab" Title="Bản đồ" Icon="map" Route="MapPage" />
        <ShellContent x:Name="POIListTab" Title="Địa điểm" Icon="location" Route="POIListPage" />
        <ShellContent x:Name="SettingsTab" Title="Cài đặt" Icon="settings" Route="SettingsPage" />
    </TabBar>

</Shell>
