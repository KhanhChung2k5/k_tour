<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext (HTTP) traffic for development and map tiles -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Allow all HTTPS domains (for OpenStreetMap tiles, Supabase, etc.) -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">tile.openstreetmap.org</domain>
        <domain includeSubdomains="true">unpkg.com</domain>
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">heristepai.app</domain>
        <domain includeSubdomains="true">cartocdn.com</domain>
    </domain-config>
</network-security-config>
