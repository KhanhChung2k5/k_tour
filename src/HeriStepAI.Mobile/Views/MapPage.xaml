<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.MapPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:MapPageViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top Bar with Search -->
        <Grid Grid.Row="0"
              BackgroundColor="{StaticResource White}"
              x:Name="TopBar"
              Padding="16,48,16,12"
              ZIndex="10">
            <Grid.Shadow>
                <Shadow Brush="{StaticResource Black}" Offset="0,2" Radius="6" Opacity="0.04" />
            </Grid.Shadow>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                <!-- Back Button -->
                <Frame Grid.Column="0"
                       BackgroundColor="{StaticResource WarmCream}"
                       CornerRadius="16"
                       WidthRequest="40"
                       HeightRequest="40"
                       Padding="0"
                       HasShadow="False"
                       BorderColor="{StaticResource WarmBorder}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="&#x2190;"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>

                <!-- Search Entry -->
                <Frame Grid.Column="1"
                       BackgroundColor="{StaticResource WarmCream}"
                       CornerRadius="20"
                       Padding="12,0"
                       HasShadow="False"
                       BorderColor="{StaticResource WarmBorder}"
                       HeightRequest="40">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="&#x1F50D;"
                               FontSize="13"
                               TextColor="{StaticResource TextMuted}"
                               VerticalOptions="Center"
                               Margin="0,0,6,0" />
                        <Entry Grid.Column="1"
                               Placeholder="{Binding LblSearch}"
                               Text="{Binding SearchText}"
                               BackgroundColor="Transparent"
                               FontSize="13"
                               TextColor="{StaticResource TextPrimary}"
                               PlaceholderColor="{StaticResource TextMuted}"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- List View Button -->
                <Frame Grid.Column="2"
                       BackgroundColor="{StaticResource Primary}"
                       CornerRadius="16"
                       WidthRequest="40"
                       HeightRequest="40"
                       Padding="0"
                       HasShadow="False"
                       BorderColor="Transparent">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowListCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="&#x2261;"
                           TextColor="{StaticResource White}"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
            </Grid>
        </Grid>

        <!-- Map View - spans into Row 2 so map is visible behind collapsed bottom sheet -->
        <WebView Grid.Row="1"
                 Grid.RowSpan="2"
                 x:Name="MapWebView"
                 Margin="0"
                 MinimumHeightRequest="300"
                 ZIndex="1" />

        <!-- Test Mode Status Banner (shown when test mode is active) -->
        <Frame Grid.Row="1"
               BackgroundColor="#E8F5E9"
               CornerRadius="12"
               Padding="12,8"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="16,8,16,0"
               IsVisible="{Binding ShowTestModeStatus}"
               ZIndex="8">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="&#x1F9EA;"
                       FontSize="14"
                       VerticalOptions="Center" />
                <Label Text="{Binding TestModeStatus}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#2E7D32"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Frame>

        <!-- Floating My Location Button -->
        <Frame Grid.Row="1"
               BackgroundColor="{StaticResource White}"
               CornerRadius="22"
               WidthRequest="44"
               HeightRequest="44"
               Padding="0"
               HasShadow="True"
               HorizontalOptions="End"
               VerticalOptions="End"
               Margin="0,0,16,76"
               ZIndex="5">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CenterOnLocationCommand}" />
            </Frame.GestureRecognizers>
            <Label Text="&#x1F4CD;"
                   FontSize="20"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Frame>

        <!-- Floating Test Mode Button -->
        <Frame Grid.Row="1"
               BackgroundColor="{StaticResource Primary}"
               CornerRadius="18"
               Padding="12,8"
               HasShadow="True"
               HorizontalOptions="End"
               VerticalOptions="End"
               Margin="0,0,16,128"
               ZIndex="5">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleTestModeCommand}" />
            </Frame.GestureRecognizers>
            <Label Text="{Binding TestModeButtonText}"
                   TextColor="{StaticResource White}"
                   FontSize="12"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Frame>

        <!-- Bottom Sheet Container (draggable) -->
        <Grid Grid.Row="2"
              x:Name="BottomSheet"
              ZIndex="10">
            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnBottomSheetPanUpdated" />
            </Grid.GestureRecognizers>

            <!-- Selected POI Info -->
            <Frame BackgroundColor="{StaticResource White}"
                   CornerRadius="20"
                   Padding="0"
                   HasShadow="True"
                   BorderColor="{StaticResource WarmBorder}"
                   IsVisible="{Binding HasSelectedPOI}">
                <VerticalStackLayout Padding="16,4,16,16" Spacing="10">

                    <!-- Draggable Handle Bar -->
                    <ContentView HeightRequest="24" Padding="0">
                        <ContentView.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHandleBarTapped" />
                        </ContentView.GestureRecognizers>
                        <BoxView Color="{StaticResource WarmBorder}"
                                 WidthRequest="36"
                                 HeightRequest="4"
                                 CornerRadius="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />
                    </ContentView>

                    <!-- POI Header -->
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding SelectedPOI.Name}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="15"
                               FontAttributes="Bold" />

                        <!-- Distance Badge -->
                        <Frame Grid.Column="1"
                               BackgroundColor="{StaticResource WarmCream}"
                               CornerRadius="10"
                               Padding="10,4"
                               HasShadow="False"
                               BorderColor="{StaticResource WarmBorder}">
                            <Label Text="{Binding SelectedPOI.DistanceText}"
                                   TextColor="{StaticResource Primary}"
                                   FontSize="11"
                                   FontAttributes="Bold" />
                        </Frame>

                        <!-- Address -->
                        <Label Grid.Row="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding SelectedPOI.Address}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="11"
                               LineBreakMode="TailTruncation"
                               MaxLines="2"
                               Margin="0,3,0,0" />
                    </Grid>

                    <!-- Rating and Time -->
                    <HorizontalStackLayout Spacing="12">
                        <HorizontalStackLayout Spacing="3">
                            <Label Text="&#x2B50;" FontSize="11" />
                            <Label Text="{Binding SelectedPOI.RatingText}"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="3">
                            <Label Text="&#x23F1;" FontSize="11" TextColor="{StaticResource Primary}" />
                            <Label Text="{Binding SelectedPOI.EstimatedTimeText}"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="3">
                            <Label Text="&#x1F4C2;" FontSize="11" />
                            <Label Text="{Binding SelectedPOI.CategoryText}"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="{Binding LblListenNarration}"
                                Command="{Binding PlayNarrationCommand}"
                                TextColor="{StaticResource White}"
                                FontSize="12"
                                FontAttributes="Bold"
                                CornerRadius="20"
                                HeightRequest="44"
                                Padding="4,0">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#E8943A" Offset="0.0" />
                                    <GradientStop Color="#C97B28" Offset="1.0" />
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                        <Button Grid.Column="1"
                                Text="{Binding LblGetDirections}"
                                Command="{Binding NavigateCommand}"
                                BackgroundColor="{StaticResource White}"
                                TextColor="{StaticResource Primary}"
                                BorderColor="{StaticResource Primary}"
                                BorderWidth="1.5"
                                FontSize="12"
                                CornerRadius="20"
                                HeightRequest="44"
                                Padding="4,0" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- POI Quick List (when no POI selected) -->
            <Frame BackgroundColor="{StaticResource White}"
                   CornerRadius="20"
                   Padding="0"
                   HasShadow="True"
                   BorderColor="{StaticResource WarmBorder}"
                   IsVisible="{Binding HasSelectedPOI, Converter={StaticResource InvertBoolConverter}}">
                <VerticalStackLayout Padding="16,4,16,16" Spacing="8">

                    <!-- Draggable Handle Bar -->
                    <ContentView HeightRequest="24" Padding="0">
                        <ContentView.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnHandleBarTapped" />
                        </ContentView.GestureRecognizers>
                        <BoxView Color="{StaticResource WarmBorder}"
                                 WidthRequest="36"
                                 HeightRequest="4"
                                 CornerRadius="2"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />
                    </ContentView>

                    <Label Text="{Binding LblNearbyPlaces}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="14"
                           FontAttributes="Bold"
                           Margin="0" />

                    <ScrollView Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="8"
                                               BindableLayout.ItemsSource="{Binding NearbyPOIs}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:POI">
                                    <Frame BackgroundColor="{StaticResource White}"
                                           CornerRadius="14"
                                           MinimumWidthRequest="120"
                                           WidthRequest="135"
                                           MinimumHeightRequest="100"
                                           HeightRequest="115"
                                           Padding="0"
                                           HasShadow="True"
                                           BorderColor="{StaticResource WarmBorder}">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MapPageViewModel}}, Path=POISelectedCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Frame.GestureRecognizers>
                                        <Grid RowDefinitions="65,*">
                                            <Image Source="{Binding ImageUrl}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="65" />
                                            <VerticalStackLayout Grid.Row="1"
                                                                 Padding="7,5"
                                                                 Spacing="2">
                                                <Label Text="{Binding Name}"
                                                       FontSize="12"
                                                       FontAttributes="Bold"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1" />
                                                <HorizontalStackLayout Spacing="3">
                                                    <Label Text="{Binding DistanceText}"
                                                           FontSize="9"
                                                           TextColor="{StaticResource Primary}" />
                                                    <Label Text="&#x2022;"
                                                           FontSize="9"
                                                           TextColor="{StaticResource TextMuted}" />
                                                    <Label Text="{Binding RatingText, StringFormat='&#x2B50; {0}'}"
                                                           FontSize="9"
                                                           TextColor="{StaticResource TextMuted}" />
                                                </HorizontalStackLayout>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>
            </Frame>
        </Grid>

    </Grid>

</ContentPage>
