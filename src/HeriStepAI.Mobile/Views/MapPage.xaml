<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.MapPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:MapPageViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top Bar with Search -->
        <Frame Grid.Row="0"
               BackgroundColor="{StaticResource White}"
               CornerRadius="0"
               x:Name="TopBar"
               HasShadow="True"
               ZIndex="10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Back Button -->
                <Frame Grid.Column="0"
                       BackgroundColor="{StaticResource Gray100}"
                       CornerRadius="16"
                       WidthRequest="44"
                       HeightRequest="44"
                       Padding="0"
                       HasShadow="False"
                       Margin="0,0,10,0">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="←"
                           FontSize="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>

                <!-- Search Entry -->
                <Frame Grid.Column="1"
                       BackgroundColor="{StaticResource Gray100}"
                       CornerRadius="20"
                       Padding="12,0"
                       HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="🔍"
                               FontSize="13"
                               VerticalOptions="Center"
                               Margin="0,0,6,0" />
                        <Entry Grid.Column="1"
                               Placeholder="Tìm kiếm..."
                               Text="{Binding SearchText}"
                               BackgroundColor="Transparent"
                               FontSize="13"
                               VerticalOptions="Center" />
                    </Grid>
                </Frame>

                <!-- List View Button -->
                <Frame Grid.Column="2"
                       BackgroundColor="{StaticResource Primary}"
                       CornerRadius="16"
                       WidthRequest="44"
                       HeightRequest="44"
                       Padding="0"
                       HasShadow="False"
                       Margin="10,0,0,0">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShowListCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="≡"
                           TextColor="{StaticResource White}"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
            </Grid>
        </Frame>

        <!-- Map View - Full Screen -->
        <WebView Grid.Row="1"
                 x:Name="MapWebView"
                 Margin="0"
                 MinimumHeightRequest="300"
                 ZIndex="1" />

        <!-- Test Mode Status Banner (shown when test mode is active) -->
        <Frame Grid.Row="1"
               BackgroundColor="#E8F5E9"
               CornerRadius="12"
               Padding="12,8"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="16,8,16,0"
               IsVisible="{Binding ShowTestModeStatus}"
               ZIndex="8">
            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="🧪"
                       FontSize="14"
                       VerticalOptions="Center" />
                <Label Text="{Binding TestModeStatus}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#2E7D32"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Frame>

        <!-- Floating My Location Button -->
        <Frame Grid.Row="1"
               BackgroundColor="{StaticResource White}"
               CornerRadius="22"
               WidthRequest="44"
               HeightRequest="44"
               Padding="0"
               HasShadow="True"
               HorizontalOptions="End"
               VerticalOptions="End"
               Margin="0,0,16,76"
               ZIndex="5">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CenterOnLocationCommand}" />
            </Frame.GestureRecognizers>
            <Label Text="📍"
                   FontSize="20"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Frame>

        <!-- Floating Test Mode Button -->
        <Frame Grid.Row="1"
               BackgroundColor="{StaticResource Primary}"
               CornerRadius="18"
               Padding="12,8"
               HasShadow="True"
               HorizontalOptions="End"
               VerticalOptions="End"
               Margin="0,0,16,128"
               ZIndex="5">
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleTestModeCommand}" />
            </Frame.GestureRecognizers>
            <Label Text="{Binding TestModeButtonText}"
                   TextColor="{StaticResource White}"
                   FontSize="12"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Frame>

        <!-- Bottom Sheet - Selected POI Info -->
        <Frame Grid.Row="2"
               BackgroundColor="{StaticResource White}"
               CornerRadius="0"
               Padding="0"
               HasShadow="True"
               IsVisible="{Binding HasSelectedPOI}"
               ZIndex="10">
            <VerticalStackLayout Padding="14,10,14,14" Spacing="8">

                <!-- Handle Bar -->
                <BoxView Color="{StaticResource Gray300}"
                         WidthRequest="36"
                         HeightRequest="4"
                         CornerRadius="2"
                         HorizontalOptions="Center"
                         Margin="0,0,0,4" />

                <!-- POI Header -->
                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                    <Label Grid.Column="0"
                           Text="{Binding SelectedPOI.Name}"
                           Style="{StaticResource TitleLabel}"
                           FontSize="14" />

                    <!-- Distance Badge -->
                    <Frame Grid.Column="1"
                           BackgroundColor="{StaticResource PrimaryLight}"
                           CornerRadius="10"
                           Padding="8,3"
                           HasShadow="False">
                        <Label Text="{Binding SelectedPOI.DistanceText}"
                               TextColor="{StaticResource PrimaryDark}"
                               FontSize="11"
                               FontAttributes="Bold" />
                    </Frame>

                    <!-- Address -->
                    <Label Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding SelectedPOI.Address}"
                           Style="{StaticResource CaptionLabel}"
                           FontSize="11"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           Margin="0,2,0,0" />
                </Grid>

                <!-- Rating and Time -->
                <HorizontalStackLayout Spacing="12">
                    <HorizontalStackLayout Spacing="3">
                        <Label Text="⭐" FontSize="11" />
                        <Label Text="{Binding SelectedPOI.RatingText}"
                               FontSize="11"
                               TextColor="{StaticResource TextSecondary}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="3">
                        <Label Text="⏱" FontSize="11" TextColor="{StaticResource Primary}" />
                        <Label Text="{Binding SelectedPOI.EstimatedMinutes, StringFormat='{0} phút'}"
                               FontSize="11"
                               TextColor="{StaticResource TextSecondary}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="3">
                        <Label Text="📂" FontSize="11" />
                        <Label Text="{Binding SelectedPOI.CategoryText}"
                               FontSize="11"
                               TextColor="{StaticResource TextSecondary}" />
                    </HorizontalStackLayout>
                </HorizontalStackLayout>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Text="🔊 Nghe thuyết minh"
                            Command="{Binding PlayNarrationCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            FontSize="12"
                            CornerRadius="20"
                            HeightRequest="44"
                            Padding="4,0" />
                    <Button Grid.Column="1"
                            Text="🗺️ Chỉ đường"
                            Command="{Binding NavigateCommand}"
                            BackgroundColor="{StaticResource White}"
                            TextColor="{StaticResource Primary}"
                            BorderColor="{StaticResource Primary}"
                            BorderWidth="1.5"
                            FontSize="12"
                            CornerRadius="20"
                            HeightRequest="44"
                            Padding="4,0" />
                </Grid>
            </VerticalStackLayout>
        </Frame>

        <!-- POI Quick List (when no POI selected) -->
        <Frame Grid.Row="2"
               BackgroundColor="{StaticResource White}"
               CornerRadius="0"
               Padding="0"
               HasShadow="True"
               IsVisible="{Binding HasSelectedPOI, Converter={StaticResource InvertBoolConverter}}"
               ZIndex="10">
            <VerticalStackLayout Padding="14,8,14,14" Spacing="6">

                <!-- Handle Bar -->
                <BoxView Color="{StaticResource Gray300}"
                         WidthRequest="36"
                         HeightRequest="4"
                         CornerRadius="2"
                         HorizontalOptions="Center"
                         Margin="0,0,0,2" />

                <Label Text="Địa điểm gần bạn"
                       FontSize="13"
                       FontAttributes="Bold"
                       Margin="0" />

                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding NearbyPOIs}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:POI">
                                <Frame Style="{StaticResource CardFrame}"
                                       MinimumWidthRequest="120"
                                       WidthRequest="135"
                                       MinimumHeightRequest="100"
                                       HeightRequest="115"
                                       Padding="0">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MapPageViewModel}}, Path=POISelectedCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid RowDefinitions="65,*">
                                        <Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               HeightRequest="65" />
                                        <VerticalStackLayout Grid.Row="1"
                                                             Padding="7,5"
                                                             Spacing="2">
                                            <Label Text="{Binding Name}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1" />
                                            <HorizontalStackLayout Spacing="3">
                                                <Label Text="{Binding DistanceText}"
                                                       FontSize="9"
                                                       TextColor="{StaticResource Primary}" />
                                                <Label Text="•"
                                                       FontSize="9"
                                                       TextColor="{StaticResource TextMuted}" />
                                                <Label Text="{Binding RatingText, StringFormat='⭐ {0}'}"
                                                       FontSize="9"
                                                       TextColor="{StaticResource TextMuted}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>
        </Frame>

    </Grid>

</ContentPage>
