<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.MapPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:MapPageViewModel"
             Title="Bản đồ">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Map View - Using WebView with Leaflet + OpenStreetMap (Free) -->
        <WebView Grid.Row="0" 
                 x:Name="MapWebView" />

        <!-- POI List -->
        <Frame Grid.Row="1" 
               BackgroundColor="White" 
               Padding="10"
               HasShadow="True">
            <ScrollView Orientation="Horizontal">
                <StackLayout Orientation="Horizontal" Spacing="10">
                    <CollectionView ItemsSource="{Binding POIs}" 
                                    SelectionMode="Single"
                                    SelectionChanged="OnPOISelected">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:POI">
                                <Frame BackgroundColor="LightBlue" 
                                       Padding="10"
                                       CornerRadius="5"
                                       WidthRequest="200">
                                    <StackLayout>
                                        <Label Text="{Binding Name}" 
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Description}" 
                                               FontSize="12" />
                                    </StackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </StackLayout>
            </ScrollView>
        </Frame>
    </Grid>

</ContentPage>
