<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.TourDetailPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:TourDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header with Tour Image -->
        <Grid Grid.Row="0" x:Name="HeaderGrid">
            <Image Source="{Binding Tour.ImageUrl}"
                   Aspect="AspectFill" />
            <BoxView Color="{StaticResource Black}" Opacity="0.4" />

            <!-- Header Content -->
            <Grid RowDefinitions="Auto,*,Auto" x:Name="HeaderContent" Padding="14,10,14,12">
                <!-- Back Button -->
                <Frame Grid.Row="0"
                       BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       WidthRequest="44"
                       HeightRequest="44"
                       Padding="0"
                       HasShadow="False"
                       HorizontalOptions="Start">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="←"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>

                <!-- Tour Title -->
                <VerticalStackLayout Grid.Row="2" Spacing="4">
                    <Label Text="{Binding Tour.Name}"
                           TextColor="{StaticResource White}"
                           FontSize="18"
                           FontAttributes="Bold" />
                    <Label Text="{Binding Tour.Description}"
                           TextColor="{StaticResource White}"
                           FontSize="12"
                           Opacity="0.9"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <!-- Tour Stats -->
                    <FlexLayout Wrap="Wrap"
                                AlignItems="Center"
                                Margin="0,4,0,0"
                                Direction="Row">
                        <HorizontalStackLayout Spacing="3" Margin="0,0,12,2">
                            <Label Text="📍" FontSize="11" />
                            <Label Text="{Binding Tour.ShopCountText}"
                                   TextColor="{StaticResource White}"
                                   FontSize="11" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="3" Margin="0,0,12,2">
                            <Label Text="⏱" FontSize="11" />
                            <Label Text="{Binding Tour.EstimatedTimeText}"
                                   TextColor="{StaticResource White}"
                                   FontSize="11" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="3" Margin="0,0,0,2">
                            <Label Text="💰" FontSize="11" />
                            <Label Text="{Binding TotalPriceRange}"
                                   TextColor="{StaticResource White}"
                                   FontSize="11"
                                   FontAttributes="Bold" />
                        </HorizontalStackLayout>
                    </FlexLayout>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- POI List -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ContentStack" Spacing="8" Padding="14,10">
                <Label Text="{Binding LblPOIList}"
                       Style="{StaticResource SectionHeader}" />

                <CollectionView ItemsSource="{Binding Tour.POIs}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:POI">
                            <Frame Style="{StaticResource CardFrame}"
                                   Margin="0,0,0,8"
                                   Padding="0">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TourDetailViewModel}}, Path=SelectPOICommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="90,*" MinimumHeightRequest="80">
                                    <!-- POI Image -->
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="FillAndExpand"
                                           VerticalOptions="FillAndExpand">
                                        <Image.Clip>
                                            <RoundRectangleGeometry Rect="0,0,90,80" CornerRadius="12,0,0,12" />
                                        </Image.Clip>
                                    </Image>

                                    <!-- POI Info -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="10,8"
                                                         VerticalOptions="Center"
                                                         Spacing="3"
                                                         HorizontalOptions="FillAndExpand">
                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource TitleLabel}"
                                               FontSize="13"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="⭐" FontSize="10" />
                                            <Label Text="{Binding RatingText}"
                                                   Style="{StaticResource CaptionLabel}"
                                                   FontSize="11" />
                                        </HorizontalStackLayout>

                                        <Label Text="{Binding FoodTypeText}"
                                               TextColor="{StaticResource Primary}"
                                               FontSize="10"
                                               FontAttributes="Bold" />

                                        <Label Text="{Binding PriceRangeText}"
                                               TextColor="{StaticResource Secondary}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               IsVisible="{Binding PriceRangeText, Converter={StaticResource IsNotEmptyConverter}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Frame Grid.Row="2"
               BackgroundColor="{StaticResource White}"
               CornerRadius="0"
               Padding="14,10,14,14"
               HasShadow="True">
            <Button Text="{Binding LblStartTour}"
                    Command="{Binding StartTourCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="{StaticResource White}"
                    FontSize="14"
                    CornerRadius="22"
                    HeightRequest="44" />
        </Frame>
    </Grid>

</ContentPage>
