<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.TourDetailPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:TourDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header with Tour Image -->
        <Grid Grid.Row="0" x:Name="HeaderGrid" MinimumHeightRequest="240">
            <Image Source="{Binding Tour.ImageUrl}"
                   Aspect="AspectFill" />
            <!-- Dark gradient overlay -->
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55000000" Offset="0.0" />
                        <GradientStop Color="#CC1E1612" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
            </Grid>

            <!-- Header Content -->
            <Grid RowDefinitions="Auto,*,Auto" x:Name="HeaderContent" Padding="16,48,16,16">
                <!-- Back Button -->
                <Frame Grid.Row="0"
                       BackgroundColor="#33FFFFFF"
                       CornerRadius="16"
                       WidthRequest="40"
                       HeightRequest="40"
                       Padding="0"
                       HasShadow="False"
                       BorderColor="Transparent"
                       HorizontalOptions="Start">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="←"
                           TextColor="{StaticResource White}"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>

                <!-- Tour Title -->
                <VerticalStackLayout Grid.Row="2" Spacing="6">
                    <Label Text="{Binding Tour.Name}"
                           TextColor="{StaticResource White}"
                           FontSize="20"
                           FontAttributes="Bold" />
                    <Label Text="{Binding Tour.Description}"
                           TextColor="{StaticResource White}"
                           FontSize="12"
                           Opacity="0.85"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <!-- Tour Stats Chips -->
                    <FlexLayout Wrap="Wrap"
                                AlignItems="Center"
                                Margin="0,4,0,0"
                                Direction="Row">
                        <Frame BackgroundColor="#33FFFFFF"
                               CornerRadius="12"
                               Padding="10,5"
                               HasShadow="False"
                               BorderColor="Transparent"
                               Margin="0,0,8,4">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="📍" FontSize="11" />
                                <Label Text="{Binding Tour.ShopCountText}"
                                       TextColor="{StaticResource White}"
                                       FontSize="11" />
                            </HorizontalStackLayout>
                        </Frame>
                        <Frame BackgroundColor="#33FFFFFF"
                               CornerRadius="12"
                               Padding="10,5"
                               HasShadow="False"
                               BorderColor="Transparent"
                               Margin="0,0,8,4">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="⏱" FontSize="11" />
                                <Label Text="{Binding Tour.EstimatedTimeText}"
                                       TextColor="{StaticResource White}"
                                       FontSize="11" />
                            </HorizontalStackLayout>
                        </Frame>
                        <Frame BackgroundColor="#33FFFFFF"
                               CornerRadius="12"
                               Padding="10,5"
                               HasShadow="False"
                               BorderColor="Transparent"
                               Margin="0,0,0,4">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="💰" FontSize="11" />
                                <Label Text="{Binding TotalPriceRange}"
                                       TextColor="{StaticResource White}"
                                       FontSize="11"
                                       FontAttributes="Bold" />
                            </HorizontalStackLayout>
                        </Frame>
                    </FlexLayout>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- POI List -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ContentStack" Spacing="8" Padding="16,14">
                <Label Text="{Binding LblPOIList}"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="16"
                       FontAttributes="Bold"
                       Margin="0,0,0,4" />

                <CollectionView ItemsSource="{Binding Tour.POIs}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:POI">
                            <Frame BackgroundColor="{StaticResource White}"
                                   CornerRadius="16"
                                   Margin="0,0,0,10"
                                   Padding="0"
                                   HasShadow="True"
                                   BorderColor="{StaticResource WarmBorder}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TourDetailViewModel}}, Path=SelectPOICommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="90,*" MinimumHeightRequest="82">
                                    <!-- POI Image -->
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="FillAndExpand"
                                           VerticalOptions="FillAndExpand">
                                        <Image.Clip>
                                            <RoundRectangleGeometry Rect="0,0,90,82" CornerRadius="16,0,0,16" />
                                        </Image.Clip>
                                    </Image>

                                    <!-- POI Info -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="12,10"
                                                         VerticalOptions="Center"
                                                         Spacing="4">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />

                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="⭐" FontSize="10" />
                                            <Label Text="{Binding RatingText}"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   FontSize="11" />
                                        </HorizontalStackLayout>

                                        <Label Text="{Binding FoodTypeText}"
                                               TextColor="{StaticResource Primary}"
                                               FontSize="10"
                                               FontAttributes="Bold" />

                                        <Label Text="{Binding PriceRangeText}"
                                               TextColor="{StaticResource Success}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               IsVisible="{Binding PriceRangeText, Converter={StaticResource IsNotEmptyConverter}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Grid Grid.Row="2"
              BackgroundColor="{StaticResource White}"
              Padding="16,10,16,14">
            <Grid.Shadow>
                <Shadow Brush="{StaticResource Black}" Offset="0,-2" Radius="8" Opacity="0.06" />
            </Grid.Shadow>
            <Button Text="{Binding LblStartTour}"
                    Command="{Binding StartTourCommand}"
                    TextColor="{StaticResource White}"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="24"
                    HeightRequest="48">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#E8943A" Offset="0.0" />
                        <GradientStop Color="#C97B28" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Grid>
    </Grid>

</ContentPage>
