<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.TourDetailPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:TourDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Photo Header -->
        <Grid Grid.Row="0" x:Name="HeaderGrid" MinimumHeightRequest="250">
            <Image Source="{Binding Tour.ImageUrl}" Aspect="AspectFill" />
            <!-- Overlay -->
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#44000000" Offset="0.0" />
                        <GradientStop Color="#EE1A1712" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
            </Grid>

            <Grid x:Name="HeaderContent" RowDefinitions="Auto,*,Auto" Padding="18,50,18,18">
                <!-- Back + share row -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" BackgroundColor="#33FFFFFF"
                            StrokeShape="RoundRectangle 14" WidthRequest="38" HeightRequest="38"
                            Padding="0" Stroke="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="←" TextColor="{StaticResource White}" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- Tour info -->
                <VerticalStackLayout Grid.Row="2" Spacing="8">
                    <Label Text="TOUR ẨM THỰC"
                           TextColor="{StaticResource CreamDark}"
                           FontSize="9" CharacterSpacing="1.5" FontAttributes="Bold" />
                    <Label Text="{Binding Tour.Name}"
                           TextColor="{StaticResource White}"
                           FontSize="22" FontAttributes="Bold" />
                    <Label Text="{Binding Tour.Description}"
                           TextColor="{StaticResource CreamDark}"
                           FontSize="12" MaxLines="2" LineBreakMode="TailTruncation" />

                    <!-- Stat chips -->
                    <HorizontalStackLayout Spacing="7" Margin="0,4,0,0">
                        <Border BackgroundColor="#33FFFFFF" Stroke="Transparent"
                                StrokeShape="RoundRectangle 10" Padding="10,5">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="📍" FontSize="11" />
                                <Label Text="{Binding Tour.ShopCountText}"
                                       TextColor="{StaticResource White}" FontSize="11" />
                            </HorizontalStackLayout>
                        </Border>
                        <Border BackgroundColor="#33FFFFFF" Stroke="Transparent"
                                StrokeShape="RoundRectangle 10" Padding="10,5">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="⏱" FontSize="11" />
                                <Label Text="{Binding Tour.EstimatedTimeText}"
                                       TextColor="{StaticResource White}" FontSize="11" />
                            </HorizontalStackLayout>
                        </Border>
                        <Border BackgroundColor="#33FFFFFF" Stroke="Transparent"
                                StrokeShape="RoundRectangle 10" Padding="10,5">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="💰" FontSize="11" />
                                <Label Text="{Binding TotalPriceRange}"
                                       TextColor="{StaticResource White}" FontSize="11" FontAttributes="Bold" />
                            </HorizontalStackLayout>
                        </Border>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ContentStack" Spacing="0" Padding="16,16,16,4">

                <!-- Section heading + progress -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="ĐIỂM DỪNG" TextColor="{StaticResource TextMuted}"
                               FontSize="9" CharacterSpacing="1.2" FontAttributes="Bold" />
                        <Label Text="{Binding LblPOIList}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="16" FontAttributes="Bold" />
                    </VerticalStackLayout>
                    <!-- Progress indicator -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource WarmCream}"
                            Stroke="{StaticResource WarmBorder}"
                            StrokeShape="RoundRectangle 10"
                            Padding="12,6" VerticalOptions="Center">
                        <Label Text="{Binding Tour.ShopCountText}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12" FontAttributes="Bold" />
                    </Border>
                </Grid>

                <!-- Progress bar -->
                <Grid Margin="0,0,0,16">
                    <BoxView Color="{StaticResource WarmBorder}" HeightRequest="3" CornerRadius="2" />
                    <BoxView Color="{StaticResource Accent}" HeightRequest="3" CornerRadius="2"
                             HorizontalOptions="Start" WidthRequest="80" />
                </Grid>

                <!-- Stop list -->
                <CollectionView ItemsSource="{Binding Tour.POIs}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:POI">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14"
                                  Padding="0,0,0,14">
                                <!-- Left: number + connector line -->
                                <VerticalStackLayout Grid.Column="0" Spacing="0"
                                                     HorizontalOptions="Center" WidthRequest="28">
                                    <!-- Stop number bubble -->
                                    <Border BackgroundColor="{StaticResource Primary}"
                                            StrokeShape="RoundRectangle 14"
                                            WidthRequest="28" HeightRequest="28"
                                            Stroke="Transparent" Padding="0"
                                            HorizontalOptions="Center">
                                        <Label Text="1" TextColor="{StaticResource White}"
                                               FontSize="11" FontAttributes="Bold"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <!-- Connector line -->
                                    <BoxView Color="{StaticResource WarmBorder}"
                                             WidthRequest="1" VerticalOptions="Fill"
                                             MinimumHeightRequest="30"
                                             HorizontalOptions="Center" />
                                </VerticalStackLayout>

                                <!-- Right: card -->
                                <Border Grid.Column="1"
                                        BackgroundColor="{StaticResource CardBackground}"
                                        Stroke="{StaticResource WarmBorder}" StrokeThickness="0.5"
                                        StrokeShape="RoundRectangle 14" Padding="0">
                                    <Border.Shadow>
                                        <Shadow Brush="Black" Offset="0,2" Radius="6" Opacity="0.04" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TourDetailViewModel}}, Path=SelectPOICommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="76,*" MinimumHeightRequest="76">
                                        <Border Grid.Column="0" StrokeShape="RoundRectangle 14,0,0,14"
                                                Stroke="Transparent" Padding="0">
                                            <Image Source="{Binding ImageUrl}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="76" WidthRequest="76" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1"
                                                             Padding="12,10"
                                                             VerticalOptions="Center"
                                                             Spacing="3">
                                            <Label Text="{Binding Name}"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation" MaxLines="2" />
                                            <HorizontalStackLayout Spacing="3">
                                                <Label Text="⭐" FontSize="10" TextColor="{StaticResource Accent}" />
                                                <Label Text="{Binding RatingText}"
                                                       TextColor="{StaticResource TextSecondary}" FontSize="11" />
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="6">
                                                <Border BackgroundColor="{StaticResource WarmCream}"
                                                        Stroke="{StaticResource WarmBorder}"
                                                        StrokeShape="RoundRectangle 5" Padding="6,2">
                                                    <Label Text="{Binding FoodTypeText}"
                                                           FontSize="10" TextColor="{StaticResource TextSecondary}" />
                                                </Border>
                                                <Label Text="{Binding PriceRangeText}"
                                                       TextColor="{StaticResource Secondary}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       VerticalOptions="Center"
                                                       IsVisible="{Binding PriceRangeText, Converter={StaticResource IsNotEmptyConverter}}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="8" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Bar -->
        <Grid Grid.Row="2"
              BackgroundColor="{StaticResource CardBackground}"
              Padding="16,12,16,18">
            <Grid.Shadow>
                <Shadow Brush="{StaticResource Black}" Offset="0,-2" Radius="10" Opacity="0.05" />
            </Grid.Shadow>
            <Button Text="{Binding LblStartTour}"
                    Command="{Binding StartTourCommand}"
                    TextColor="{StaticResource White}"
                    BackgroundColor="{StaticResource Primary}"
                    FontSize="14" FontAttributes="Bold"
                    CornerRadius="24" HeightRequest="50" />
        </Grid>
    </Grid>

</ContentPage>
