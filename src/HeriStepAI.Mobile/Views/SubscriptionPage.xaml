<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HeriStepAI.Mobile.ViewModels"
             x:Class="HeriStepAI.Mobile.Views.SubscriptionPage"
             x:DataType="vm:SubscriptionViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  PLAN SELECTION VIEW                                           -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ScrollView IsVisible="{Binding IsPaying, Converter={StaticResource InvertBoolConverter}}">
            <VerticalStackLayout Spacing="0">

                <!-- Hero Header -->
                <Grid HeightRequest="220">
                    <!-- Language button — top right corner -->
                    <Border ZIndex="10"
                            HorizontalOptions="End" VerticalOptions="Start"
                            Margin="0,44,16,0"
                            BackgroundColor="#44FFFFFF"
                            StrokeThickness="0" StrokeShape="RoundRectangle 20"
                            Padding="12,6">
                        <Label Text="{Binding CurrentLangLabel}"
                               FontSize="13" FontAttributes="Bold" TextColor="White">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SwitchLanguageCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1A1410" Offset="0.0" />
                            <GradientStop Color="#2C2416" Offset="0.7" />
                            <GradientStop Color="#3A3020" Offset="1.0" />
                        </LinearGradientBrush>
                    </Grid.Background>

                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8" Padding="24">
                        <Label Text="🗺️" FontSize="52" HorizontalOptions="Center" />
                        <Label Text="HeriStep AI"
                               FontSize="28" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Label Text="{Binding LblHeroSubtitle}"
                               FontSize="14" TextColor="#C4B99A"
                               HorizontalOptions="Center" />
                        <BoxView HeightRequest="1" Color="#C4A24A" Margin="40,8,40,0" />
                        <Label Text="{Binding LblHeroPrompt}"
                               FontSize="13" TextColor="#A8A09A"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Plan Cards -->
                <VerticalStackLayout Padding="20,24,20,0" Spacing="14">

                    <!-- Daily -->
                    <Border StrokeThickness="1.5" StrokeShape="RoundRectangle 16">
                        <Border.Stroke>
                            <SolidColorBrush Color="{StaticResource WarmBorder}" />
                        </Border.Stroke>
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource CardBackground}" />
                        </Border.Background>

                        <Grid ColumnDefinitions="*,Auto" Padding="20,18">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding LblPlanDaily}" FontSize="17" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding LblPlanDailyDesc}"
                                       FontSize="13" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End"
                                                 VerticalOptions="Center" Spacing="2">
                                <Label Text="29.000 đ" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" HorizontalOptions="End" />
                                <Label Text="{Binding LblPlanDailyPeriod}" FontSize="11"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectPlanCommand}"
                                                      CommandParameter="{Binding Plans[0]}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Weekly -->
                    <Border StrokeThickness="1.5" StrokeShape="RoundRectangle 16">
                        <Border.Stroke>
                            <SolidColorBrush Color="{StaticResource WarmBorder}" />
                        </Border.Stroke>
                        <Border.Background>
                            <SolidColorBrush Color="{StaticResource CardBackground}" />
                        </Border.Background>

                        <Grid ColumnDefinitions="*,Auto" Padding="20,18">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding LblPlanWeekly}" FontSize="17" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding LblPlanWeeklyDesc}"
                                       FontSize="13" TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="End"
                                                 VerticalOptions="Center" Spacing="2">
                                <Label Text="99.000 đ" FontSize="20" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" HorizontalOptions="End" />
                                <Label Text="{Binding LblPlanWeeklyPeriod}" FontSize="11"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectPlanCommand}"
                                                      CommandParameter="{Binding Plans[1]}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Monthly (highlighted) -->
                    <Border StrokeThickness="2" StrokeShape="RoundRectangle 16">
                        <Border.Stroke>
                            <SolidColorBrush Color="{StaticResource Accent}" />
                        </Border.Stroke>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFF8EC" Offset="0.0" />
                                <GradientStop Color="#FFF2D8" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" Padding="20,18">
                            <!-- Badge -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="{StaticResource Accent}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    Padding="8,4" VerticalOptions="Start">
                                <Label Text="{Binding LblBadgePopular}" FontSize="10" FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="{Binding LblPlanMonthly}" FontSize="17" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding LblPlanMonthlyDesc}"
                                       FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="End"
                                                 VerticalOptions="Center" Spacing="2" Margin="0,8,0,0">
                                <Label Text="199.000 đ" FontSize="22" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" HorizontalOptions="End" />
                                <Label Text="{Binding LblPlanMonthlyPeriod}" FontSize="11"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectPlanCommand}"
                                                      CommandParameter="{Binding Plans[2]}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                    <!-- Yearly -->
                    <Border StrokeThickness="1.5" StrokeShape="RoundRectangle 16">
                        <Border.Stroke>
                            <SolidColorBrush Color="{StaticResource Secondary}" />
                        </Border.Stroke>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F0FFF4" Offset="0.0" />
                                <GradientStop Color="#E8F5EC" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" Padding="20,18">
                            <!-- Badge -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    BackgroundColor="{StaticResource Secondary}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 8"
                                    Padding="8,4" VerticalOptions="Start">
                                <Label Text="{Binding LblBadgeSave}" FontSize="10" FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="{Binding LblPlanYearly}" FontSize="17" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                                <Label Text="{Binding LblPlanYearlyDesc}"
                                       FontSize="13" TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="End"
                                                 VerticalOptions="Center" Spacing="2" Margin="0,8,0,0">
                                <Label Text="999.000 đ" FontSize="22" FontAttributes="Bold"
                                       TextColor="{StaticResource Secondary}" HorizontalOptions="End" />
                                <Label Text="{Binding LblPlanYearlyPeriod}" FontSize="11"
                                       TextColor="{StaticResource TextMuted}" HorizontalOptions="End" />
                            </VerticalStackLayout>

                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SelectPlanCommand}"
                                                      CommandParameter="{Binding Plans[3]}" />
                            </Grid.GestureRecognizers>
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- Features list -->
                <VerticalStackLayout Padding="28,20,28,8" Spacing="10">
                    <Label Text="{Binding LblFeaturesTitle}" FontSize="13"
                           TextColor="{StaticResource TextMuted}" FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="✓" FontSize="14" TextColor="{StaticResource Secondary}" />
                        <Label Text="{Binding LblFeature1}"
                               FontSize="13" TextColor="{StaticResource TextSecondary}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="✓" FontSize="14" TextColor="{StaticResource Secondary}" />
                        <Label Text="{Binding LblFeature2}"
                               FontSize="13" TextColor="{StaticResource TextSecondary}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="✓" FontSize="14" TextColor="{StaticResource Secondary}" />
                        <Label Text="{Binding LblFeature3}"
                               FontSize="13" TextColor="{StaticResource TextSecondary}" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="✓" FontSize="14" TextColor="{StaticResource Secondary}" />
                        <Label Text="{Binding LblFeature4}"
                               FontSize="13" TextColor="{StaticResource TextSecondary}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Footer note -->
                <Label Text="{Binding LblFooterNote}"
                       FontSize="11" TextColor="{StaticResource TextFaint}"
                       HorizontalOptions="Center" Margin="0,8,0,32" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  QR PAYMENT VIEW                                               -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <ScrollView IsVisible="{Binding IsPaying}">
            <VerticalStackLayout Padding="20,0,20,40" Spacing="0">

                <!-- Top bar -->
                <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,52,0,16">
                    <Button Grid.Column="0" Text="←" Command="{Binding BackToPlansCommand}"
                            BackgroundColor="Transparent" TextColor="{StaticResource Primary}"
                            FontSize="22" Padding="0" WidthRequest="44" />
                    <Label Grid.Column="1" Text="{Binding LblPayTitle}"
                           FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           VerticalOptions="Center" HorizontalOptions="Center" />
                    <!-- Language switch button -->
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource WarmCream}"
                            StrokeThickness="1" StrokeShape="RoundRectangle 20"
                            Padding="10,5" VerticalOptions="Center">
                        <Border.Stroke>
                            <SolidColorBrush Color="{StaticResource WarmBorder}" />
                        </Border.Stroke>
                        <Label Text="{Binding CurrentLangLabel}"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SwitchLanguageCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <!-- Plan summary card -->
                <Border BackgroundColor="{StaticResource Primary}"
                        StrokeThickness="0" StrokeShape="RoundRectangle 16"
                        Padding="20,16" Margin="0,0,0,20">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding SelectedPlan.Label}"
                                   FontSize="16" FontAttributes="Bold" TextColor="White" />
                            <Label Text="{Binding SelectedPlan.PriceNote}"
                                   FontSize="12" TextColor="#C4B99A" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="{Binding SelectedPlan.Price}"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="{StaticResource Accent}"
                               VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- QR Code -->
                <Border StrokeThickness="1" StrokeShape="RoundRectangle 16"
                        BackgroundColor="White" Padding="16" Margin="0,0,0,16">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding LblScanQR}"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalOptions="Center" />

                        <!-- QR Image from VietQR API -->
                        <Image Source="{Binding QrImageUrl}"
                               WidthRequest="240" HeightRequest="240"
                               HorizontalOptions="Center"
                               Aspect="AspectFit" />

                        <Label Text="{Binding LblOrManual}"
                               FontSize="12" TextColor="{StaticResource TextMuted}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Transfer details -->
                <Border StrokeThickness="1" StrokeShape="RoundRectangle 12"
                        BackgroundColor="{StaticResource WarmCream}"
                        Padding="16,14" Margin="0,0,0,20">
                    <VerticalStackLayout Spacing="8">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding LblBank}"
                                   FontSize="13" TextColor="{StaticResource TextMuted}" />
                            <Label Grid.Column="1" Text="Vietinbank"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource WarmBorder}" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding LblAccountNo}"
                                   FontSize="13" TextColor="{StaticResource TextMuted}" />
                            <Label Grid.Column="1" x:Name="AccountNoLabel"
                                   Text="104879400502"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource WarmBorder}" />

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="{Binding LblAmount}"
                                   FontSize="13" TextColor="{StaticResource TextMuted}" />
                            <Label Grid.Column="1" Text="{Binding TransferAmount}"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource WarmBorder}" />

                        <!-- Transfer ref — tappable to copy -->
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="{Binding LblTransferRef}"
                                       FontSize="13" TextColor="{StaticResource TextMuted}" />
                                <Label Text="{Binding LblRefImportant}"
                                       FontSize="10" TextColor="{StaticResource Warning}" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="{Binding TransferRef}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}"
                                       x:Name="RefLabel" />
                                <Label Text="📋" FontSize="16">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnCopyRefTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Warning note -->
                <Border BackgroundColor="#FFF3CD" StrokeThickness="0"
                        StrokeShape="RoundRectangle 10" Padding="14,10" Margin="0,0,0,24">
                    <Label TextColor="#856404" FontSize="12">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="⚠️  " FontAttributes="Bold" />
                                <Span Text="{Binding LblWarning}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>

                <!-- Confirm Button -->
                <Button Text="{Binding LblConfirmBtn}"
                        Command="{Binding ConfirmPaymentCommand}"
                        IsEnabled="{Binding IsInteractionEnabled}"
                        BackgroundColor="{StaticResource Secondary}"
                        TextColor="White"
                        FontSize="16" FontAttributes="Bold"
                        HeightRequest="54"
                        CornerRadius="14"
                        Margin="0,0,0,12" />

                <Button Text="{Binding LblCheckEntitlementBtn}"
                        Command="{Binding CheckEntitlementCommand}"
                        IsEnabled="{Binding IsInteractionEnabled}"
                        BackgroundColor="{StaticResource WarmCream}"
                        TextColor="{StaticResource Primary}"
                        FontSize="15" FontAttributes="Bold"
                        HeightRequest="50"
                        CornerRadius="14"
                        Margin="0,0,0,12" />

                <!-- Loading indicator -->
                <ActivityIndicator IsRunning="{Binding IsSubscriptionBusy}"
                                   IsVisible="{Binding IsSubscriptionBusy}"
                                   Color="{StaticResource Secondary}"
                                   HorizontalOptions="Center" />

                <Label Text="{Binding LblConfirmNote}"
                       FontSize="12" TextColor="{StaticResource TextMuted}"
                       HorizontalOptions="Center" Margin="0,4,0,0" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
