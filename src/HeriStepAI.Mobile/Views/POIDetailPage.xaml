<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.POIDetailPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             x:DataType="viewmodel:POIDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Photo Header -->
        <Grid Grid.Row="0" x:Name="HeaderGrid" MinimumHeightRequest="240">
            <Image Source="{Binding SelectedPoi.ImageUrl}" Aspect="AspectFill" />

            <!-- Dark overlay -->
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#33000000" Offset="0.0" />
                        <GradientStop Color="#EE1A1712" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
            </Grid>

            <!-- Header content -->
            <Grid x:Name="HeaderOverlay" RowDefinitions="Auto,*,Auto" Padding="18,50,18,18">
                <!-- Back + Save row -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto">
                    <Border Grid.Column="0" BackgroundColor="#33FFFFFF"
                            StrokeShape="RoundRectangle 14" WidthRequest="38" HeightRequest="38"
                            Padding="0" Stroke="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="←" TextColor="{StaticResource White}" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <!-- Open badge -->
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource Secondary}"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent" Padding="9,4">
                        <Label Text="Đang mở" TextColor="{StaticResource White}"
                               FontSize="10" FontAttributes="Bold" />
                    </Border>
                </Grid>

                <!-- POI name + category -->
                <VerticalStackLayout Grid.Row="2" Spacing="5">
                    <Label Text="{Binding SelectedPoi.CategoryText}"
                           TextColor="{StaticResource CreamDark}"
                           FontSize="10" CharacterSpacing="1.0"
                           FontAttributes="Bold" TextTransform="Uppercase" />
                    <Label Text="{Binding SelectedPoi.Name}"
                           TextColor="{StaticResource White}"
                           FontSize="22" FontAttributes="Bold"
                           LineBreakMode="WordWrap" />
                    <!-- Stars + reviews -->
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="⭐" FontSize="12" TextColor="{StaticResource Accent}" />
                        <Label Text="{Binding SelectedPoi.RatingText}"
                               FontSize="12" FontAttributes="Bold" TextColor="{StaticResource White}" />
                        <Label Text="{Binding SelectedPoi.ReviewCount, StringFormat='({0} đánh giá)'}"
                               FontSize="12" TextColor="{StaticResource CreamDark}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Scrollable body -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ContentStack" Spacing="10" Padding="16,14,16,4">

                <!-- Info chips -->
                <HorizontalStackLayout Spacing="7">
                    <Border BackgroundColor="{StaticResource WarmCream}"
                            Stroke="{StaticResource WarmBorder}"
                            StrokeShape="RoundRectangle 8" Padding="10,5">
                        <Label Text="{Binding SelectedPoi.EstimatedTimeText}"
                               FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border BackgroundColor="{StaticResource WarmCream}"
                            Stroke="{StaticResource WarmBorder}"
                            StrokeShape="RoundRectangle 8" Padding="10,5">
                        <Label Text="{Binding SelectedPoi.FoodTypeText}"
                               FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    </Border>
                    <Border BackgroundColor="{StaticResource WarmCream}"
                            Stroke="{StaticResource WarmBorder}"
                            StrokeShape="RoundRectangle 8" Padding="10,5">
                        <Label Text="{Binding SelectedPoi.PriceRangeText}"
                               FontSize="11" TextColor="{StaticResource Secondary}"
                               FontAttributes="Bold" />
                    </Border>
                </HorizontalStackLayout>

                <!-- AI Narration Card (dark brown, like UI kit) -->
                <Border BackgroundColor="{StaticResource Primary}"
                        StrokeShape="RoundRectangle 16"
                        Stroke="Transparent" Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <!-- Label row -->
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="2">
                                <Label Text="AI THUYẾT MINH"
                                       TextColor="{StaticResource CreamDark}"
                                       FontSize="9" CharacterSpacing="1.2"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding SelectedPoi.Name}"
                                       TextColor="{StaticResource White}"
                                       FontSize="14" FontAttributes="Bold"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                            <!-- Language indicator -->
                            <Border Grid.Column="1"
                                    BackgroundColor="#22FFFFFF"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="9,5"
                                    VerticalOptions="Start">
                                <Label Text="🌐 VI" TextColor="{StaticResource CreamDark}"
                                       FontSize="10" FontAttributes="Bold" />
                            </Border>
                        </Grid>

                        <!-- Audio player row -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <!-- Play button -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource CreamDark}"
                                    StrokeShape="RoundRectangle 22"
                                    WidthRequest="44" HeightRequest="44"
                                    Stroke="Transparent" Padding="0">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PlayNarrationCommand}" />
                                </Border.GestureRecognizers>
                                <Label Text="▶" FontSize="16" TextColor="{StaticResource Primary}"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       Margin="3,0,0,0" />
                            </Border>

                            <!-- Waveform visualization (decorative bars) -->
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="2.5"
                                                   VerticalOptions="Center">
                                <BoxView Color="#5DC4B99A" WidthRequest="3" HeightRequest="8" CornerRadius="2" />
                                <BoxView Color="#5DC4B99A" WidthRequest="3" HeightRequest="16" CornerRadius="2" />
                                <BoxView Color="{StaticResource CreamDark}" WidthRequest="3" HeightRequest="22" CornerRadius="2" />
                                <BoxView Color="{StaticResource CreamDark}" WidthRequest="3" HeightRequest="14" CornerRadius="2" />
                                <BoxView Color="#5DC4B99A" WidthRequest="3" HeightRequest="10" CornerRadius="2" />
                                <BoxView Color="#5DC4B99A" WidthRequest="3" HeightRequest="18" CornerRadius="2" />
                                <BoxView Color="{StaticResource CreamDark}" WidthRequest="3" HeightRequest="24" CornerRadius="2" />
                                <BoxView Color="#5DC4B99A" WidthRequest="3" HeightRequest="12" CornerRadius="2" />
                                <BoxView Color="{StaticResource CreamDark}" WidthRequest="3" HeightRequest="20" CornerRadius="2" />
                                <BoxView Color="#5DC4B99A" WidthRequest="3" HeightRequest="8" CornerRadius="2" />
                                <BoxView Color="#5DC4B99A" WidthRequest="3" HeightRequest="14" CornerRadius="2" />
                                <BoxView Color="{StaticResource CreamDark}" WidthRequest="3" HeightRequest="18" CornerRadius="2" />
                            </HorizontalStackLayout>

                            <!-- Duration -->
                            <Label Grid.Column="2"
                                   Text="1:30"
                                   TextColor="{StaticResource TextFaint}"
                                   FontSize="11"
                                   VerticalOptions="Center" />
                        </Grid>

                        <!-- Narration text preview -->
                        <Label Text="{Binding LocalizedDescription}"
                               TextColor="{StaticResource CreamDark}"
                               FontSize="12" LineHeight="1.5"
                               LineBreakMode="WordWrap"
                               MaxLines="3" />
                    </VerticalStackLayout>
                </Border>

                <!-- Address Card -->
                <Border BackgroundColor="{StaticResource CardBackground}"
                        Stroke="{StaticResource WarmBorder}" StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource WarmCream}"
                                StrokeShape="RoundRectangle 10"
                                WidthRequest="36" HeightRequest="36"
                                Padding="0" Stroke="{StaticResource WarmBorder}">
                            <Label Text="📍" FontSize="16"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="ĐỊA CHỈ" TextColor="{StaticResource TextMuted}"
                                   FontSize="9" CharacterSpacing="1.0" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedPoi.Address}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="13" LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Stats row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource CardBackground}"
                            Stroke="{StaticResource WarmBorder}" StrokeThickness="0.5"
                            StrokeShape="RoundRectangle 14" Padding="14">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="🍽️" FontSize="22" HorizontalOptions="Center" />
                            <Label Text="LOẠI MÓN" TextColor="{StaticResource TextFaint}"
                                   FontSize="9" CharacterSpacing="0.8"
                                   HorizontalOptions="Center" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedPoi.FoodTypeText}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="12" FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   LineBreakMode="WordWrap" MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource CardBackground}"
                            Stroke="{StaticResource WarmBorder}" StrokeThickness="0.5"
                            StrokeShape="RoundRectangle 14" Padding="14">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="💰" FontSize="22" HorizontalOptions="Center" />
                            <Label Text="GIÁ" TextColor="{StaticResource TextFaint}"
                                   FontSize="9" CharacterSpacing="0.8"
                                   HorizontalOptions="Center" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedPoi.PriceRangeText}"
                                   TextColor="{StaticResource Secondary}"
                                   FontSize="12" FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   LineBreakMode="WordWrap" MaxLines="2" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Visit time -->
                <Border BackgroundColor="{StaticResource CardBackground}"
                        Stroke="{StaticResource WarmBorder}" StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource WarmCream}"
                                StrokeShape="RoundRectangle 10"
                                WidthRequest="36" HeightRequest="36"
                                Padding="0" Stroke="{StaticResource WarmBorder}">
                            <Label Text="⏱" FontSize="16"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="THỜI GIAN THAM QUAN" TextColor="{StaticResource TextMuted}"
                                   FontSize="9" CharacterSpacing="1.0" FontAttributes="Bold" />
                            <Label Text="{Binding SelectedPoi.EstimatedTimeText}"
                                   TextColor="{StaticResource TextPrimary}" FontSize="13" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Description -->
                <Border BackgroundColor="{StaticResource CardBackground}"
                        Stroke="{StaticResource WarmBorder}" StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="GIỚI THIỆU" TextColor="{StaticResource TextMuted}"
                               FontSize="9" CharacterSpacing="1.0" FontAttributes="Bold" />
                        <Label Text="{Binding LocalizedDescription}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="13" LineBreakMode="WordWrap" LineHeight="1.5" />
                    </VerticalStackLayout>
                </Border>

                <BoxView HeightRequest="8" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Grid Grid.Row="2"
              BackgroundColor="{StaticResource CardBackground}"
              Padding="16,12,16,18">
            <Grid.Shadow>
                <Shadow Brush="{StaticResource Black}" Offset="0,-2" Radius="10" Opacity="0.05" />
            </Grid.Shadow>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Listen (dark brown) -->
                <Button Grid.Column="0"
                        Text="{Binding LblListenNarration}"
                        Command="{Binding PlayNarrationCommand}"
                        TextColor="{StaticResource White}"
                        BackgroundColor="{StaticResource Primary}"
                        FontSize="12" FontAttributes="Bold"
                        CornerRadius="22" HeightRequest="48"
                        Padding="4,0" />
                <!-- Navigate (outline) -->
                <Button Grid.Column="1"
                        Text="{Binding LblGetDirections}"
                        Command="{Binding NavigateCommand}"
                        BackgroundColor="{StaticResource CardBackground}"
                        TextColor="{StaticResource Primary}"
                        BorderColor="{StaticResource WarmBorder}"
                        BorderWidth="1"
                        FontSize="12"
                        CornerRadius="22" HeightRequest="48"
                        Padding="4,0" />
            </Grid>
        </Grid>
    </Grid>

</ContentPage>
