<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.POIDetailPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             x:DataType="viewmodel:POIDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header with POI Image -->
        <Grid Grid.Row="0" x:Name="HeaderGrid">
            <Image Source="{Binding SelectedPoi.ImageUrl}"
                   Aspect="AspectFill" />
            <BoxView Color="{StaticResource Black}" Opacity="0.4" />

            <!-- Header Overlay -->
            <Grid RowDefinitions="Auto,*" x:Name="HeaderOverlay">
                <!-- Back Button -->
                <Frame Grid.Row="0"
                       BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       WidthRequest="44"
                       HeightRequest="44"
                       Padding="0"
                       HasShadow="False"
                       HorizontalOptions="Start">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="←"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>

                <!-- POI Name and Rating -->
                <VerticalStackLayout Grid.Row="1" VerticalOptions="End" Spacing="6">
                    <Label Text="{Binding SelectedPoi.Name}"
                           TextColor="{StaticResource White}"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <HorizontalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="3">
                            <Label Text="⭐" FontSize="12" />
                            <Label Text="{Binding SelectedPoi.RatingText}"
                                   TextColor="{StaticResource White}"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                        </HorizontalStackLayout>

                        <Frame BackgroundColor="{StaticResource Primary}"
                               CornerRadius="8"
                               Padding="8,3"
                               HasShadow="False">
                            <Label Text="{Binding SelectedPoi.CategoryText}"
                                   TextColor="{StaticResource White}"
                                   FontSize="11" />
                        </Frame>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ContentStack" Spacing="10">

                <!-- Address -->
                <Frame Style="{StaticResource CardFrame}" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍"
                               FontSize="16"
                               VerticalOptions="Start" />
                        <VerticalStackLayout Spacing="2" HorizontalOptions="FillAndExpand">
                            <Label Text="Địa chỉ"
                                   Style="{StaticResource TitleLabel}"
                                   FontSize="13" />
                            <Label Text="{Binding SelectedPoi.Address}"
                                   Style="{StaticResource BodyLabel}"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"
                                   MaxLines="4" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Food Type and Price -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Frame Style="{StaticResource CardFrame}" Padding="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="🍽️" FontSize="18" HorizontalOptions="Center" />
                            <Label Text="Loại món"
                                   Style="{StaticResource CaptionLabel}"
                                   FontSize="10"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding SelectedPoi.FoodTypeText}"
                                   Style="{StaticResource TitleLabel}"
                                   FontSize="12"
                                   HorizontalOptions="Center"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1" Style="{StaticResource CardFrame}" Padding="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="💰" FontSize="18" HorizontalOptions="Center" />
                            <Label Text="Giá"
                                   Style="{StaticResource CaptionLabel}"
                                   FontSize="10"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding SelectedPoi.PriceRangeText}"
                                   Style="{StaticResource TitleLabel}"
                                   FontSize="12"
                                   TextColor="{StaticResource Secondary}"
                                   HorizontalOptions="Center"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Visit Time -->
                <Frame Style="{StaticResource CardFrame}" Padding="12">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="⏱"
                               FontSize="16"
                               VerticalOptions="Center" />
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Thời gian tham quan"
                                   Style="{StaticResource TitleLabel}"
                                   FontSize="13" />
                            <Label Text="{Binding SelectedPoi.EstimatedMinutes, StringFormat='{0} phút'}"
                                   Style="{StaticResource BodyLabel}"
                                   FontSize="12" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>

                <!-- Description -->
                <Frame Style="{StaticResource CardFrame}" Padding="12">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Thông tin"
                               Style="{StaticResource TitleLabel}"
                               FontSize="14" />
                        <Label Text="{Binding SelectedPoi.Description}"
                               Style="{StaticResource BodyLabel}"
                               FontSize="12"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Frame Grid.Row="2"
               BackgroundColor="{StaticResource White}"
               CornerRadius="0"
               Padding="14,10,14,14"
               HasShadow="True">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Grid.Column="0"
                        Text="🔊 Nghe thuyết minh"
                        Command="{Binding PlayNarrationCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        FontSize="12"
                        CornerRadius="22"
                        HeightRequest="44"
                        Padding="4,0" />
                <Button Grid.Column="1"
                        Text="🗺️ Chỉ đường"
                        Command="{Binding NavigateCommand}"
                        BackgroundColor="{StaticResource White}"
                        TextColor="{StaticResource Primary}"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="1.5"
                        FontSize="12"
                        CornerRadius="22"
                        HeightRequest="44"
                        Padding="4,0" />
            </Grid>
        </Frame>
    </Grid>

</ContentPage>
