<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.POIDetailPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             x:DataType="viewmodel:POIDetailViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header with POI Image -->
        <Grid Grid.Row="0" x:Name="HeaderGrid" MinimumHeightRequest="230">
            <Image Source="{Binding SelectedPoi.ImageUrl}"
                   Aspect="AspectFill" />
            <!-- Dark warm overlay -->
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#44000000" Offset="0.0" />
                        <GradientStop Color="#DD1A1208" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
            </Grid>

            <!-- Header Overlay -->
            <Grid RowDefinitions="Auto,*" x:Name="HeaderOverlay" Padding="16,48,16,16">
                <!-- Back Button -->
                <Frame Grid.Row="0"
                       BackgroundColor="#33FFFFFF"
                       CornerRadius="16"
                       WidthRequest="40"
                       HeightRequest="40"
                       Padding="0"
                       HasShadow="False"
                       BorderColor="Transparent"
                       HorizontalOptions="Start">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="←"
                           TextColor="{StaticResource White}"
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>

                <!-- POI Name -->
                <Label Grid.Row="1"
                       VerticalOptions="End"
                       Text="{Binding SelectedPoi.Name}"
                       TextColor="{StaticResource White}"
                       FontSize="20"
                       FontAttributes="Bold" />
            </Grid>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout x:Name="ContentStack" Spacing="10" Padding="16,14">

                <!-- Rating and Category -->
                <HorizontalStackLayout Spacing="10">
                    <HorizontalStackLayout Spacing="3" VerticalOptions="Center">
                        <Label Text="⭐" FontSize="14" VerticalOptions="Center" />
                        <Label Text="{Binding SelectedPoi.RatingText}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Frame BackgroundColor="{StaticResource WarmCream}"
                           CornerRadius="10"
                           Padding="12,5"
                           HasShadow="False"
                           BorderColor="{StaticResource WarmBorder}">
                        <Label Text="{Binding SelectedPoi.CategoryText}"
                               TextColor="{StaticResource Primary}"
                               FontSize="11"
                               FontAttributes="Bold" />
                    </Frame>
                </HorizontalStackLayout>

                <!-- Address Card -->
                <Frame BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       Padding="14"
                       HasShadow="True"
                       BorderColor="{StaticResource WarmBorder}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Frame BackgroundColor="{StaticResource WarmCream}"
                               CornerRadius="10"
                               WidthRequest="36"
                               HeightRequest="36"
                               Padding="0"
                               HasShadow="False"
                               BorderColor="{StaticResource WarmBorder}"
                               VerticalOptions="Start">
                            <Label Text="📍"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="{Binding LblAddress}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextMuted}" />
                            <Label Text="{Binding SelectedPoi.Address}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="13"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Food Type and Price Info Grid -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Frame BackgroundColor="{StaticResource White}"
                           CornerRadius="16"
                           Padding="12"
                           HasShadow="True"
                           BorderColor="{StaticResource WarmBorder}">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="🍽️" FontSize="20" HorizontalOptions="Center" />
                            <Label Text="{Binding LblFoodType}"
                                   TextColor="{StaticResource TextMuted}"
                                   FontSize="10"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding SelectedPoi.FoodTypeText}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Column="1"
                           BackgroundColor="{StaticResource White}"
                           CornerRadius="16"
                           Padding="12"
                           HasShadow="True"
                           BorderColor="{StaticResource WarmBorder}">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="💰" FontSize="20" HorizontalOptions="Center" />
                            <Label Text="{Binding LblPrice}"
                                   TextColor="{StaticResource TextMuted}"
                                   FontSize="10"
                                   HorizontalOptions="Center" />
                            <Label Text="{Binding SelectedPoi.PriceRangeText}"
                                   TextColor="{StaticResource Success}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   LineBreakMode="WordWrap"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Frame>
                </Grid>

                <!-- Visit Time Card -->
                <Frame BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       Padding="14"
                       HasShadow="True"
                       BorderColor="{StaticResource WarmBorder}">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                        <Frame BackgroundColor="{StaticResource WarmCream}"
                               CornerRadius="10"
                               WidthRequest="36"
                               HeightRequest="36"
                               Padding="0"
                               HasShadow="False"
                               BorderColor="{StaticResource WarmBorder}"
                               VerticalOptions="Center">
                            <Label Text="⏱"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="{Binding LblVisitTime}"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextMuted}" />
                            <Label Text="{Binding SelectedPoi.EstimatedTimeText}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontSize="13" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Description Card -->
                <Frame BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       Padding="14"
                       HasShadow="True"
                       BorderColor="{StaticResource WarmBorder}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding LblDescription}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />
                        <Label Text="{Binding SelectedPoi.Description}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="13"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom Action Bar -->
        <Grid Grid.Row="2"
              BackgroundColor="{StaticResource White}"
              Padding="16,10,16,14">
            <Grid.Shadow>
                <Shadow Brush="{StaticResource Black}" Offset="0,-2" Radius="8" Opacity="0.06" />
            </Grid.Shadow>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <!-- Listen Button (amber gradient) -->
                <Button Grid.Column="0"
                        Text="{Binding LblListenNarration}"
                        Command="{Binding PlayNarrationCommand}"
                        TextColor="{StaticResource White}"
                        FontSize="12"
                        FontAttributes="Bold"
                        CornerRadius="22"
                        HeightRequest="46"
                        Padding="4,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E8943A" Offset="0.0" />
                            <GradientStop Color="#C97B28" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <!-- Navigate Button (outline) -->
                <Button Grid.Column="1"
                        Text="{Binding LblGetDirections}"
                        Command="{Binding NavigateCommand}"
                        BackgroundColor="{StaticResource White}"
                        TextColor="{StaticResource Primary}"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="1.5"
                        FontSize="12"
                        CornerRadius="22"
                        HeightRequest="46"
                        Padding="4,0" />
            </Grid>
        </Grid>
    </Grid>

</ContentPage>
