<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.MainPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:MainPageViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <Grid RowDefinitions="Auto,*" Padding="0">
            
            <!-- Header Section with Coral Background -->
            <Frame Grid.Row="0"
                   BackgroundColor="{StaticResource Primary}"
                   CornerRadius="0"
                   x:Name="MainHeader"
                   HasShadow="False"
                   Margin="0,0,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">

                    <!-- App Title -->
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                        <Label Text="HERISTEP AI"
                               TextColor="{StaticResource White}"
                               FontSize="20"
                               FontAttributes="Bold" />
                        <Label Text="ĐÀ NẴNG"
                               TextColor="{StaticResource White}"
                               FontSize="14"
                               FontAttributes="Bold"
                               Opacity="0.9" />
                    </VerticalStackLayout>

                    <!-- Language Switch Button: EN / VI -->
                    <Button Grid.Row="0" Grid.Column="1"
                            Text="{Binding LblLanguageSwitch}"
                            Command="{Binding SwitchLanguageCommand}"
                            BackgroundColor="{StaticResource White}"
                            TextColor="{StaticResource Primary}"
                            FontAttributes="Bold"
                            FontSize="13"
                            WidthRequest="44"
                            HeightRequest="44"
                            CornerRadius="22"
                            Padding="0"
                            VerticalOptions="Start" />

                    <!-- Location Icon -->
                    <Frame Grid.Row="0" Grid.Column="2"
                           BackgroundColor="{StaticResource White}"
                           CornerRadius="16"
                           WidthRequest="44"
                           HeightRequest="44"
                           Padding="0"
                           HasShadow="False"
                           VerticalOptions="Start">
                        <Label Text="📍"
                               FontSize="16"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Frame>

                    <!-- Welcome Message -->
                    <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0" Spacing="2">
                        <Label Text="{Binding LblWelcome}"
                               TextColor="{StaticResource White}"
                               FontSize="12" />
                        <Label Text="{Binding LblAppName}"
                               TextColor="{StaticResource White}"
                               FontSize="13"
                               FontAttributes="Bold" />
                        <Label Text="{Binding LblAppTagline}"
                               TextColor="{StaticResource White}"
                               FontSize="11"
                               Opacity="0.9" />
                    </VerticalStackLayout>

                    <!-- Quick Stats Section -->
                    <Grid Grid.Row="2" Grid.ColumnSpan="3"
                          Margin="0,12,0,0"
                          ColumnDefinitions="*,*,*"
                          ColumnSpacing="8">

                        <!-- Total Tours -->
                        <Frame BackgroundColor="{StaticResource White}"
                               CornerRadius="10"
                               Padding="8,6"
                               HasShadow="False">
                            <VerticalStackLayout Spacing="1">
                                <Label Text="🎯"
                                       FontSize="16"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Tours.Count, StringFormat='{0}'}"
                                       TextColor="{StaticResource Primary}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" />
                                <Label Text="Tours"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="9"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Settings Icon -->
                        <Frame Grid.Column="1"
                               BackgroundColor="{StaticResource White}"
                               CornerRadius="10"
                               Padding="8,6"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSettingsTapped" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="1">
                                <Label Text="⚙️"
                                       FontSize="16"
                                       HorizontalOptions="Center" />
                                <Label Text="Cài đặt"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="9"
                                       HorizontalOptions="Center"
                                       Margin="0,10,0,0" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Refresh Button -->
                        <Frame Grid.Column="2"
                               BackgroundColor="{StaticResource White}"
                               CornerRadius="10"
                               Padding="8,6"
                               HasShadow="False">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshPOIsCommand}" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="1">
                                <Label Text="🔄"
                                       FontSize="16"
                                       HorizontalOptions="Center" />
                                <Label Text="Làm mới"
                                       TextColor="{StaticResource TextSecondary}"
                                       FontSize="9"
                                       HorizontalOptions="Center"
                                       Margin="0,10,0,0" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>
                </Grid>
            </Frame>
            
            <!-- Content Section -->
            <VerticalStackLayout Grid.Row="1" Padding="14,12" Spacing="10">
                
                <!-- Tour Selection Section -->
                <Label Text="{Binding LblChooseTour}"
                       Style="{StaticResource SectionHeader}" />
                
                <!-- Tour Cards Horizontal Scroll -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding Tours}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Tour">
                                <Frame Style="{StaticResource CardFrame}"
                                       HeightRequest="110"
                                       MinimumWidthRequest="150"
                                       Padding="0"
                                       Margin="0,0,6,0">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, Path=SelectTourCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid>
                                        <!-- Tour Image Background -->
                                        <Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               Opacity="0.85" />
                                        <!-- Overlay -->
                                        <BoxView Color="{StaticResource Black}" Opacity="0.35" />
                                        <!-- Tour Name and Price -->
                                        <VerticalStackLayout VerticalOptions="End" Margin="8" Spacing="1">
                                            <Label Text="{Binding Name}"
                                                   TextColor="{StaticResource White}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                            <Label Text="{Binding PriceRangeText}"
                                                   TextColor="{StaticResource White}"
                                                   FontSize="10"
                                                   Opacity="0.9"
                                                   IsVisible="{Binding PriceRangeText, Converter={StaticResource IsNotEmptyConverter}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
                
                <!-- Create New Tour Button -->
                <Button Text="{Binding LblCreateNewTour}"
                        Command="{Binding CreateTourCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        HeightRequest="46"
                        Margin="0,6,0,0" />
                
                <!-- Recent Tours Section -->
                <Label Text="{Binding LblRecentTours}"
                       Style="{StaticResource SectionHeader}" />
                
                <CollectionView ItemsSource="{Binding RecentTours}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Tour">
                            <Frame Style="{StaticResource CardFrame}"
                                   Margin="0,0,0,8"
                                   Padding="0">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, Path=SelectTourCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="85,*" HeightRequest="80">
                                    <!-- Tour Image -->
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           WidthRequest="85">
                                        <Image.Clip>
                                            <RoundRectangleGeometry Rect="0,0,85,80" CornerRadius="12,0,0,12" />
                                        </Image.Clip>
                                    </Image>

                                    <!-- Tour Info -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="10,8"
                                                         VerticalOptions="Center"
                                                         Spacing="3">
                                        <Label Text="{Binding Name}"
                                               Style="{StaticResource TitleLabel}"
                                               FontSize="13"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="⏱"
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="10" />
                                            <Label Text="{Binding EstimatedMinutes, StringFormat='{0} phút'}"
                                                   Style="{StaticResource CaptionLabel}"
                                                   FontSize="11" />
                                            <Label Text="📍"
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="10" />
                                            <Label Text="{Binding POICount, StringFormat='{0} điểm'}"
                                                   Style="{StaticResource CaptionLabel}"
                                                   FontSize="11" />
                                            <Label Text="{Binding PriceRangeText}"
                                                   Style="{StaticResource CaptionLabel}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Primary}"
                                                   IsVisible="{Binding PriceRangeText, Converter={StaticResource IsNotEmptyConverter}}" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                
                <!-- Current Location Status (hidden when not needed) -->
                <Frame BackgroundColor="{StaticResource SecondaryLight}"
                       Padding="12"
                       CornerRadius="12"
                       IsVisible="{Binding ShowLocationStatus}"
                       HasShadow="False">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍" FontSize="16" />
                        <Label Text="{Binding CurrentLocationText}"
                               Style="{StaticResource BodyLabel}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>
                
                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center" />
                
            </VerticalStackLayout>
        </Grid>
    </ScrollView>

</ContentPage>
