<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.MainPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:MainPageViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <Grid RowDefinitions="Auto,*" Padding="0">

            <!-- Hero Header with Amber Gradient -->
            <Grid Grid.Row="0" x:Name="MainHeader" Padding="16,48,16,20">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#C97B28" Offset="0.0" />
                        <GradientStop Color="#E8943A" Offset="0.6" />
                        <GradientStop Color="#F5A84E" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>

                <VerticalStackLayout Spacing="14">

                    <!-- Top Bar: Logo + Lang + Location -->
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                            <Label Text="HERISTEP AI"
                                   TextColor="{StaticResource White}"
                                   FontSize="19"
                                   FontAttributes="Bold"
                                   CharacterSpacing="1" />
                            <Label Text="ĐÀ NẴNG · VIỆT NAM"
                                   TextColor="{StaticResource White}"
                                   FontSize="10"
                                   Opacity="0.85"
                                   CharacterSpacing="0.5" />
                        </VerticalStackLayout>

                        <!-- Language Switch Button -->
                        <Frame Grid.Column="1"
                               BackgroundColor="#33FFFFFF"
                               CornerRadius="14"
                               Padding="0"
                               HasShadow="False"
                               BorderColor="Transparent"
                               WidthRequest="44"
                               HeightRequest="36"
                               VerticalOptions="Center">
                            <Button Text="{Binding LblLanguageSwitch}"
                                    Command="{Binding SwitchLanguageCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource White}"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Padding="0" />
                        </Frame>

                        <!-- Location Icon -->
                        <Frame Grid.Column="2"
                               BackgroundColor="#33FFFFFF"
                               CornerRadius="18"
                               WidthRequest="36"
                               HeightRequest="36"
                               Padding="0"
                               HasShadow="False"
                               BorderColor="Transparent"
                               VerticalOptions="Center">
                            <Label Text="📍"
                                   FontSize="15"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                    </Grid>

                    <!-- Welcome Text -->
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding LblWelcome}"
                               TextColor="{StaticResource White}"
                               FontSize="13"
                               Opacity="0.9" />
                        <Label Text="{Binding LblAppTagline}"
                               TextColor="{StaticResource White}"
                               FontSize="11"
                               Opacity="0.75" />
                    </VerticalStackLayout>

                    <!-- Quick Stats Chips -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">

                        <!-- Total Tours -->
                        <Frame BackgroundColor="#33FFFFFF"
                               CornerRadius="14"
                               Padding="8,10"
                               HasShadow="False"
                               BorderColor="Transparent">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🎯"
                                       FontSize="18"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding Tours.Count, StringFormat='{0}'}"
                                       TextColor="{StaticResource White}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" />
                                <Label Text="Tours"
                                       TextColor="{StaticResource White}"
                                       FontSize="9"
                                       Opacity="0.8"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Settings Chip -->
                        <Frame Grid.Column="1"
                               BackgroundColor="#33FFFFFF"
                               CornerRadius="14"
                               Padding="8,10"
                               HasShadow="False"
                               BorderColor="Transparent">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSettingsTapped" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="⚙️"
                                       FontSize="18"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding LblSettings}"
                                       TextColor="{StaticResource White}"
                                       FontSize="9"
                                       Opacity="0.8"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Refresh Chip -->
                        <Frame Grid.Column="2"
                               BackgroundColor="#33FFFFFF"
                               CornerRadius="14"
                               Padding="8,10"
                               HasShadow="False"
                               BorderColor="Transparent">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding RefreshPOIsCommand}" />
                            </Frame.GestureRecognizers>
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🔄"
                                       FontSize="18"
                                       HorizontalOptions="Center" />
                                <Label Text="{Binding LblRefresh}"
                                       TextColor="{StaticResource White}"
                                       FontSize="9"
                                       Opacity="0.8"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Frame>
                    </Grid>

                </VerticalStackLayout>
            </Grid>

            <!-- Content Section on Cream Background -->
            <VerticalStackLayout Grid.Row="1" Padding="16,14" Spacing="12">

                <!-- Tour Selection Section Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="{Binding LblChooseTour}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="16"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="Xem tất cả →"
                           TextColor="{StaticResource Primary}"
                           FontSize="13"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Tour Cards Horizontal Scroll -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="10" BindableLayout.ItemsSource="{Binding Tours}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Tour">
                                <Frame CornerRadius="16"
                                       HeightRequest="175"
                                       WidthRequest="140"
                                       Padding="0"
                                       Margin="0,0,2,4"
                                       HasShadow="True"
                                       BorderColor="{StaticResource WarmBorder}"
                                       BackgroundColor="{StaticResource White}">
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, Path=SelectTourCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Frame.GestureRecognizers>
                                    <Grid>
                                        <!-- Tour Image -->
                                        <Image Source="{Binding ImageUrl}"
                                               Aspect="AspectFill"
                                               Opacity="0.9" />
                                        <!-- Dark gradient overlay -->
                                        <Grid>
                                            <Grid.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0.3" />
                                                    <GradientStop Color="#CC1E1612" Offset="1.0" />
                                                </LinearGradientBrush>
                                            </Grid.Background>
                                        </Grid>
                                        <!-- Tour Info at Bottom -->
                                        <VerticalStackLayout VerticalOptions="End" Margin="10,10" Spacing="3">
                                            <Label Text="{Binding Name}"
                                                   TextColor="{StaticResource White}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="2" />
                                            <Label Text="{Binding PriceRangeText}"
                                                   TextColor="{StaticResource PrimaryLight}"
                                                   FontSize="10"
                                                   IsVisible="{Binding PriceRangeText, Converter={StaticResource IsNotEmptyConverter}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Create New Tour Button -->
                <Button Text="{Binding LblCreateNewTour}"
                        Command="{Binding CreateTourCommand}"
                        CornerRadius="24"
                        HeightRequest="48"
                        FontSize="14"
                        FontAttributes="Bold"
                        TextColor="{StaticResource White}"
                        Margin="0,2,0,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E8943A" Offset="0.0" />
                            <GradientStop Color="#C97B28" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <!-- Recent Tours Section Header -->
                <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                    <Label Grid.Column="0"
                           Text="{Binding LblRecentTours}"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="16"
                           FontAttributes="Bold"
                           VerticalOptions="Center" />
                </Grid>

                <!-- Recent Tour List -->
                <CollectionView ItemsSource="{Binding RecentTours}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Tour">
                            <Frame BackgroundColor="{StaticResource White}"
                                   CornerRadius="16"
                                   Margin="0,0,0,10"
                                   Padding="0"
                                   HasShadow="True"
                                   BorderColor="{StaticResource WarmBorder}">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainPageViewModel}}, Path=SelectTourCommand}"
                                        CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Grid ColumnDefinitions="90,*" MinimumHeightRequest="80">
                                    <!-- Tour Image -->
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="FillAndExpand"
                                           VerticalOptions="FillAndExpand">
                                        <Image.Clip>
                                            <RoundRectangleGeometry Rect="0,0,90,80" CornerRadius="16,0,0,16" />
                                        </Image.Clip>
                                    </Image>

                                    <!-- Tour Info -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Padding="12,10"
                                                         VerticalOptions="Center"
                                                         Spacing="4">
                                        <Label Text="{Binding Name}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="⏱"
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="10" />
                                            <Label Text="{Binding EstimatedTimeText}"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   FontSize="11" />
                                            <Label Text="📍"
                                                   TextColor="{StaticResource TextMuted}"
                                                   FontSize="10" />
                                            <Label Text="{Binding POICountText}"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   FontSize="11" />
                                        </HorizontalStackLayout>
                                        <Label Text="{Binding PriceRangeText}"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Primary}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1"
                                               IsVisible="{Binding PriceRangeText, Converter={StaticResource IsNotEmptyConverter}}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Location Status -->
                <Frame BackgroundColor="#E8F5E9"
                       Padding="12"
                       CornerRadius="14"
                       IsVisible="{Binding ShowLocationStatus}"
                       HasShadow="False"
                       BorderColor="#C8E6C9">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📍" FontSize="16" />
                        <Label Text="{Binding CurrentLocationText}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="13"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Frame>

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center" />

            </VerticalStackLayout>
        </Grid>
    </ScrollView>

</ContentPage>
