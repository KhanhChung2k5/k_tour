<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.SettingsPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             x:DataType="viewmodel:SettingsPageViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0">
            
            <!-- Header -->
            <Frame BackgroundColor="{StaticResource Primary}"
                   CornerRadius="0"
                   x:Name="SettingsHeader"
                   HasShadow="False">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Cài đặt"
                           TextColor="{StaticResource White}"
                           FontSize="20"
                           FontAttributes="Bold" />
                    <Label Text="Tùy chỉnh ứng dụng của bạn"
                           TextColor="{StaticResource White}"
                           FontSize="12"
                           Opacity="0.9" />
                </VerticalStackLayout>
            </Frame>

            <VerticalStackLayout Padding="14,14" Spacing="12">
                
                <!-- Language Section -->
                <Label Text="Thuyết minh"
                       Style="{StaticResource SectionHeader}" />

                <Frame Style="{StaticResource CardFrame}" Padding="12">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Frame BackgroundColor="{StaticResource PrimaryLight}"
                                   CornerRadius="10"
                                   WidthRequest="36"
                                   HeightRequest="36"
                                   Padding="0"
                                   HasShadow="False">
                                <Label Text="🗣️"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                                <Label Text="Ngôn ngữ thuyết minh"
                                       FontSize="13"
                                       FontAttributes="Bold" />
                                <Label Text="Chọn ngôn ngữ cho audio"
                                       Style="{StaticResource CaptionLabel}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                            <Picker Grid.Column="2"
                                    ItemsSource="{Binding AvailableLanguages}"
                                    SelectedItem="{Binding SelectedLanguage}"
                                    HorizontalOptions="End"
                                    MinimumWidthRequest="90" />
                        </Grid>

                        <BoxView Grid.Row="1"
                                 Color="{StaticResource Gray200}"
                                 HeightRequest="1"
                                 Margin="-12,0" />
                    </Grid>
                </Frame>

                <!-- Voice Gender Section -->
                <Frame Style="{StaticResource CardFrame}" Padding="12" Margin="0,4">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Frame BackgroundColor="{StaticResource Secondary}"
                               CornerRadius="10"
                               WidthRequest="36"
                               HeightRequest="36"
                               Padding="0"
                               HasShadow="False">
                            <Label Text="🎙️"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                            <Label Text="Giọng đọc"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                            <Label Text="Chọn giọng Nam hoặc Nữ"
                                   Style="{StaticResource CaptionLabel}"
                                   FontSize="11" />
                        </VerticalStackLayout>
                        <Picker Grid.Column="2"
                                ItemsSource="{Binding AvailableVoiceGenders}"
                                SelectedItem="{Binding SelectedVoiceGender}"
                                HorizontalOptions="End"
                                MinimumWidthRequest="90" />
                    </Grid>
                </Frame>

                <!-- GPS Section -->
                <Label Text="Vị trí"
                       Style="{StaticResource SectionHeader}" />

                <Frame Style="{StaticResource CardFrame}" Padding="12">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Frame BackgroundColor="{Binding IsLocationEnabled, Converter={StaticResource BoolToColorConverter}}"
                               CornerRadius="10"
                               WidthRequest="36"
                               HeightRequest="36"
                               Padding="0"
                               HasShadow="False">
                            <Label Text="📍"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                            <Label Text="Trạng thái GPS"
                                   FontSize="13"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding GpsStatusText}"
                                   Style="{StaticResource CaptionLabel}"
                                   FontSize="11" />
                        </VerticalStackLayout>
                        <Frame Grid.Column="2"
                               BackgroundColor="{Binding IsLocationEnabled, Converter={StaticResource BoolToColorConverter}}"
                               CornerRadius="8"
                               Padding="8,4"
                               HasShadow="False">
                            <Label Text="{Binding IsLocationEnabled, Converter={StaticResource BoolToStatusConverter}}"
                                   TextColor="{StaticResource White}"
                                   FontSize="11"
                                   FontAttributes="Bold" />
                        </Frame>
                    </Grid>
                </Frame>
                
                <!-- About Section -->
                <Label Text="Thông tin"
                       Style="{StaticResource SectionHeader}" />

                <Frame Style="{StaticResource CardFrame}" Padding="12">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Frame BackgroundColor="{StaticResource SecondaryLight}"
                                   CornerRadius="10"
                                   WidthRequest="36"
                                   HeightRequest="36"
                                   Padding="0"
                                   HasShadow="False">
                                <Label Text="ℹ️"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                                <Label Text="Phiên bản"
                                       FontSize="13"
                                       FontAttributes="Bold" />
                                <Label Text="HeriStepAI Mobile"
                                       Style="{StaticResource CaptionLabel}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="1.0.0"
                                   FontSize="12"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <BoxView Color="{StaticResource Gray200}"
                                 HeightRequest="1"
                                 Margin="-12,0" />

                        <Grid ColumnDefinitions="Auto,*">
                            <Frame BackgroundColor="{StaticResource Gray100}"
                                   CornerRadius="10"
                                   WidthRequest="36"
                                   HeightRequest="36"
                                   Padding="0"
                                   HasShadow="False">
                                <Label Text="📧"
                                       FontSize="16"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Margin="10,0" VerticalOptions="Center">
                                <Label Text="Liên hệ hỗ trợ"
                                       FontSize="13"
                                       FontAttributes="Bold" />
                                <Label Text="support@heristepai.com"
                                       Style="{StaticResource CaptionLabel}"
                                       FontSize="11" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Sync Button -->
                <Button Text="Đồng bộ dữ liệu"
                        Command="{Binding SyncDataCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource White}"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        HeightRequest="46"
                        Margin="0,12,0,0" />
                
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
