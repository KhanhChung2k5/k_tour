<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.SettingsPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             x:DataType="viewmodel:SettingsPageViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="0" Spacing="0">

            <!-- Hero Header with Amber Gradient -->
            <Grid x:Name="SettingsHeader" Padding="16,48,16,22">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#C97B28" Offset="0.0" />
                        <GradientStop Color="#E8943A" Offset="0.6" />
                        <GradientStop Color="#F5A84E" Offset="1.0" />
                    </LinearGradientBrush>
                </Grid.Background>
                <VerticalStackLayout Spacing="3">
                    <Label Text="{Binding LblSettingsTitle}"
                           TextColor="{StaticResource White}"
                           FontSize="22"
                           FontAttributes="Bold" />
                    <Label Text="{Binding LblSettingsSubtitle}"
                           TextColor="{StaticResource White}"
                           FontSize="12"
                           Opacity="0.85" />
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Padding="16,14" Spacing="12">

                <!-- Tài khoản Section -->
                <Label Text="{Binding LblAccount}"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="15"
                       FontAttributes="Bold"
                       Margin="0,0,0,2" />

                <Frame BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       Padding="14"
                       HasShadow="True"
                       BorderColor="{StaticResource WarmBorder}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="Auto,*">
                            <Frame BackgroundColor="{StaticResource WarmCream}"
                                   CornerRadius="12"
                                   WidthRequest="40"
                                   HeightRequest="40"
                                   Padding="0"
                                   HasShadow="False"
                                   BorderColor="{StaticResource WarmBorder}">
                                <Label Text="👤"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                                <Label Text="{Binding AccountDisplayName}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding AccountEmail}"
                                       FontSize="12"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </Grid>
                        <BoxView Color="{StaticResource WarmBorder}" HeightRequest="1" Margin="-14,0" />
                        <Button Text="{Binding LblLogout}"
                                Command="{Binding LogoutCommand}"
                                TextColor="#DC2626"
                                FontSize="14"
                                FontAttributes="Bold"
                                BackgroundColor="Transparent"
                                BorderColor="#FECACA"
                                BorderWidth="1"
                                CornerRadius="12"
                                HeightRequest="44" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Narration Section Header -->
                <Label Text="{Binding LblNarration}"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="15"
                       FontAttributes="Bold"
                       Margin="0,0,0,2" />

                <!-- Language Setting -->
                <Frame BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       Padding="14"
                       HasShadow="True"
                       BorderColor="{StaticResource WarmBorder}">
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Frame BackgroundColor="{StaticResource WarmCream}"
                                   CornerRadius="12"
                                   WidthRequest="40"
                                   HeightRequest="40"
                                   Padding="0"
                                   HasShadow="False"
                                   BorderColor="{StaticResource WarmBorder}">
                                <Label Text="🗣️"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                                <Label Text="{Binding LblNarrationLanguage}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding LblNarrationLanguageHint}"
                                       FontSize="11"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <Picker Grid.Column="2"
                                    ItemsSource="{Binding AvailableLanguages}"
                                    SelectedItem="{Binding SelectedLanguage}"
                                    HorizontalOptions="End"
                                    MinimumWidthRequest="90"
                                    TextColor="{StaticResource TextPrimary}" />
                        </Grid>

                        <BoxView Grid.Row="1"
                                 Color="{StaticResource WarmBorder}"
                                 HeightRequest="1"
                                 Margin="-14,0" />
                    </Grid>
                </Frame>

                <!-- Voice Gender Setting -->
                <Frame BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       Padding="14"
                       HasShadow="True"
                       BorderColor="{StaticResource WarmBorder}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Frame BackgroundColor="#E8F5E9"
                               CornerRadius="12"
                               WidthRequest="40"
                               HeightRequest="40"
                               Padding="0"
                               HasShadow="False"
                               BorderColor="#C8E6C9">
                            <Label Text="🎙️"
                                   FontSize="18"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                            <Label Text="{Binding LblVoiceGender}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding LblVoiceGenderHint}"
                                   FontSize="11"
                                   TextColor="{StaticResource TextMuted}" />
                        </VerticalStackLayout>
                        <Picker Grid.Column="2"
                                ItemsSource="{Binding AvailableVoiceGenders}"
                                SelectedItem="{Binding SelectedVoiceGender}"
                                HorizontalOptions="End"
                                MinimumWidthRequest="90"
                                TextColor="{StaticResource TextPrimary}" />
                    </Grid>
                </Frame>

                <!-- Location Section Header -->
                <Label Text="{Binding LblLocation}"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="15"
                       FontAttributes="Bold"
                       Margin="0,4,0,2" />

                <!-- GPS Status -->
                <Frame BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       Padding="14"
                       HasShadow="True"
                       BorderColor="{StaticResource WarmBorder}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Frame BackgroundColor="{Binding IsLocationEnabled, Converter={StaticResource BoolToColorConverter}}"
                               CornerRadius="12"
                               WidthRequest="40"
                               HeightRequest="40"
                               Padding="0"
                               HasShadow="False"
                               BorderColor="Transparent">
                            <Label Text="📍"
                                   FontSize="18"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                            <Label Text="{Binding LblGpsStatus}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding GpsStatusText}"
                                   FontSize="11"
                                   TextColor="{StaticResource TextMuted}" />
                        </VerticalStackLayout>
                        <Frame Grid.Column="2"
                               BackgroundColor="{Binding IsLocationEnabled, Converter={StaticResource BoolToColorConverter}}"
                               CornerRadius="10"
                               Padding="10,5"
                               HasShadow="False"
                               BorderColor="Transparent">
                            <Label Text="{Binding IsLocationEnabled, Converter={StaticResource BoolToStatusConverter}}"
                                   TextColor="{StaticResource White}"
                                   FontSize="11"
                                   FontAttributes="Bold" />
                        </Frame>
                    </Grid>
                </Frame>

                <!-- About Section Header -->
                <Label Text="{Binding LblInfo}"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="15"
                       FontAttributes="Bold"
                       Margin="0,4,0,2" />

                <!-- App Info Card -->
                <Frame BackgroundColor="{StaticResource White}"
                       CornerRadius="16"
                       Padding="14"
                       HasShadow="True"
                       BorderColor="{StaticResource WarmBorder}">
                    <VerticalStackLayout Spacing="14">
                        <!-- Version Row -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Frame BackgroundColor="#EDE7F6"
                                   CornerRadius="12"
                                   WidthRequest="40"
                                   HeightRequest="40"
                                   Padding="0"
                                   HasShadow="False"
                                   BorderColor="#D1C4E9">
                                <Label Text="ℹ️"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                                <Label Text="{Binding LblVersion}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="HeriStepAI Mobile"
                                       FontSize="11"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2"
                                   Text="1.0.3"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <BoxView Color="{StaticResource WarmBorder}"
                                 HeightRequest="1"
                                 Margin="-14,0" />

                        <!-- Contact Row -->
                        <Grid ColumnDefinitions="Auto,*">
                            <Frame BackgroundColor="#E3F2FD"
                                   CornerRadius="12"
                                   WidthRequest="40"
                                   HeightRequest="40"
                                   Padding="0"
                                   HasShadow="False"
                                   BorderColor="#BBDEFB">
                                <Label Text="📧"
                                       FontSize="18"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0" VerticalOptions="Center">
                                <Label Text="{Binding LblContactSupport}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="support@heristepai.com"
                                       FontSize="11"
                                       TextColor="{StaticResource TextMuted}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Sync Button -->
                <Button Text="{Binding LblSyncData}"
                        Command="{Binding SyncDataCommand}"
                        TextColor="{StaticResource White}"
                        FontSize="14"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        HeightRequest="48"
                        Margin="0,8,0,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#E8943A" Offset="0.0" />
                            <GradientStop Color="#C97B28" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
