<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             x:Class="HeriStepAI.Mobile.Views.AuthPage"
             x:DataType="viewmodel:AuthViewModel"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  LOGIN VIEW                                            -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ScrollView IsVisible="{Binding ShowLogin}">
            <Grid RowDefinitions="280,*">

                <!-- Amber Hero -->
                <Grid Grid.Row="0" BackgroundColor="#E8943A">
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10" Padding="24">
                        <Border BackgroundColor="#33FFFFFF" StrokeShape="RoundRectangle 36"
                                WidthRequest="72" HeightRequest="72" Padding="0"
                                Stroke="Transparent" HorizontalOptions="Center">
                            <Image x:Name="HeroImage" WidthRequest="50" HeightRequest="50"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="HERISTEP AI" TextColor="{StaticResource White}"
                               FontSize="26" FontAttributes="Bold" CharacterSpacing="2"
                               HorizontalOptions="Center" />
                        <Label Text="Du lịch thông minh · Đà Nẵng"
                               TextColor="{StaticResource White}" FontSize="13"
                               Opacity="0.85" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Login Card -->
                <Border Grid.Row="1" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 28"
                        Padding="28,32" Margin="0,-28,0,0" Stroke="Transparent">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="12" Opacity="0.08" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">

                        <Label Text="Đăng nhập" TextColor="{StaticResource TextPrimary}"
                               FontSize="22" FontAttributes="Bold" />

                        <!-- Error -->
                        <Border BackgroundColor="#FEF2F2" Stroke="#FECACA" StrokeShape="RoundRectangle 10"
                                Padding="12,10" IsVisible="{Binding HasError}">
                            <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="13" />
                        </Border>

                        <!-- Success (e.g. after register) -->
                        <Border BackgroundColor="#ECFDF5" Stroke="#A7F3D0" StrokeShape="RoundRectangle 10"
                                Padding="12,10" IsVisible="{Binding HasSuccess}">
                            <Label Text="{Binding SuccessMessage}" TextColor="#059669" FontSize="13" />
                        </Border>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email" TextColor="{StaticResource TextSecondary}"
                                   FontSize="13" FontAttributes="Bold" />
                            <Border BackgroundColor="{StaticResource WarmCream}" Stroke="{StaticResource WarmBorder}"
                                    StrokeShape="RoundRectangle 12" Padding="4,0">
                                <Entry Text="{Binding LoginEmail}" Placeholder="your@email.com"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="Transparent" Keyboard="Email"
                                       FontSize="15" Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Mật khẩu" TextColor="{StaticResource TextSecondary}"
                                   FontSize="13" FontAttributes="Bold" />
                            <Border BackgroundColor="{StaticResource WarmCream}" Stroke="{StaticResource WarmBorder}"
                                    StrokeShape="RoundRectangle 12" Padding="4,0">
                                <Entry Text="{Binding LoginPassword}" Placeholder="••••••"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="Transparent" IsPassword="True"
                                       FontSize="15" ReturnType="Done"
                                       ReturnCommand="{Binding LoginCommand}" Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Login Button -->
                        <Button Command="{Binding LoginCommand}" CornerRadius="14" HeightRequest="52"
                                FontSize="16" FontAttributes="Bold" TextColor="{StaticResource White}"
                                BackgroundColor="{StaticResource Primary}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                                Text="Đăng nhập" Margin="0,4,0,0" />

                        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                           Color="{StaticResource Primary}" HorizontalOptions="Center" />

                        <!-- Divider -->
                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12" Margin="0,4">
                            <BoxView Grid.Column="0" BackgroundColor="{StaticResource WarmBorder}"
                                     HeightRequest="1" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="hoặc" TextColor="{StaticResource TextMuted}" FontSize="13" />
                            <BoxView Grid.Column="2" BackgroundColor="{StaticResource WarmBorder}"
                                     HeightRequest="1" VerticalOptions="Center" />
                        </Grid>

                        <!-- Go to Register -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Chưa có tài khoản?" TextColor="{StaticResource TextSecondary}" FontSize="14" />
                            <Label Text="Đăng ký ngay" TextColor="{StaticResource Primary}"
                                   FontSize="14" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="16" Color="Transparent" />
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!--  REGISTER VIEW                                         -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ScrollView IsVisible="{Binding ShowRegister}">
            <Grid RowDefinitions="200,*">

                <!-- Amber Hero (shorter) -->
                <Grid Grid.Row="0" BackgroundColor="#E8943A">

                    <!-- Back button -->
                    <Border BackgroundColor="#33FFFFFF" StrokeShape="RoundRectangle 18"
                            WidthRequest="36" HeightRequest="36" Padding="0"
                            Stroke="Transparent"
                            HorizontalOptions="Start" VerticalOptions="Start"
                            Margin="16,48,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="←" TextColor="{StaticResource White}" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="6" Padding="24">
                        <Label Text="Tạo tài khoản mới" TextColor="{StaticResource White}"
                               FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Đăng ký để lưu hành trình của bạn"
                               TextColor="{StaticResource White}" FontSize="13"
                               Opacity="0.85" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Register Card -->
                <Border Grid.Row="1" BackgroundColor="{StaticResource White}" StrokeShape="RoundRectangle 28"
                        Padding="28,28" Margin="0,-24,0,0" Stroke="Transparent">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="12" Opacity="0.08" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">

                        <!-- Error -->
                        <Border BackgroundColor="#FEF2F2" Stroke="#FECACA" StrokeShape="RoundRectangle 10"
                                Padding="12,10" IsVisible="{Binding HasError}">
                            <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="13" />
                        </Border>

                        <!-- Full Name -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Họ và tên" TextColor="{StaticResource TextSecondary}"
                                   FontSize="13" FontAttributes="Bold" />
                            <Border BackgroundColor="{StaticResource WarmCream}" Stroke="{StaticResource WarmBorder}"
                                    StrokeShape="RoundRectangle 12" Padding="4,0">
                                <Entry Text="{Binding FullName}" Placeholder="Nguyễn Văn A"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="Transparent" FontSize="15" Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Email -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Email" TextColor="{StaticResource TextSecondary}"
                                   FontSize="13" FontAttributes="Bold" />
                            <Border BackgroundColor="{StaticResource WarmCream}" Stroke="{StaticResource WarmBorder}"
                                    StrokeShape="RoundRectangle 12" Padding="4,0">
                                <Entry Text="{Binding RegEmail}" Placeholder="your@email.com"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="Transparent" Keyboard="Email"
                                       FontSize="15" Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Mật khẩu" TextColor="{StaticResource TextSecondary}"
                                   FontSize="13" FontAttributes="Bold" />
                            <Border BackgroundColor="{StaticResource WarmCream}" Stroke="{StaticResource WarmBorder}"
                                    StrokeShape="RoundRectangle 12" Padding="4,0">
                                <Entry Text="{Binding RegPassword}" Placeholder="Tối thiểu 6 ký tự"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="Transparent" IsPassword="True"
                                       FontSize="15" Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Confirm Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Xác nhận mật khẩu" TextColor="{StaticResource TextSecondary}"
                                   FontSize="13" FontAttributes="Bold" />
                            <Border BackgroundColor="{StaticResource WarmCream}" Stroke="{StaticResource WarmBorder}"
                                    StrokeShape="RoundRectangle 12" Padding="4,0">
                                <Entry Text="{Binding ConfirmPassword}" Placeholder="Nhập lại mật khẩu"
                                       PlaceholderColor="{StaticResource TextMuted}"
                                       TextColor="{StaticResource TextPrimary}"
                                       BackgroundColor="Transparent" IsPassword="True"
                                       FontSize="15" ReturnType="Done"
                                       ReturnCommand="{Binding RegisterCommand}" Margin="8,0" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Certificate note -->
                        <Border BackgroundColor="#FFF8F0" Stroke="{StaticResource WarmBorder}"
                                StrokeShape="RoundRectangle 10" Padding="12,10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🎁" FontSize="16" VerticalOptions="Center" />
                                <Label Text="Sau mỗi ngày tham quan, bạn sẽ nhận email tổng kết hành trình!"
                                       TextColor="{StaticResource TextSecondary}" FontSize="12"
                                       LineBreakMode="WordWrap" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Register Button -->
                        <Button Command="{Binding RegisterCommand}" CornerRadius="14" HeightRequest="52"
                                FontSize="16" FontAttributes="Bold" TextColor="{StaticResource White}"
                                BackgroundColor="{StaticResource Primary}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"
                                Text="Tạo tài khoản" Margin="0,4,0,0" />

                        <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                           Color="{StaticResource Primary}" HorizontalOptions="Center" />

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                            <Label Text="Đã có tài khoản?" TextColor="{StaticResource TextSecondary}" FontSize="14" />
                            <Label Text="Đăng nhập" TextColor="{StaticResource Primary}"
                                   FontSize="14" FontAttributes="Bold">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                        <BoxView HeightRequest="16" Color="Transparent" />
                    </VerticalStackLayout>
                </Border>

            </Grid>
        </ScrollView>

    </Grid>
</ContentPage>
