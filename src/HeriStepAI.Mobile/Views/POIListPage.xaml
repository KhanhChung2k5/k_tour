<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="HeriStepAI.Mobile.Views.POIListPage"
             xmlns:viewmodel="clr-namespace:HeriStepAI.Mobile.ViewModels"
             xmlns:models="clr-namespace:HeriStepAI.Mobile.Models"
             x:DataType="viewmodel:POIListViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search Bar Section -->
        <Grid Grid.Row="0"
              x:Name="SearchTopBar"
              BackgroundColor="{StaticResource White}"
              Padding="16,48,16,12">
            <Grid.Shadow>
                <Shadow Brush="{StaticResource Black}" Offset="0,2" Radius="6" Opacity="0.04" />
            </Grid.Shadow>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                <!-- Back Button -->
                <Frame Grid.Column="0"
                       BackgroundColor="{StaticResource WarmCream}"
                       CornerRadius="16"
                       WidthRequest="40"
                       HeightRequest="40"
                       Padding="0"
                       HasShadow="False"
                       BorderColor="{StaticResource WarmBorder}">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Frame.GestureRecognizers>
                    <Label Text="←"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="16"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>

                <!-- Search Entry -->
                <Frame Grid.Column="1"
                       BackgroundColor="{StaticResource WarmCream}"
                       CornerRadius="20"
                       Padding="12,0"
                       HasShadow="False"
                       BorderColor="{StaticResource WarmBorder}"
                       HeightRequest="40">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Text="🔍"
                               FontSize="13"
                               VerticalOptions="Center"
                               TextColor="{StaticResource TextMuted}"
                               Margin="0,0,6,0" />
                        <Entry Grid.Column="1"
                               Placeholder="{Binding LblSearchPlaces}"
                               Text="{Binding SearchText}"
                               BackgroundColor="Transparent"
                               FontSize="13"
                               VerticalOptions="Center"
                               PlaceholderColor="{StaticResource TextMuted}"
                               TextColor="{StaticResource TextPrimary}" />
                    </Grid>
                </Frame>
            </Grid>
        </Grid>

        <!-- Category Filter Tabs -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    BackgroundColor="{StaticResource White}">
            <HorizontalStackLayout Padding="16,8,16,10" Spacing="8">
                <Button Text="{Binding LblCatAll}"
                        Command="{Binding SelectCategoryCommand}"
                        CommandParameter="0"
                        FontSize="12"
                        HeightRequest="32"
                        CornerRadius="16"
                        Padding="14,0"
                        BackgroundColor="{Binding SelectedCategory, Converter={StaticResource CategoryColorConverter}, ConverterParameter='0'}"
                        TextColor="{Binding SelectedCategory, Converter={StaticResource CategoryTextColorConverter}, ConverterParameter='0'}" />
                <Button Text="{Binding LblCatSightseeing}"
                        Command="{Binding SelectCategoryCommand}"
                        CommandParameter="1"
                        FontSize="12"
                        HeightRequest="32"
                        CornerRadius="16"
                        Padding="14,0"
                        BackgroundColor="{Binding SelectedCategory, Converter={StaticResource CategoryColorConverter}, ConverterParameter='1'}"
                        TextColor="{Binding SelectedCategory, Converter={StaticResource CategoryTextColorConverter}, ConverterParameter='1'}" />
                <Button Text="{Binding LblCatFood}"
                        Command="{Binding SelectCategoryCommand}"
                        CommandParameter="2"
                        FontSize="12"
                        HeightRequest="32"
                        CornerRadius="16"
                        Padding="14,0"
                        BackgroundColor="{Binding SelectedCategory, Converter={StaticResource CategoryColorConverter}, ConverterParameter='2'}"
                        TextColor="{Binding SelectedCategory, Converter={StaticResource CategoryTextColorConverter}, ConverterParameter='2'}" />
                <Button Text="{Binding LblCatAccommodation}"
                        Command="{Binding SelectCategoryCommand}"
                        CommandParameter="3"
                        FontSize="12"
                        HeightRequest="32"
                        CornerRadius="16"
                        Padding="14,0"
                        BackgroundColor="{Binding SelectedCategory, Converter={StaticResource CategoryColorConverter}, ConverterParameter='3'}"
                        TextColor="{Binding SelectedCategory, Converter={StaticResource CategoryTextColorConverter}, ConverterParameter='3'}" />
            </HorizontalStackLayout>
        </ScrollView>

        <!-- POI List -->
        <RefreshView Grid.Row="2"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsRefreshing}">
            <CollectionView ItemsSource="{Binding FilteredPOIs}"
                            SelectionMode="None"
                            Margin="16,8">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:POI">
                        <Frame BackgroundColor="{StaticResource White}"
                               CornerRadius="16"
                               Padding="0"
                               Margin="0,0,0,10"
                               HasShadow="True"
                               BorderColor="{StaticResource WarmBorder}"
                               IsClippedToBounds="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectPOICommand}"
                                    CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>

                            <Grid ColumnDefinitions="95,*" MinimumHeightRequest="88">
                                <!-- POI Image -->
                                <Image Grid.Column="0"
                                       Source="{Binding ImageUrl}"
                                       Aspect="AspectFill"
                                       HorizontalOptions="FillAndExpand"
                                       VerticalOptions="FillAndExpand">
                                    <Image.Clip>
                                        <RoundRectangleGeometry Rect="0,0,95,88" CornerRadius="16,0,0,16" />
                                    </Image.Clip>
                                </Image>

                                <!-- POI Info -->
                                <VerticalStackLayout Grid.Column="1"
                                                     Padding="12,10"
                                                     Spacing="5"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2" />

                                    <HorizontalStackLayout Spacing="3">
                                        <Label Text="⭐"
                                               FontSize="10"
                                               TextColor="{StaticResource StarColor}" />
                                        <Label Text="{Binding RatingText}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Label Text="{Binding ReviewCount, StringFormat='({0})'}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextMuted}" />
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="10">
                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="⏱"
                                                   FontSize="10"
                                                   TextColor="{StaticResource Primary}" />
                                            <Label Text="{Binding EstimatedTimeText}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="3">
                                            <Label Text="📍"
                                                   FontSize="10"
                                                   TextColor="{StaticResource Primary}" />
                                            <Label Text="{Binding DistanceText}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- Empty State -->
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10"
                                         Padding="40">
                        <Label Text="📍"
                               FontSize="40"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.LblNoPlacesFound}"
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="15"
                               FontAttributes="Bold"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.LblTryDifferentSearch}"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="13"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="3"
              BackgroundColor="#80F7F2EC"
              IsVisible="{Binding IsLoading}">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               WidthRequest="44"
                               HeightRequest="44" />
        </Grid>
    </Grid>

</ContentPage>
