# Supabase Database Connection
# Format: postgresql://postgres:[PASSWORD]@[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_CONNECTION_STRING=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Settings
JWT_SECRET_KEY=MySuperSecretKey123!@#$%^&*()
JWT_ISSUER=HeriStepAI
JWT_AUDIENCE=HeriStepAIUsers

# Supabase API Keys 
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
